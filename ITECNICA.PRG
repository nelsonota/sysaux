FUNCTION ITECNICA()
LOCAL  GETLIST:={},TELA2
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN

MEMVAR FICHA,RECEBE,CLIFOR,DATENT,ITEM,ORCAMENT,DATORC
MEMVAR DATAPR,DATEXE,DATEXE2,DATSAI,MECVEN,GARANTIA,VALMO,VALITOT,NOTA

MEMVAR MARCA,MODELO,COR,ANO,NSERIE,TANQUE,AVAR1,AVAR2,AVAR3,SOLICLI1,SOLICLI2,SOLICLI3
MEMVAR ORIENT1,ORIENT2,ORIENT3,PLACA,SERV,TIPOKM,QTDKM

FICHA  :=0
GARANTIA:=SPACE(LEN(TECNICA->GARANTIA_V))
CLIFOR  :=SPACE(LEN(TECNICA->CLIFOR_V))
ITEM    :=SPACE(LEN(TECNICA->ITEM_V))
ORCAMENT:=SPACE(LEN(TECNICA->ORCAMENT_V))
MECVEN  :=SPACE(LEN(TECNICA->MECVEN_V))
DATENT  :=CTOD("  /  /  ")
MARCA   :=SPACE(LEN(TECNICA->MARCA_V))
MODELO  :=SPACE(LEN(TECNICA->MODELO_V))
NSERIE  :=SPACE(LEN(TECNICA->NSERIE_V))
TIPOKM  :=SPACE(1)
QTDKM   :=0
ANO     :=SPACE(LEN(TECNICA->ANO_V))
COR     :=SPACE(LEN(TECNICA->COR_V))
TANQUE  :=SPACE(LEN(TECNICA->TANQUE_V))
PLACA   :=SPACE(LEN(TECNICA->PLACA_V))
SERV    :=SPACE(LEN(TECNICA->SERV_V))
AVAR1   :=SPACE(LEN(TECNICA->AVAR1_V))
AVAR2   :=SPACE(LEN(TECNICA->AVAR2_V))
AVAR3   :=SPACE(LEN(TECNICA->AVAR3_V))
SOLICLI1:=SPACE(LEN(TECNICA->SOLICLI1_V))
SOLICLI2:=SPACE(LEN(TECNICA->SOLICLI2_V))
SOLICLI3:=SPACE(LEN(TECNICA->SOLICLI3_V))
ORIENT1:=SPACE(LEN(TECNICA->ORIENT1_V))
ORIENT2:=SPACE(LEN(TECNICA->ORIENT2_V))
ORIENT3:=SPACE(LEN(TECNICA->ORIENT3_V))
DO WHILE .T.
//   FICHA  :=CONFIG->TECNICA_V+1
   SET KEY -2 TO T_CLIFOR()
   @ 01,15 GET FICHA PICT "99999" VALID(! EMPTY(FICHA) .AND. !TECNICA->(DBSEEK(STRZERO(FICHA,5,0))))
   @ 01,21 SAY "Garantia :" GET GARANTIA PICT "@K!"
   @ 05,01 CLEAR TO 09,78
   @ 05,02 SAY "Cliente    :" GET CLIFOR VALID(LASTKEY()=5 .OR. SEA_CLIFOR(CLIFOR,5,22,"C") .AND. TECFUN())
   @ 13,02 SAY "Fazer Or‡amento ?" GET ORCAMENT PICT "@!" VALID(ORCAMENT$"SN")
   @ 14,16 GET SERV VALID(SEA_SERV(SERV,14,20))
   @ 20,17 GET DATENT VALID(!EMPTY(DATENT))
   READ
   IF LASTKEY()=27
      @ 01,45 CLEAR TO 01,78
      EXIT
   ENDIF
   TELA2:=SAVESCREEN()
   DO WHILE .T.
      @ 01,01 CLEAR TO 21,78
      @ 01,01 SAY PADC("Descri‡ao do Servi‡o … Executar",78) COLOR CORTIT
      @ 02,01 TO 02,78
      @ 03,02 SAY "Servi‡o para :" GET ITEM PICT "@K!S20"
      @ 03,43 SAY "Marca :" GET MARCA PICT "@K!"
      @ 04,02 SAY "Modelo       :" GET MODELO PICT "@K!" 
      @ 04,45 SAY "Ano :" GET ANO PICT "@K!"
      @ 05,02 SAY "Cor          :" GET COR PICT "@K!"
      IF CONFIG->KMSERIE_V="S"
         @ 05,39 SAY "N§. S‚rie :" GET NSERIE PICT "@K!"
      ELSE
        @ 05,43 SAY "Km-Ml :" GET TIPOKM PICT "@K!" VALID(TIPOKM$"KM")
        @ 05,53 GET QTDKM PICT "@R 999999.9"
      ENDIF
      @ 06,02 SAY "Placa/Patrim.:" GET PLACA PICT "@K!"
      @ 06,42 SAY "Tanque :" GET TANQUE WHEN FUEL()
      @ 07,01 TO 07,78
      @ 08,01 SAY PADC("Avarias / Observa‡oes",78) COLOR CORTIT
      @ 09,02 GET AVAR1
      @ 10,02 GET AVAR2
      @ 11,02 GET AVAR3
      @ 12,01 TO 12,78
      @ 13,01 SAY PADC("Servi‡os Solicitados pelo Cliente",78) COLOR CORTIT
      @ 14,02 GET SOLICLI1
      @ 15,02 GET SOLICLI2
      @ 16,02 GET SOLICLI3
      @ 17,01 TO 17,78
      @ 18,01 SAY PADC("Orienta‡ao ao Mecƒnico / Servi‡os … Executar",78) COLOR CORTIT
      @ 19,02 GET ORIENT1
      @ 20,02 GET ORIENT2
      @ 21,02 GET ORIENT3
      READ
      IF LASTKEY()=27
         EXIT
      ENDIF
      EXIT
   ENDDO
   RESTSCREEN(,,,,TELA2)
   IF LASTKEY()=27
      LOOP
   ENDIF
   IF CONFIRMA(20,20,"Confirma todos os dados ?")
      //IF CONFIG->(RECLOCK())
//         CONFIG->TECNICA_V:=CONFIG->TECNICA_V+1
//         FICHA:=CONFIG->TECNICA_V
//         CONFIG->(DBUNLOCK())
         IF CLIFOR->(DBSEEK(CLIFOR)) .AND. CLIFOR->(RECLOCK(5))
            CLIFOR->DATTEC_V:=DATE()
            CLIFOR->ULTTEC_V:=STRZERO(FICHA,5,0)
            CLIFOR->(DBUNLOCK())
         ENDIF
         IF TECNICA->(ADDREC())
            TECNICA->CODIGO_V  :=STRZERO(FICHA,5,0)
            TECNICA->GARANTIA_V:=GARANTIA
            TECNICA->CLIFOR_V  :=CLIFOR
            TECNICA->ITEM_V    :=ITEM
            TECNICA->ORCAMENT_V:=ORCAMENT
            TECNICA->SERV_V    :=SERV
            TECNICA->DATENT_V  :=DATENT
            TECNICA->NOMSEN_V  :=NOMSEN
            TECNICA->MARCA_V   :=MARCA
            TECNICA->MODELO_V  :=MODELO
            TECNICA->NSERIE_V  :=NSERIE
            TECNICA->QTDKM_V   :=QTDKM
            TECNICA->TIPOKM_V  :=TIPOKM
            TECNICA->ANO_V     :=ANO
            TECNICA->COR_V     :=COR
            TECNICA->TANQUE_V  :=TANQUE
            TECNICA->PLACA_V   :=PLACA
            TECNICA->AVAR1_V   :=AVAR1
            TECNICA->AVAR2_V   :=AVAR2
            TECNICA->AVAR3_V   :=AVAR3
            TECNICA->SOLICLI1_V:=SOLICLI1
            TECNICA->SOLICLI2_V:=SOLICLI2
            TECNICA->SOLICLI3_V:=SOLICLI3
            TECNICA->ORIENT1_V :=ORIENT1
            TECNICA->ORIENT2_V :=ORIENT2
            TECNICA->ORIENT3_V :=ORIENT3
            TECNICA->(DBUNLOCK())
            IF CONFIRMA(20,20,"Deseja imprimir a ficha de recep‡ao ?")
               IMPRECEPCAO()
            ENDIF
            EXIT
         ENDIF
      //ENDIF
   ENDIF
ENDDO
SET KEY -2 TO
RETURN(.T.)