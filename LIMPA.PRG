FUNCTION LIMPA()
SET DATE TO BRIT
DBUSEAREA(.T.,,"TECNICA","TECNICA",.T.)
SET INDEX TO TECNI11,TECNI12,TECNI13,TECNI14,TECNI15,TECNI16,TECNI17,TECNI18,TECNI19
TECNICA->(DBGOTOP())
DBUSEAREA(.T.,,"TECNICA2","TECNICA2",.T.)
SET INDEX TO TECNI21
DO WHILE .NOT. TECNICA->(EOF())
   @ 10,10 SAY TECNICA->CODIGO_V+" "+DTOC(TECNICA->DATENT_V)+" "+DTOC(TECNICA->DATSAI_V)
   IF .NOT. EMPTY(TECNICA->DATSAI_V) .AND. TECNICA->DATSAI_V<DATE()-120 .AND. EMPTY(TECNICA->NOTA_V)
      @ 12,10 SAY "APAGANDO "
      TECNICA2->(DBSEEK(TECNICA->CODIGO_V))
      DO WHILE TECNICA2->CODIGO_V==TECNICA->CODIGO_V .AND. .NOT. TECNICA2->(EOF())
         @ 11,10 SAY TECNICA2->ITEM_V
         TECNICA2->(RLOCK())
         TECNICA2->(DBDELETE())
         TECNICA2->(DBUNLOCK())
         TECNICA2->(DBSKIP())
      ENDDO
      TECNICA->(RLOCK())
      TECNICA->(DBDELETE())
      TECNICA->(DBUNLOCK())
      @ 12,10 SAY "APAGADO  "
   ELSE
      @ 12,10 SAY "NAO APAGA"
   ENDIF
   TECNICA->(DBSKIP())
ENDDO
CLS
DBUSEAREA(.T.,,"PEDIDO","PEDIDO",.T.)
SET INDEX TO PEDIDO11,PEDIDO12,PEDIDO13,PEDIDO14,PEDIDO15
PEDIDO->(DBGOTOP())
DBUSEAREA(.T.,,"PEDIDO2","PEDIDO2",.T.)
SET INDEX TO PEDIDO21,PEDIDO22
DO WHILE .NOT. PEDIDO->(EOF())
   @ 10,10 SAY PEDIDO->CODIGO_V+" "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATBAI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+STRZERO(PEDIDO->NOTA_V,6,0)
   IF .NOT. EMPTY(PEDIDO->DATBAI_V) .AND. .NOT. EMPTY(PEDIDO->DATPAG_V) .AND. EMPTY(PEDIDO->NOTA_V) .AND. EMPTY(PEDIDO->NOTACOM_V)
      @ 12,10 SAY "APAGANDO "
      PEDIDO2->(DBSEEK(PEDIDO->CODIGO_V))
      DO WHILE PEDIDO2->CODIGO_V==PEDIDO->CODIGO_V .AND. .NOT. PEDIDO2->(EOF())
         @ 11,10 SAY PEDIDO2->ITEM_V
         PEDIDO2->(RLOCK())
         PEDIDO2->(DBDELETE())
         PEDIDO2->(DBUNLOCK())
         PEDIDO2->(DBSKIP())
      ENDDO
      PEDIDO->(RLOCK())
      PEDIDO->(DBDELETE())
      PEDIDO->(DBUNLOCK())
      @ 12,10 SAY "APAGADO  "
   ELSE
      @ 12,10 SAY "NAO APAGA"
   ENDIF
   PEDIDO->(DBSKIP())
ENDDO
RETURN(.T.)