FUNCTION DUPLICA()
LOCAL  TELA,GETLIST:={},TELA2
LOCAL  MES,ANO
MEMVAR DOCINT,DATVEN,VALOR,CLIFOR,DUPLICA,EXTENSOX,EXTENSO,EXTENSO2,Y,X
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
TELA:=SAVESCREEN()
MES:=SPACE(10)
ANO:=0
WINDOW(3,0,21,79)
DO WHILE .T.
   IF LEFT(PAGREC->CODIGO_V,1)#"R"
      AVISO("Imposs¡vel Emitir Duplicata para Conta … Pagar ...")
      EXIT
   ENDIF
   @ 04,01 SAY DECRIP(CONFIG->NOME_V)
   @ 05,50 SAY "Emissao : "+DTOC(DATE())
   @ 06,01 TO 06,78
   @ 07,02 SAY "Mˆs de" GET MES
   @ 07,20 SAY "de 19"
   @ 07,25 GET ANO PICT "99"
   @ 07,28 SAY  "Fatura        Valor R$      Duplicata  Vencto."
   @ 08,01 TO 08,78
   @ 09,28 SAY DOCINT
   @ 09,41 SAY TRANSFORM(VALOR,"@R 999,999,999.99")
   @ 09,56 GET DUPLICA
   @ 09,67 SAY DTOC(DATVEN)
   @ 10,28 TO 10,78
   @ 10,27 SAY CHR(218) 
   @ 11,27 TO 20,27
   @ 11,28 SAY "Sacado  : "+IF(CLIFOR->(DBSEEK(CLIFOR)),LEFT(CLIFOR->NOME_V,40),SPACE(40))
   @ 12,28 SAY "Endere‡o: "+IF(CLIFOR->(DBSEEK(CLIFOR)),LEFT(alltrim(CLIFOR->ENDERECO_V)+" "+alltrim(clifor->numero_v)+" "+alltrim(clifor->complem_v),40),SPACE(40))
   @ 13,28 SAY "Cidade  : "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->CIDADE_V,SPACE(30))
   @ 13,59 SAY "Estado: "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->ESTADO_V,SPACE(2))
   @ 14,28 SAY "Pr‡.Pgto: "+IF(CLIFOR->(DBSEEK(CLIFOR)),IF(EMPTY(CLIFOR->ENDCOB_V),SPACE(32),CLIFOR->CIDCOB_V+" - "+CLIFOR->ESTCOB_V),SPACE(32))
   @ 15,28 SAY "End.Cob.: "+IF(CLIFOR->(DBSEEK(CLIFOR)),IF(EMPTY(CLIFOR->ENDCOB_V),SPACE(25),LEFT(CLIFOR->ENDCOB_V,25)),SPACE(25))+" CEP: "+IF(CLIFOR->(DBSEEK(CLIFOR)),IF(EMPTY(CLIFOR->ENDCOB_V),SPACE(9),TRANSFORM(CLIFOR->CEPCOB_V,"@R 99999-999")),SPACE(9))
   @ 16,28 SAY "C.G.C.: "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->CGCCPF_V,SPACE(19))
   @ 16,55 SAY "I.Est.: "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->RGINSEST_V,SPACE(15))
   @ 17,27 SAY CHR(195)
   @ 17,28 TO 17,78
   @ 18,35 TO 20,35
   @ 17,35 SAY CHR(194)
   @ 18,28 SAY " Valor "
   @ 19,28 SAY "  por  "
   @ 20,28 SAY "Extenso"
   EXTENSOX:=EXTENSO(VALOR)
   EXTENSO:=EXTENSOX
   EXTENSO2:=""
   X:=LEN(EXTENSOX)
   IF X>40
      Y:=40
      DO WHILE SUBSTR(EXTENSOX,Y,1)<>" "
         Y--
      ENDDO
      EXTENSO:=LEFT(EXTENSOX,Y)
      X:=X-Y
      EXTENSO2:=RIGHT(EXTENSOX,X)
   ENDIF
   @ 18,36 SAY EXTENSO
   @ 19,36 SAY EXTENSO2
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Deseja Imprimir a Duplicata ?")
      TELA2:=SAVESCREEN()
      @ 24,0 SAY PADC("Esta duplicata ir  ser cobrada pelo banco ...",78) COLOR CORTIT
      DBE_BANK(14,4,20,16)
      IF LASTKEY()=27
         RESTSCREEN(,,,,TELA2)
         LOOP
      ENDIF
      RESTSCREEN(,,,,TELA2)
      LigaImpressora()
      @ PROW(),PCOL() SAY CHR(18)
      @ PROW(),PCOL() SAY CHR(15)
      @ PROW()+5,97 SAY DTOC(DATE())
      @ PROW()+2,6  SAY MES
      @ PROW(),35   SAY STRZERO(ANO,2,0)
      @ PROW()+2,48 SAY DOCINT
      @ PROW(),67   SAY TRANSFORM(VALOR,"@R 999,999,999.99")
      @ PROW(),87   SAY DUPLICA
      @ PROW(),105   SAY DATVEN
      @ PROW()+6,57 SAY IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->NOME_V,SPACE(50))
      @ PROW()+1,57 SAY IF(CLIFOR->(DBSEEK(CLIFOR)),alltrim(CLIFOR->ENDERECO_V)+" "+alltrim(clifor->numero_v)+" "+alltrim(clifor->complem_v),SPACE(50))
      @ PROW()+1,57 SAY IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->CIDADE_V,SPACE(30))
      @ PROW(),121   SAY IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->ESTADO_V,SPACE(2))
      @ PROW()+1,57 SAY IF(CLIFOR->(DBSEEK(CLIFOR)),IF(EMPTY(CLIFOR->ENDCOB_V),SPACE(32),CLIFOR->CIDCOB_V+" - "+CLIFOR->ESTCOB_V),SPACE(32))
      @ PROW()+1,57 SAY IF(CLIFOR->(DBSEEK(CLIFOR)),IF(EMPTY(CLIFOR->ENDCOB_V),SPACE(50),CLIFOR->ENDCOB_V),SPACE(50))
      @ PROW(),121   SAY IF(CLIFOR->(DBSEEK(CLIFOR)),IF(EMPTY(CLIFOR->ENDCOB_V),TRANSFORM(CLIFOR->CEP_V,"@R 99999-999"),TRANSFORM(CLIFOR->CEPCOB_V,"@R 99999-999")),SPACE(9))
      @ PROW()+1,57 SAY IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->CGCCPF_V,SPACE(19))
      @ PROW(),102   SAY IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->RGINSEST_V,SPACE(15))
      EXTENSOX:=EXTENSO(VALOR)
      EXTENSO:=EXTENSOX
      EXTENSO2:=""
      X:=LEN(EXTENSOX)
      IF X>70
         Y:=70
         DO WHILE SUBSTR(EXTENSOX,Y,1)<>" "
            Y--
         ENDDO
         EXTENSO:=LEFT(EXTENSOX,Y)
         X:=X-Y
         EXTENSO2:=RIGHT(EXTENSOX,X)
      ENDIF
      @ PROW()+2,56 SAY EXTENSO
      @ PROW()+1,56 SAY EXTENSO2
      @ PROW()+12,PCOL() SAY "  "
      SET PRINTER TO
      SET DEVICE TO SCREEN
      IF PAGREC->(RECLOCK(10))
         PAGREC->DUPLICA_V:=DUPLICA
         PAGREC->CODBANDU_V:=BANK->CODIGO_V
         PAGREC->(DBUNLOCK())
      ENDIF
      EXIT
   ENDIF
   LOOP
ENDDO
RESTSCREEN(,,,,TELA)
CLOSEWIN(3,0,21,79)
RETURN(.T.)