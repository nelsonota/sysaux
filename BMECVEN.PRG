FUNCTION BMECVEN(OPCAO)
LOCAL GETLIST:={},TELA,OP
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN

*** VARIAVEIS PARA CADASTRO DE MECANICOS/VENDEDORES
MEMVAR CODIGO,NOME,ENDERECO,BAIRRO,CIDADE,ESTADO,CEP,FONE1,FONE2,FAX
MEMVAR MECVEN,CGCCPF,RGINSEST
TELA:=SAVESCREEN(0,0,24,80)
@ 5,2  PROMPT "Cḃdigo   "
@ 6,2  PROMPT "Nome     "
MENU TO OP
DO CASE
   CASE OP=1
      MECVEN->(DBSETORDER(1))
      CODIGO:=0
      @ 5,13 GET CODIGO PICT "99999"
      READ
      CODIGO:=OPCAO+STRZERO(CODIGO,5,0)
      MECVEN->(DBSEEK(CODIGO,.F.))
   CASE OP=2
      MECVEN->(DBSETORDER(2))
      @ 6,13 GET NOME PICT "@K!"
      READ
      MECVEN->(DBSEEK(NOME,.T.))
ENDCASE
RESTSCREEN(0,0,24,80,TELA)
IF LASTKEY()=27
   RETURN(.F.)
ENDIF
DBE_MECVEN(10,10,20,70)
RETURN(.T.)