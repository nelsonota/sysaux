FUNCTION RELFUTCF(TIPO)
LOCAL GETLIST:={},VALTOT,TELA,X
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR LINHA,CLIFOR,INICIO,FIM
LINHA:={}
TELA:=SAVESCREEN(0,0,24,80)
WINDOW(9,10,12,60)
INICIO:=TRABALHO
FIM   :=TRABALHO
DBF_CONFIG()
DBF_PLANO()
DBF_PAGREC()
DBF_CLIFOR()
VALTOT:=0
X:=1
CLIFOR:=SPACE(LEN(CLIFOR->CODIGO_V))
DO WHILE .T.
   DATCFINIFIN("Relatḃrio de Contas a "+IF(TIPO="P","Pagar por Fornecedor","Receber por Cliente"),IF(TIPO="P","F","C"))
   IF LASTKEY()=27
      EXIT
   ENDIF
   PAGREC->(DBSETORDER(5))
   PAGREC->(DBSEEK(INICIO,.T.))
   CLIFOR->(DBSETORDER(1))
   DO WHILE PAGREC->DATVEN_V>=INICIO.AND.PAGREC->DATVEN_V<=FIM .AND. PAGREC->(.NOT. EOF()) .AND. X<=4090
      IF LEFT(PAGREC->CODIGO_V,1)# TIPO .OR. PAGREC->CLIFOR_V#CLIFOR
         PAGREC->(DBSKIP())
         LOOP
      ENDIF
      AADD(LINHA," "+LEFT(PAGREC->DESC_V,31)+" "+PAGREC->DOCEXT_V+" "+PAGREC->DOCINT_V+" "+TRANSFORM(PAGREC->VALOR_V,"@R 99,999,999.99")+" "+DTOC(PAGREC->DATVEN_V))
      VALTOT:=VALTOT+PAGREC->VALOR_V
      PAGREC->(DBSKIP())
      X=X+10
   ENDDO
   WINDOW(2,0,23,79)
   @ 6,1 TO 6,78
   @ 21,1 TO 21,78
   SETCOLOR(CORTIT)
   @ 3,1 SAY PADC("Relatḃrio de Contas  "+IF(TIPO="P","Pagar","Receber")+" no PerḂdo de "+DTOC(INICIO)+"  "+DTOC(FIM),78)
   CLIFOR->(DBSETORDER(1))
   @ 4,1 SAY PADC(IF(CLIFOR->(DBSEEK(CLIFOR)),ALLTRIM(CLIFOR->NOME_V),SPACE(50)),78)
   @ 5,1 SAY PADR(" Descriao                       Doc.Ext.   Doc.Int.           Valor Dt.Venc. ",78)
   @ 22,1 CLEAR TO 22,78
   @ 22,1 SAY " Valor Total : "+TRANSFORM(VALTOT,"@R 999,999,999.99")
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   ACHOICE(7,1,20,78,LINHA,.T.,"RELACHOFUN")
   IF CONFIRMA(20,20,"Deseja Imprimir o Relatḃrio ?")
      AADD(LINHA,REPLICATE("-",78))
      AADD(LINHA, " Valor Total : "+TRANSFORM(VALTOT,"@R 999,999,999.99"))
      IMPREL("Relatorio de Contas a "+IF(TIPO="P","Pagar","Receber")+" no Perido de "+DTOC(INICIO)+"  "+DTOC(FIM),IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->NOME_V,SPACE(50)),48)
   ENDIF
   EXIT
ENDDO
PAGREC->(DBCLOSEAREA())
PLANO->(DBCLOSEAREA())
CLIFOR->(DBCLOSEAREA())
CONFIG->(DBCLOSEAREA())
RESTSCREEN(0,0,24,80,TELA)
RETURN(.T.)