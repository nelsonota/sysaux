FUNCTION RELESTL()
LOCAL OP,OPCOES,TELA,VC
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
TELA:=SAVESCREEN(0,0,24,80)
WINDOW(9,33,20,67)
IF CONFIRMA(15,20,"Ativar impressao com valor de custo ?")
   VC:="S"
ELSE
   VC:="N"
ENDIF
DO WHILE .T.
   OPCOES:={"  Itens por Inicial              ",;
            "  Itens por Fornecedor           ",;
            "  Itens por Fornecedor e Inicial ",;
            "  Itens por Família              ",;
            "  Itens por Família e Fornecedor ",;
            "  Itens por Família e Fabricante ",;
            "  Geral por Ordem Alfabética     ",;
            "  Geral por Ordem de Códigos     ",;
            "  Itens em falta no estoque      ",;
            "  Itens em excesso no estoque    " }
   OP:=ACHOICE(10,34,19,66,OPCOES,.T.,"ACHOFUN")
   DO CASE
      CASE OP=1
         REESTINI(VC,"L")
      CASE OP=2
         REESTFOR(VC,"L")
      CASE OP=3
         RESINIFO(VC,"L")
      CASE OP=4
         REESTFAM(,VC,"L")
      CASE OP=5
         REESTFAM("F",VC,"L")
      CASE OP=6
         REESTFAM("I",VC,"L")
      CASE OP=7
         REESTORD("A",VC,"L")
      CASE OP=8
         REESTORD("C",VC,"L")
      CASE OP=9
         REESTFE("FAL")
      CASE OP=10
         REESTFE("EXC")
      OTHERWISE
         EXIT
   ENDCASE
ENDDO
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(9,33,20,67)
RETURN(.T.)