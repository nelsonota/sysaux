FUNCTION BTECNICA()
LOCAL OP,GETLIST:={}
*** VARIAVEIS PARA ENTRADA DE EQUIPAMENTOS
MEMVAR FICHA,CLIFOR,DATENT,ITEM,RECEBE,GARANTIA,COMPLETA,VALMO,VALITOT,VALTOT
MEMVAR DATORC,DATAPR,DATEXE,DATSAI,DOCMO,DOCITE,MECVEN,ORCAMENT,DATEXE2
@ 1,2   PROMPT "Ficha      "
@ 5,2   PROMPT "Cliente    "
@ 20,02 PROMPT "Entrada   em "
@ 20,28 PROMPT "Or‡amento em "
@ 20,54 PROMPT "Aprovado em "
@ 21,02 PROMPT "Saˇda Pe‡as  "
@ 21,28 PROMPT "Executado em "
@ 21,54 PROMPT "Entregue em "
MENU TO OP
DO CASE
   CASE OP=1
      TECNICA->(DBSETORDER(1))
      @ 1,15 GET FICHA PICT "@!" VALID(SEA_FICHA(FICHA))
      READ
      TECNICA->(DBSEEK(FICHA))
   CASE OP=2
      TECNICA->(DBSETORDER(2))
      @ 5,15 GET CLIFOR PICT "@!" VALID(SEA_CLIFOR(CLIFOR))
      READ
      TECNICA->(DBSEEK(CLIFOR))
   CASE OP=3
      TECNICA->(DBSETORDER(3))
      @ 20,17 GET DATENT
      READ
      TECNICA->(DBSEEK(DATENT))
   CASE OP=4
      TECNICA->(DBSETORDER(4))
      @ 20,42 GET DATORC
      READ
      TECNICA->(DBSEEK(DATORC))
   CASE OP=5
      TECNICA->(DBSETORDER(5))
      @ 20,68 GET DATAPR
      READ
      TECNICA->(DBSEEK(DATAPR))
   CASE OP=6
      TECNICA->(DBSETORDER(6))
      @ 21,17 GET DATEXE
      READ
      TECNICA->(DBSEEK(DATEXE))
   CASE OP=7
      TECNICA->(DBSETORDER(7))
      @ 20,42 GET DATEXE2
      READ
      TECNICA->(DBSEEK(DATEXE2))
   CASE OP=8
      TECNICA->(DBSETORDER(8))
      @ 20,68 GET DATSAI
      READ
      TECNICA->(DBSEEK(DATSAI))
ENDCASE
IF LASTKEY()=27
   RETURN(.F.)
ENDIF
TECNICA->(DBSETORDER(1))
DBE_TECNICA(10,5,20,75)
RETURN(.T.)