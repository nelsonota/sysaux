FUNCTION BTRANSP()
LOCAL OP,GETLIST:={},CIDSERV
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
*** VARIAVEIS PARA CADASTRO DE TRANSPORTADORAS
MEMVAR CODIGO,NOME,ENDERECO,CIDADE,ESTADO,CGC,INSEST,FONE1,FONE2,FAX,CONTATO
DO WHILE .T.
   @ 11,2  PROMPT "C˘digo   "
   @ 12,2  PROMPT "Nome     "
   @ 18,31 PROMPT "Cidades de Servi‡o"
   MENU TO OP
   DO CASE
      CASE OP=1
         TRANSP->(DBSETORDER(1))
         @ 11,13 GET CODIGO
         READ
         TRANSP->(DBSEEK(CODIGO))
      CASE OP=2
         TRANSP->(DBSETORDER(2))
         @ 12,13 GET NOME PICT "@K!"
         READ
         TRANSP->(DBSEEK(NOME))
      CASE OP=3
         CIDSERV:=SPACE(LEN(TRANSP->CIDSERV1_V))
         @ 18,02 CLEAR TO 18,48
         @ 18,02 SAY "Cidade desejada :" GET CIDSERV PICT "@!"
         READ
         IF LASTKEY()=27
            RETURN(.T.)
         ENDIF
         TRANSP->(DBSETFILTER({|| ALLTRIM(CIDSERV)$ALLTRIM(TRANSP->CIDSERV1_V) .OR. ALLTRIM(CIDSERV)$ALLTRIM(TRANSP->CIDSERV2_V) .OR. ALLTRIM(CIDSERV)$ALLTRIM(TRANSP->CIDSERV3_V)},"ALLTRIM(CIDSERV)$ALLTRIM(TRANSP->CIDSERV1_V) .OR. ALLTRIM(CIDSERV)$ALLTRIM(TRANSP->CIDSERV2_V) .OR. ALLTRIM(CIDSERV)$ALLTRIM(TRANSP->CIDSERV3_V)"))
      OTHERWISE
         EXIT
   ENDCASE
   IF LASTKEY()=27
      EXIT
   ENDIF
   DBE_TRANSP(10,5,20,75)
   TRANSP->(DBCLEARFILTER())
   EXIT
ENDDO
RETURN(.T.)