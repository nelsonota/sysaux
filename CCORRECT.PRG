FUNCTION CCORRECT()
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR BANCO,CLIFOR,CODPLA,DOCEXT,DESC,DOCINT,DATVEN,DATBAI,VALOR,CHEQUE,MOVI
IF DATBAI<TRABALHO
   AVISO("Impossˇvel cancelar lan‡amentos de dias anteriores ...")
   RETURN(.F.)
ENDIF
IF ! CONFIRMA(20,20,"Cancela Lan‡amento ?")
   RETURN(.T.)
ENDIF
IF !EMPTY((MOVI)->CHEQUE_V)
   CHEQUE->(DBSETORDER(2))
   IF CHEQUE->(DBSEEK((MOVI)->CHEQUE_V))
      IF !EMPTY(CHEQUE->DATBAI_V)
         AVISO("Impossˇvel Cancelar Este Lan‡amento, o Cheque J  Foi Compensado ...")
         RETURN(.F.)
      ENDIF
      IF CHEQUE->(RECLOCK(5))
         CHEQUE->VALOR_V:=CHEQUE->VALOR_V-(MOVI)->VALOR_V
         IF CHEQUE->VALOR_V=0
            CHEQUE->DATEMI_V:=CTOD("  /  /  ")
            CHEQUE->DATBAI_V:=CTOD("  /  /  ")
         ENDIF
         CHEQUE->(DBUNLOCK())
      ENDIF
   ENDIF
ENDIF
IF (MOVI)->FUTVIS_V="F"
   DBF_PAGREC()
   IF PAGREC->(ADDREC(5))
      PAGREC->CODIGO_V  :=(MOVI)->PAGREC_V
      PAGREC->CLIFOR_V  :=(MOVI)->CLIFOR_V
      PAGREC->DOCEXT_V  :=(MOVI)->DOCEXT_V
      PAGREC->DESC_V    :=(MOVI)->DESC_V
      PAGREC->DOCINT_V  :=(MOVI)->DOCINT_V
      PAGREC->VALOR_V   :=(MOVI)->VALOR_V
      PAGREC->CODPLA_V  :=(MOVI)->CODPLA_V
      PAGREC->DATVEN_V  :=(MOVI)->DATVEN_V
      PAGREC->BOLETO_V  :=(MOVI)->BOLETO_V
      PAGREC->CODBANBO_V:=(MOVI)->CODBANBO_V
      PAGREC->DUPLICA_V :=(MOVI)->DUPLICA_V
      PAGREC->CODBANDU_V:=(MOVI)->CODBANDU_V
      PAGREC->COBCHQ_V  :=(MOVI)->COBCHQ_V
      PAGREC->CBCODBAN_V:=(MOVI)->CBCODBAN_V
      PAGREC->COBBANCO_V:=(MOVI)->COBBANCO_V
      PAGREC->COBAGEN_V :=(MOVI)->COBAGEN_V
      PAGREC->COBCONTA_V:=(MOVI)->COBCONTA_V
      PAGREC->PROTESTO_V:=(MOVI)->PROTESTO_V
      PAGREC->(DBUNLOCK())
   ENDIF
   PAGREC->(DBCLOSEAREA())
ENDIF
BANK->(DBSETORDER(1))
IF BANK->(DBSEEK((MOVI)->BANCO_V))
   IF BANK->(RECLOCK(5))
      DO CASE
         CASE LEFT((MOVI)->PAGREC_V,1)="R"
            BANK->SALDO_V:=BANK->SALDO_V-(MOVI)->VALOR_V
         CASE LEFT((MOVI)->PAGREC_V,1)="P"
            IF EMPTY((MOVI)->CHEQUE_V)
               BANK->SALDO_V:=BANK->SALDO_V+(MOVI)->VALOR_V
            ENDIF
      ENDCASE
      BANK->(DBUNLOCK())
   ENDIF
ENDIF
IF (MOVI)->(RECLOCK(5))
   (MOVI)->(DBDELETE())
   (MOVI)->(DBUNLOCK())
ENDIF
(MOVI) -> (DBGOTOP())
DBSELECTAREA(MOVI)
LOCATE FOR (MOVI) -> DATBAI_V=DATBAI
RETURN(.T.)