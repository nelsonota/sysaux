FUNCTION RELDIR(TIPO,TIPO2)
LOCA   GETLIST:={},TELA,X,TITULO,TOTAL
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR LINHA,CLIFOR,MECVEN,INICIO,FIM
TELA:=SAVESCREEN(0,0,24,80)
INICIO:=CTOD("  /  /  ")
FIM   :=CTOD("  /  /  ")
DBF_PEDIDO()
DBF_CONFIG()
DBF_CLIFOR()
DBF_MECVEN()
DO WHILE .T.
   CLIFOR:=SPACE(LEN(CLIFOR->CODIGO_V))
   MECVEN:=SPACE(LEN(MECVEN->CODIGO_V))
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   IF TIPO2=="DIRV" .OR. TIPO2=="DIRVP" .OR. TIPO2=="DIRVNP"
      DATMVINIFIN(,"V")
   ELSE
      IF TIPO2=="DIRC" .OR. TIPO2=="DIRCP" .OR. TIPO2=="DIRCNP"
         DATCFINIFIN(,"C")
      ELSE
         IF TIPO2="DIRF"
            DATCFINIFIN(,"F")
         ELSE
            DATINIFIN()
         ENDIF
      ENDIF
   ENDIF
   IF LASTKEY()=27
      EXIT
   ENDIF
   LINHA:={}
   X=1
   CLIFOR->(DBSETORDER(1))
   MECVEN->(DBSETORDER(1))
   TOTAL:=0
   DO CASE
      CASE TIPO2=="DIR"
         IF TIPO="V"
            TITULO:="Vendas Diretas"
         ELSE
            TITULO:="Compras Diretas"
         ENDIF
         PEDIDO->(DBSETORDER(3))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATEMI_V>=INICIO .AND. PEDIDO->DATEMI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->TIPO_V="D"
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,29),SPACE(29))+" "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="DIRP"
         IF TIPO="V"
            TITULO:="Vendas Diretas Pagas"
         ELSE
            TITULO:="Compras Diretas Pagas"
         ENDIF
         PEDIDO->(DBSETORDER(5))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATPAG_V>=INICIO .AND. PEDIDO->DATPAG_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->TIPO_V="D"
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,29),SPACE(29))+" "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="DIRNP"
         IF TIPO="V"
            TITULO:="Vendas Diretas nao Pagas"
         ELSE
            TITULO:="Compras Diretas nao Pagas"
         ENDIF
         PEDIDO->(DBSETORDER(3))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATEMI_V>=INICIO .AND. PEDIDO->DATEMI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->TIPO_V="D" .AND. EMPTY(PEDIDO->DATPAG_V)
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,29),SPACE(29))+" "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="DIRC" .OR. TIPO2=="DIRF"
         IF TIPO="V"
            TITULO:="Vendas Diretas"
         ELSE
            TITULO:="Compras Diretas"
         ENDIF
         PEDIDO->(DBSETORDER(3))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATEMI_V>=INICIO .AND. PEDIDO->DATEMI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->TIPO_V="D" .AND. PEDIDO->CLIFOR_V=CLIFOR
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,29),SPACE(29))+" "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="DIRCP"
         IF TIPO="V"
            TITULO:="Vendas Diretas Pagas"
         ELSE
            TITULO:="Compras Diretas Pagas"
         ENDIF
         PEDIDO->(DBSETORDER(5))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATPAG_V>=INICIO .AND. PEDIDO->DATPAG_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->TIPO_V="D" .AND. PEDIDO->CLIFOR_V=CLIFOR
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,29),SPACE(29))+" "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="DIRCNP"
         IF TIPO="V"
            TITULO:="Vendas Diretas nao Pagas"
         ELSE
            TITULO:="Compras Diretas nao Pagas"
         ENDIF
         PEDIDO->(DBSETORDER(3))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATEMI_V>=INICIO .AND. PEDIDO->DATEMI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->TIPO_V="D" .AND. PEDIDO->CLIFOR_V=CLIFOR .AND. EMPTY(PEDIDO->DATPAG_V)
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,29),SPACE(29))+" "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="DIRV"
         IF TIPO="V"
            TITULO:="Vendas Diretas"
         ELSE
            TITULO:="Compras Diretas"
         ENDIF
         PEDIDO->(DBSETORDER(3))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATEMI_V>=INICIO .AND. PEDIDO->DATEMI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->TIPO_V="D" .AND. PEDIDO->MECVEN_V=MECVEN
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,29),SPACE(29))+" "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="DIRVP"
         IF TIPO="V"
            TITULO:="Vendas Diretas"
         ELSE
            TITULO:="Compras Diretas"
         ENDIF
         PEDIDO->(DBSETORDER(5))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATPAG_V>=INICIO .AND. PEDIDO->DATPAG_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->TIPO_V="D" .AND. PEDIDO->MECVEN_V=MECVEN
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,29),SPACE(29))+" "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="DIRVNP"
         IF TIPO="V"
            TITULO:="Vendas Diretas nao Pagas"
         ELSE
            TITULO:="Compras Diretas nao Pagas"
         ENDIF
         PEDIDO->(DBSETORDER(3))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATEMI_V>=INICIO .AND. PEDIDO->DATEMI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->TIPO_V="D" .AND. PEDIDO->MECVEN_V=MECVEN .AND. EMPTY(PEDIDO->DATPAG_V)
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,29),SPACE(29))+" "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
   ENDCASE
   WINDOW(5,0,22,79)
   SETCOLOR(CORTIT)
   @ 6,1 SAY PADC(TITULO+" no Perˇodo de "+DTOC(INICIO)+" … "+DTOC(FIM),78)
   @ 7,1 SAY PADR("Direto Nome                       Dt.Opera‡ao Dt.Pagto. Valor         Nota",78)
   @ 21,1 SAY PADR(" Valor Total : "+TRANSFORM(TOTAL,"@R 999,999,999.99"),78)
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 8,1 TO 8,78
   @ 20,1 TO 20,78
   ACHOICE(9,1,19,78,LINHA,.T.,"RELACHOFUN")
   IF CONFIRMA(20,20,"Deseja Imprimir o Relat˘rio ?")
      IMPREL(TITULO+" no Perˇodo de "+DTOC(INICIO)+" … "+DTOC(FIM),"Direto Nome                      Dt.Operacao Dt.Pagto. Valor         Nota",,50)
   ENDIF
   EXIT
ENDDO
CLIFOR->(DBCLOSEAREA())
CONFIG->(DBCLOSEAREA())
PEDIDO->(DBCLOSEAREA())
MECVEN->(DBCLOSEAREA())
RESTSCREEN(,,,,TELA)
RETURN(.T.)