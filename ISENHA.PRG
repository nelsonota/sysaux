FUNCTION ISENHA()
LOCAL GETLIST:={},SENHA1
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN,CODVEN
MEMVAR MECVEN

*** VARIAVEIS P/ REGISTRO DE SENHA
MEMVAR NOMSEN,SENHA,NIVEL,CODIGO
CODIGO  := CONFIG->SENHA_V+1
IF LEVEL = "SP" .OR. LEVEL = "NE" .OR. LEVEL = ""
   NIVEL :="DI"
ELSE
   NIVEL:=LEVEL
ENDIF
DO WHILE .T.
   @ 7,54 SAY STRZERO(CODIGO,5,0)
   SETCOLOR(CORBAR)
   @ 8,54 CLEAR TO 8,64
   NOMSEN:=SPACE(0)
   DO WHILE EMPTY(NOMSEN) .AND. LASTKEY()<>27
      NOMSEN := NEWGET(LEN(SENHA->NOMSEN_V),8,54)
   ENDDO
   IF LASTKEY()=27
      RETURN(.T.)
   ENDIF
   SETCOLOR(CORTEX)
   @ 8,54 CLEAR TO 8,64
   @ 8,54 SAY NOMSEN
   SETCOLOR(CORBAR)
   @ 9,54 CLEAR TO 9,64
   SENHA :=SPACE(0)
   DO WHILE EMPTY(SENHA) .AND. LASTKEY()<>27
      SENHA :=NEWGET(LEN(SENHA->SENHA_V),9,54,.F.)
   ENDDO
   IF LASTKEY()=27
      RETURN(.T.)
   ENDIF
   SETCOLOR(CORBAR)
   @ 9,54 CLEAR TO 9,64
   SENHA1:=SPACE(0)
   DO WHILE EMPTY(SENHA1)
      SENHA1:=NEWGET(LEN(SENHA->SENHA_V),9,54,.F.)
   ENDDO
   IF .NOT. SENHA==SENHA1
      AVISO("Senha Nao Confirmada ...")
      EXIT
   ENDIF
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   IF LASTKEY()=27
      RETURN(.T.)
   ENDIF
   @ 10,54 GET MECVEN VALID(EMPTY(MECVEN) .OR. SEA_MECVEN(MECVEN,10,61,"V"))
   READ
   IF LASTKEY()=27
      RETURN(.T.)
   ENDIF
   IF CONFIRMA(15,20,"Confirma Inclusao do UsuĀrio ?")
      IF SENHA->(ADDREC(5))
         IF CONFIG->(RECLOCK(5))
            CONFIG->SENHA_V:=CONFIG->SENHA_V+1
            CODSEN:=CONFIG->SENHA_V
            CONFIG->(DBUNLOCK())
         ELSE
            EXIT
         ENDIF
         SENHA->CODSEN_V:=CODSEN
         SENHA->NOMSEN_V:=NOMSEN
         SENHA->SENHA_V :=CRIP(SENHA)
         SENHA->CODVEN_V:=MECVEN
         SENHA->LEVEL_V :=NIVEL
         SENHA->CORTIT_V:=CORTIT
         SENHA->CORTEX_V:=CORTEX
         SENHA->CORPAR_V:=CORPAR
         SENHA->CORBAR_V:=CORBAR
         SENHA->CORDES_V:=CORDES
         SENHA->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
ENDDO
RETURN(.T.)