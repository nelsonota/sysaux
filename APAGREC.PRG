FUNCTION APAGREC(OPCAO)
LOCAL GETLIST:={},DOCEXT2
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN

*** VARIAVEIS P/ CADASTRO DE CONTAS A PAGAR/RECEBER
MEMVAR PAGREC,CODIGO,CLIFOR,DOCEXT,DESC,DOCINT,DATVEN,VALOR,CODPLA,DATEXT,DATINT
MEMVAR CODPORTA
*** VARIAVEIS DE COBRANCA
MEMVAR BOLETO,CODBANBO,DUPLICA,CODBANDU,COBCHQ,CBCODBAN,COBBANCO
MEMVAR COBAGEN,COBCONTA
DO CASE
   CASE OPCAO="P"
      IF LEFT(PAGREC->CODIGO_V,1)#OPCAO
         AVISO("Este nao  um TÀtulo  Pagar ...")
         RETURN(.F.)
      ENDIF
   CASE OPCAO="R"
      IF LEFT(PAGREC->CODIGO_V,1)#OPCAO
         AVISO("Este nao  um TÀtulo  Receber ...")
         RETURN(.F.)
      ENDIF
ENDCASE
DOCEXT2:=DOCEXT
DO WHILE .T.
   @ IF(OPCAO="R",04,11),16 SAY CODIGO
   @ IF(OPCAO="R",05,12),16 GET CLIFOR PICT "@!" VALID(SEA_CLIFOR(CLIFOR,IF(OPCAO="R",05,12),25,IF(OPCAO="R","C","F")))
   @ IF(OPCAO="R",7,14),16 GET DOCEXT PICT "@!"
   @ IF(OPCAO="R",7,14),50 GET DATEXT
   @ IF(OPCAO="R",8,15),16 GET DESC   PICT "@!"
   @ IF(OPCAO="R",9,16),16 GET DOCINT PICT "@!"
   @ IF(OPCAO="R",9,16),50 GET DATINT
   @ IF(OPCAO="R",10,17),16 GET VALOR  PICT "@R 999,999,999.99" VALID(VALOR>0.OR.LASTKEY()=5)
   @ IF(OPCAO="R",10,17),48 GET CODPLA PICT "@!" VALID(LASTKEY()=5 .OR. SEA_CODPLA(CODPLA,IF(OPCAO="R",10,17),55,IF(OPCAO="R","+","-")))
   @ IF(OPCAO="R",11,18),16 GET DATVEN VALID(!EMPTY(DATVEN).OR.LASTKEY()=5)
   IF OPCAO="R"
      @ 11,48 GET CODPORTA PICT "@!" VALID(LASTKEY()=5 .OR. SEA_PORTA(CODPORTA,11,53))
   ENDIF
   IF .NOT. EMPTY(BOLETO)
      @ 15,14 GET BOLETO PICT "@!"
      @ 15,54 GET CODBANBO VALID(COBBANK("B"))
   ENDIF
   IF .NOT. EMPTY(DUPLICA)
      @ 16,14 GET DUPLICA PICT "@!"
      @ 16,54 GET CODBANDU VALID(COBBANK("D"))
   ENDIF
   IF .NOT. EMPTY(COBCHQ)
      @ 17,14 GET COBCHQ PICT "@!"
      @ 17,31 GET CBCODBAN PICT "@!"
      @ 17,36 GET COBBANCO PICT "@!"
      @ 18,31 GET COBAGEN PICT "@!"
      @ 18,54 GET COBCONTA PICT "@!"
   ENDIF
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Confirma Alteraao do TÀtulo ?")
      IF PAGREC->(RECLOCK(5))
         PAGREC->CODIGO_V  :=CODIGO
         PAGREC->CLIFOR_V  :=CLIFOR
         PAGREC->DOCEXT_V  :=DOCEXT
         PAGREC->DATEXT_V  :=DATEXT
         PAGREC->DESC_V    :=DESC
         PAGREC->DOCINT_V  :=DOCINT
         PAGREC->DATINT_V  :=DATINT
         PAGREC->DATVEN_V  :=DATVEN
         PAGREC->VALOR_V   :=VALOR
         PAGREC->CODPLA_V  :=CODPLA
         PAGREC->BOLETO_V  :=BOLETO
         PAGREC->CODBANBO_V:=CODBANBO
         PAGREC->DUPLICA_V :=DUPLICA
         PAGREC->CODBANDU_V:=CODBANDU
         PAGREC->COBCHQ_V  :=COBCHQ
         PAGREC->CBCODBAN_V:=CBCODBAN
         PAGREC->COBBANCO_V:=COBBANCO
         PAGREC->COBAGEN_V :=COBAGEN
         PAGREC->COBCONTA_V:=COBCONTA
         PAGREC->CODPORTA_V:=CODPORTA
         PAGREC->(DBUNLOCK())
         xmig_pagrec()
         EXIT
      ENDIF
   ENDIF
ENDDO
RETURN(.T.)