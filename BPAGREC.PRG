FUNCTION BPAGREC(OPCAO)
LOCAL OP,GETLIST:={}
*** VARIAVEIS P/ CADASTRO DE CONTAS A PAGAR/RECEBER
MEMVAR PAGREC,CODIGO,CLIFOR,DOCEXT,DESC,DOCINT,DATVEN,VALOR,CODPLA
@ IF(OPCAO="R",04,11),02 PROMPT "C˘digo      "
@ IF(OPCAO="R",05,12),02 PROMPT IF(OPCAO="P","Fornecedor ","Cliente    ")
@ IF(OPCAO="R",7,14),02 PROMPT "Doc.Externo "
@ IF(OPCAO="R",9,16),02 PROMPT "Doc.Interno "
@ IF(OPCAO="R",10,17),02 PROMPT "Valor       "
@ IF(OPCAO="R",11,18),02 PROMPT "Vencimento  "
MENU TO OP
DO CASE
   CASE OP=1
      PAGREC->(DBSETORDER(1))
      @ IF(OPCAO="R",04,11),16 GET CODIGO PICT "@!"
      READ
      PAGREC->(DBSEEK(CODIGO))
   CASE OP=2
      PAGREC->(DBSETORDER(2))
      @ IF(OPCAO="R",05,12),16 GET CLIFOR PICT "@!" VALID(SEA_CLIFOR(CLIFOR,,,IF(OPCAO="R","C","F")))
      READ
      PAGREC->(DBSEEK(CLIFOR))
   CASE OP=3
      PAGREC->(DBSETORDER(3))
      @ IF(OPCAO="R",7,14),16 GET DOCEXT PICT "@!"
      READ
      PAGREC->(DBSEEK(DOCEXT,.T.))
   CASE OP=4
      PAGREC->(DBSETORDER(4))
      @ IF(OPCAO="R",9,16),16 GET DOCINT PICT "@!"
      READ
      PAGREC->(DBSEEK(DOCINT,.T.))
   CASE OP=5
      @ IF(OPCAO="R",10,17),16 GET VALOR  PICT "@R 999,999,999.99"
      READ
      PAGREC->(DBLOCATE("PAGREC->VALOR_V","=",VALOR))
   CASE OP=6
      PAGREC->(DBSETORDER(5))
      @ IF(OPCAO="R",11,18),16 GET DATVEN VALID(!EMPTY(DATVEN).OR.LASTKEY()=5)
      READ
      PAGREC->(DBSEEK(DATVEN))
ENDCASE
PAGREC->(DBSETORDER(5))
DBE_PAGREC(10,5,20,75)
PAGREC->(DBCLEARFIL())
RETURN(.T.)