FUNCTION USERVAR()
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN
MEMVAR COMPR,COMPON,NORMAL,COMPOFF,ENFOFF,ENFON,EXPON,EXPOFF,ITALON,ITALOFF,CPI10,CPI12,RESET
MEMVAR SYSVEN,BLQVEN
DBF_SENHA()
DBF_MECVEN()
IF SENHA->(DBSEEK(CODSEN))
   CORTIT:=SENHA->CORTIT_V
   CORTEX:=SENHA->CORTEX_V
   CORPAR:=SENHA->CORPAR_V
   CORBAR:=SENHA->CORBAR_V
   CORDES:=SENHA->CORDES_V
   LEVEL :=SENHA->LEVEL_V
   IF LEVEL$"NESP"
      SYSVEN=''
      BLQVEN='N'
   ELSE
      SYSVEN:=SENHA->CODVEN_V
      BLQVEN:=IF(EMPTY(SYSVEN),"N",IF(MECVEN->(DBSEEK(SYSVEN)),IF(MECVEN->ALLCLI_V='N','S','N'),"S"))
   ENDIF
   COMPR	:= IIF( SENHA->IMPFUN_V=1 , CHR( 27 ) + "(s16.67H" , CHR( 15 ) )
   COMPON	:= IIF( SENHA->IMPFUN_V=1 , CHR( 27 ) + "(s16.67H" , CHR( 15 ) )
   NORMAL	:= IIF( SENHA->IMPFUN_V=1 , CHR( 27 ) + "(s10H"    , CHR( 18 ) )
   COMPOFF:= IIF( SENHA->IMPFUN_V=1 , CHR( 27 ) + "(s10H"    , CHR( 18 ) )
   ENFON	:= IIF( SENHA->IMPFUN_V=1 , CHR( 27 ) + "(s3B"     , CHR( 27 ) + CHR( 69 ) )
   ENFOFF	:= IIF( SENHA->IMPFUN_V=1 , CHR( 27 ) + "(s-3B"    , CHR( 27 ) + CHR( 70 ) )
   EXPON	:= IIF( SENHA->IMPFUN_V=1 , CHR( 27 ) + "(s1P"     , CHR( 14 ) )
   EXPOFF	:= IIF( SENHA->IMPFUN_V=1 , CHR( 27 ) + "(s0P"     , CHR( 20 ) )
   ITALON	:= IIF( SENHA->IMPFUN_V=1 , CHR( 27 ) + "(s1S"     , CHR( 27 ) + "4" )
   ITALOFF:= IIF( SENHA->IMPFUN_V=1 , CHR( 27 ) + "(s0S"     , CHR( 27 ) + "5" )
   CPI10	:= IIF( SENHA->IMPFUN_V=1 , ""                     , CHR( 27 ) + CHR( 80 ) )
   CPI12	:= IIF( SENHA->IMPFUN_V=1 , ""                     , CHR( 27 ) + CHR( 77 ) )
   RESET	:= IIF( SENHA->IMPFUN_V=1 , CHR( 27 ) + "E"        , "" )
ENDIF
SENHA->(DBCLOSEAREA())
MECVEN->(DBCLOSEAREA())
RETURN(.T.)