FUNCTION AMECVEN(OPCAO)
LOCAL GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO

*** VARIAVEIS PARA CADASTRO DE MECANICOS/VENDEDORES
MEMVAR CODIGO,NOME,ENDERECO,BAIRRO,CIDADE,ESTADO,CEP,FONE1,FONE2,FAX
MEMVAR MECVEN,CGCCPF,RGINSEST,CONTATO,ALLCLI, NUMERO, COMPLEM
SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
DO CASE
   CASE OPCAO="M"
      IF LEFT(CODIGO,1)#OPCAO
         AVISO("Este nao ‚ um Mecanico ...")
         RETURN(.F.)
      ENDIF
   CASE OPCAO="V"
      IF LEFT(CODIGO,1)#OPCAO
         AVISO("Este nao ‚ um Vendedor ...")
         RETURN(.F.)
      ENDIF
ENDCASE
DO WHILE LASTKEY()#27
   @ 05,13 SAY CODIGO
   IF OPCAO="V"
      @ 05,48 GET ALLCLI   PICT "@!"
   ENDIF
   @ 06,13 GET NOME     PICT "@!" VALID(!EMPTY(NOME))
   @ 07,13 GET ENDERECO PICT "@s35!"
   @ 07,53 GET NUMERO PICT "@!"
   @ 07,68 GET COMPLEM PICT "@!"
   @ 08,13 GET BAIRRO   PICT "@!"
   @ 09,13 GET CIDADE   PICT "@!" valid sea_cidade(cidade)
   @ 09,54 GET ESTADO   PICT "@!"
   @ 09,65 GET CEP      PICT "@R 99999-999"
   @ 10,13 GET CGCCPF
   @ 10,43 GET RGINSEST
   @ 11,13 GET FONE1    PICT "@R (#999) ##99-9999"
   @ 11,37 GET FONE2    PICT "@R (#999) ##99-9999"
   @ 11,59 GET FAX      PICT "@R (#999) ##99-9999"
   @ 12,13 GET CONTATO  PICT "@!"
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(22,20,"Confirma Altera‡ao ?")
      IF MECVEN->(RECLOCK(5))
         MECVEN->CODIGO_V  :=CODIGO
         MECVEN->NOME_V    :=NOME
         MECVEN->CGCCPF_V  :=CGCCPF
         MECVEN->RGINSEST_V:=RGINSEST
         MECVEN->ENDERECO_V:=ENDERECO
         MECVEN->NUMERO_V  :=NUMERO
         MECVEN->COMPLEM_V :=COMPLEM
         MECVEN->BAIRRO_V  :=BAIRRO
         MECVEN->CIDADE_V  :=CIDADE
         MECVEN->ESTADO_V  :=ESTADO
         MECVEN->CEP_V     :=CEP
         MECVEN->FONE1_V   :=FONE1
         MECVEN->FONE2_V   :=FONE2
         MECVEN->FAX_V     :=FAX
         MECVEN->ALLCLI_V  :=ALLCLI
         MECVEN->(DBUNLOCK())
         RETURN(.T.)
      ENDIF
   ENDIF
ENDDO
RETURN(.T.)