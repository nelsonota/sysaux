FUNCTION FECHA()
LOCAL  TELA
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR LINHA
TELA:=SAVESCREEN(0,0,24,80)
WINDOW(10,10,18,56)
SETCOLOR(CORTIT)
@ 11,11 SAY PADC("Fechamento de Caixa "+DTOC(TRABALHO),45)
SETCOLOR(CORTEX)
@ 12,11 TO 12,55
@ 13,12 SAY "Esta op‡ao ir  fechar o dia de trabalho.   "
@ 14,12 SAY "Tenha absoluta certeza de que todos os     "
@ 15,12 SAY "lan‡amentos realizados e saldos banc rios  "
@ 16,12 SAY "estao corretos.                            "
@ 17,12 SAY "Ser  impossˇvel altera‡oes nos lan‡amentos."
IF CONFIRMA(20,10,"Todos os Dados Estao Corretos ?")
   IF CONFIRMA(20,10,"J  Foi Realizada a C˘pia de Seguran‡a ?")
      FECHADIA()
      DBF_CONFIG()
      TRABALHO:=TRABALHO+1
      DO CASE
         CASE DOW(TRABALHO)=7
            TRABALHO=TRABALHO+2
         CASE DOW(TRABALHO)=1
            TRABALHO=TRABALHO+1
      ENDCASE
      IF CONFIG->(RECLOCK(20))
         CONFIG->TRABALHO_V:=TRABALHO
         CONFIG->(DBUNLOCK())
      ENDIF
      CONFIG->(DBCLOSEAREA())
      VERIFY()
   ENDIF
ENDIF
RESTSCREEN(0,0,24,80,TELA)
DATA(24,45)
RETURN(.T.)

FUNCTION FECHADIA()
LOCAL  MOVI,TPLANO,TRECEBER,TPAGAR,TEMITIDO,TCANCELADO,TCOMPENSADO
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR LINHA
LINHA:={}
DBF_CONFIG()
MOVI:=BAN_MOVI()
DBF_CLIFOR()
DBF_PLANO()
DBF_MOVI(MOVI)
DBF_CHEQUE()
DBF_BANK()
PLANO->(DBSETORDER(1))
PLANO->(DBGOTOP())
AADD(LINHA,"("+LEFT(PLANO->CODIGO_V,1)+")"+PLANO->NOME_V)
AADD(LINHA," ")
TPLANO:=0
TRECEBER:=0
TPAGAR:=0
TEMITIDO:=0
TCOMPENSADO:=0
TCANCELADO:=0


*** FLUXO DO PLANO DE CONTAS


DO WHILE PLANO->(! EOF())
   IF (MOVI)->CODPLA_V=PLANO->CODIGO_V .AND. (MOVI)->DATBAI_V=TRABALHO
      AADD(LINHA,"   "+IF(CLIFOR->(DBSEEK((MOVI)->CLIFOR_V)),LEFT(CLIFOR->NOME_V,30),SPACE(30))+" "+(MOVI)->DOCEXT_V+" "+(MOVI)->DOCINT_V+TRANSFORM((MOVI)->VALOR_V,"@R 999,999,999.99")+" "+DTOC((MOVI)->DATBAI_V))
      TPLANO:=TPLANO+(MOVI)->VALOR_V
      DO CASE
         CASE LEFT((MOVI)->PAGREC_V,1)="R"
            TRECEBER:=TRECEBER+(MOVI)->VALOR_V
         CASE LEFT((MOVI)->PAGREC_V,1)="P"
            TPAGAR:=TPAGAR+(MOVI)->VALOR_V
      ENDCASE
   ENDIF
   (MOVI)->(DBSKIP())
   IF (MOVI)->(EOF())
      AADD(LINHA,REPLICATE("-",80))
      AADD(LINHA,"Total "+ALLTRIM(PLANO->NOME_V)+" : "+TRANSFORM(TPLANO,"@R 999,999,999.99"))
      PLANO->(DBSKIP())
      (MOVI)->(DBGOTOP())
      TPLANO:=0
      IF PLANO->(!EOF())
         AADD(LINHA," ")
         AADD(LINHA," ")
         AADD(LINHA,"("+LEFT(PLANO->CODIGO_V,1)+")"+PLANO->NOME_V)
      ENDIF
      AADD(LINHA," ")
   ENDIF
ENDDO

*** MOVIMENTOS DOS CHEQUES

CHEQUE->(DBSETORDER(4))
CHEQUE->(DBSEEK(TRABALHO))
AADD(LINHA," ")
AADD(LINHA,"Cheque(s) Emitido(s) no Dia")
AADD(LINHA," ")
DO WHILE CHEQUE->DATEMI_V=TRABALHO .AND. CHEQUE->(!EOF())
   IF ALLTRIM(UPPER(CHEQUE->OBS_V))="CANCELADO" .OR. !EMPTY(CHEQUE->DATBAI_V)
      CHEQUE->(DBSKIP())
      LOOP
   ENDIF
   AADD(LINHA,"   "+IF(BANK->(DBSEEK(CHEQUE->CODBAN_V)),BANK->NOME_V,SPACE(10))+" "+CHEQUE->CHEQUE_V+" "+TRANSFORM(CHEQUE->VALOR_V,"@R 999,999,999.99"))
   TEMITIDO:=TEMITIDO+CHEQUE->VALOR_V
   CHEQUE->(DBSKIP())
ENDDO
AADD(LINHA,REPLICATE("-",47))
AADD(LINHA,"Total de Cheque(s) Emitido(s) : "+TRANSFORM(TEMITIDO,"@R 999,999,999.99"))


CHEQUE->(DBSETORDER(4))
CHEQUE->(DBSEEK(TRABALHO))
AADD(LINHA," ")
AADD(LINHA,"Cheque(s) Cancelado(s) no Dia")
AADD(LINHA," ")
DO WHILE CHEQUE->DATBAI_V=TRABALHO .AND. CHEQUE->(!EOF())
   IF ALLTRIM(UPPER(CHEQUE->OBS_V))#"CANCELADO"
      CHEQUE->(DBSKIP())
      LOOP
   ENDIF
   AADD(LINHA,"   "+IF(BANK->(DBSEEK(CHEQUE->CODBAN_V)),BANK->NOME_V,SPACE(10))+" "+CHEQUE->CHEQUE_V+" "+TRANSFORM(CHEQUE->VALOR_V,"@R 999,999,999.99"))
   TCANCELADO:=TCANCELADO+CHEQUE->VALOR_V
   CHEQUE->(DBSKIP())
ENDDO
AADD(LINHA,REPLICATE("-",49))
AADD(LINHA,"Total de Cheque(s) Cancelado(s) : "+TRANSFORM(TCANCELADO,"@R 999,999,999.99"))


CHEQUE->(DBSETORDER(5))
CHEQUE->(DBSEEK(TRABALHO))
AADD(LINHA," ")
AADD(LINHA,"Cheque(s) Compensado(s) no Dia")
AADD(LINHA," ")
DO WHILE CHEQUE->DATBAI_V=TRABALHO .AND. CHEQUE->(!EOF())
   IF ALLTRIM(UPPER(CHEQUE->OBS_V))="CANCELADO" .OR. EMPTY(CHEQUE->DATBAI_V)
      CHEQUE->(DBSKIP())
      LOOP
   ENDIF
   AADD(LINHA,"   "+IF(BANK->(DBSEEK(CHEQUE->CODBAN_V)),BANK->NOME_V,SPACE(10))+" "+CHEQUE->CHEQUE_V+" "+TRANSFORM(CHEQUE->VALOR_V,"@R 999,999,999.99"))
   TCOMPENSADO:=TCOMPENSADO+CHEQUE->VALOR_V
   CHEQUE->(DBSKIP())
ENDDO
AADD(LINHA,REPLICATE("-",50))
AADD(LINHA,"Total de Cheque(s) Compensado(s) : "+TRANSFORM(TCOMPENSADO,"@R 999,999,999.99"))



AADD(LINHA," ")
AADD(LINHA,REPLICATE("-",80))
AADD(LINHA,"Total de Recebimentos : "+TRANSFORM(TRECEBER,"@R 999,999,999.99")+" Total de Pagamentos : "+TRANSFORM(TPAGAR,"@R 999,999,999.99"))
SETCOLOR(CORTIT)
@ 3,0 SAY PADR("Fechamento de Caixa do Dia : "+DTOC(TRABALHO),79)
WINDOW(4,0,21,79)
SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
ACHOICE(5,1,20,78,LINHA,.T.,"RELACHOFUN")
IF CONFIRMA(20,20,"Deseja Imprimir ?")
   IMPREL("Fechamento de Caixa Dia : "+DTOC(TRABALHO),,50)
ENDIF
(MOVI) ->(DBCLOSEAREA())
CHEQUE->(DBCLOSEAREA())
CLIFOR->(DBCLOSEAREA())
CONFIG->(DBCLOSEAREA())
PLANO->(DBCLOSEAREA())
BANK->(DBCLOSEAREA())
RETURN(.T.)