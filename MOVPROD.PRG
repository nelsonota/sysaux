FUNCTION MOVPROD()
LOCAL TELA,LINHA,COLUNA,VARIAVEIS,MASCARAS,TITULOS,GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR CODIGO
TELA:=SAVESCREEN()
DBF_PROD()
DBF_PROD2()
DBF_MECVEN()
DBF_ESTOQUE()
WINDOW(0,0,23,79)
CODIGO:=0
DO WHILE .T.
   @ 1,2 SAY "Código  :" GET CODIGO PICT "9999999" VALID(SEA_PROD(CODIGO))
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   @ 2,2  SAY "Técnico : "+IF(MECVEN->(DBSEEK(PROD->MECVEN_V)),MECVEN->NOME_V,SPACE(LEN(MECVEN->NOME_V)))
   @ 3,2  SAY "Data da produćao : "+DTOC(PROD->DATA_V)
   @ 3,32 SAY "Total do Custo : "+TRANSFORM(PROD->VALTOT_V,"@R 999,999.99")
   @ 4,1 TO 4,78
   @ 5,1 SAY PADC("Itens Produzidos",78) COLOR CORTIT
   LINHA:=CHR(220)
   COLUNA:=CHR(219)
   VARIAVEIS:={"IF(PROD2->CODIGO_V==PROD->CODIGO_V,PROD2->ITEM_V,SPACE(LEN(PROD2->ITEM_V)))",;
               "IF(PROD2->CODIGO_V==PROD->CODIGO_V,IF(ESTOQUE->(DBSEEK(PROD2->ITEM_V)),LEFT(ESTOQUE->NOME_V,32),SPACE(32)),SPACE(32))",;
               "IF(PROD2->CODIGO_V==PROD->CODIGO_V,PROD2->VALCUS_V,0)",;
               "IF(PROD2->CODIGO_V==PROD->CODIGO_V,PROD2->QTD_V,0)",;
               "IF(PROD2->CODIGO_V==PROD->CODIGO_V,PROD2->VALTOT_V,0)"}
   MASCARAS :={,,"@R 999,999.99","@R 999,999","@R 999,999.99"}
   TITULOS  :={"Código","Descrićao","Custo Unit.","Qtd.","Custo Total"}
   PROD2->(DBEDIT(6,1,22,78,VARIAVEIS,,MASCARAS,TITULOS,LINHA,COLUNA))
ENDDO
PROD->(DBCLOSEAREA())
PROD2->(DBCLOSEAREA())
MECVEN->(DBCLOSEAREA())
ESTOQUE->(DBCLOSEAREA())
RESTSCREEN(,,,,TELA)
CLOSEWIN(0,0,23,79)
RETURN(.T.)