FUNCTION BESTOQUE()
LOCAL GETLIST:={},TELA,OP
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN

*** VARIAVEIS P/ CADATRO DE ESTOQUE
MEMVAR CODIGO,NOME,CLIFOR,VALCUS,PERCENT,VALVEN,QTD,UNIDADE,CODBASC,CODICMS
MEMVAR SITTABA,SITTABB,FAMILIA,LOCALIZA
TELA:=SAVESCREEN(0,0,24,80)
@ 1,2  PROMPT "Código    "
@ 2,2  PROMPT "Descrićao "
@ 6,2  PROMPT "Fornecedor"
MENU TO OP
DO CASE
   CASE OP=1
      ESTOQUE->(DBSETORDER(1))
      @ 1,14 GET CODIGO PICT "@K!"
      READ
      ESTOQUE->(DBSEEK(CODIGO,.F.))
   CASE OP=2
      ESTOQUE->(DBSETORDER(2))
      @ 2,14 GET NOME PICT "@K!"
      READ
      ESTOQUE->(DBSEEK(NOME,.T.))
   CASE OP=3
      ESTOQUE->(DBSETORDER(3))
      @ 6,14 GET CLIFOR VALID(SEA_CLIFOR(CLIFOR,7,23,"F"))
      READ
      ESTOQUE->(DBSEEK(CLIFOR,.F.))
ENDCASE
RESTSCREEN(0,0,24,80,TELA)
IF LASTKEY()=27
   RETURN(.F.)
ENDIF
DBE_ESTOQUE(10,2,20,77)
RETURN(.T.)