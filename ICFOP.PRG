FUNCTION ICFOP()
LOCAL  GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN
MEMVAR CFOP,MENSAGEM,MOVEST,MOVIMP,MOVFIN
DO WHILE .T.
   CFOP:=SPACE(LEN(CFOP->CFOP_V))
   MENSAGEM:=SPACE(LEN(CFOP->MENSAGEM_V))
   @ 15,21 GET CFOP     PICT "@K!"
   @ 16,21 GET MENSAGEM PICT "@K!"
   @ 17,32 GET MOVEST PICT "@!" VALID MOVEST$"SN"
   @ 18,32 GET MOVIMP PICT "@!" VALID MOVIMP$"SN"
   @ 19,32 GET MOVFIN PICT "@!" VALID MOVFIN$"SN"
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Confirma Inclusao ?")
      IF CFOP->(ADDREC())
         CFOP->CFOP_V:=CFOP
         CFOP->MENSAGEM_V:=MENSAGEM
         CFOP->MOVEST_V := MOVEST=="S"
         CFOP->MOVIMP_V := MOVIMP=="S"
         CFOP->MOVFIN_V := MOVFIN=="S"
         CFOP->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
ENDDO
RETURN(.T.)