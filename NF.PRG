FUNCTION CORPARCS(VALFRETE)
LOCAL I, FRETEPARC, RESTO,DIVIDIR
MEMVAR MDATE,VALPAR,VALMO
MEMVAR CORTIT
DIVIDIR=.F.
IF DIVIDIR
   I := 0
   IF ! EMPTY(PEDIDO->DATPAG_V)
      I++
   ENDIF
   IF ! EMPTY(PEDIDO->DATPAG1_V)
      I++
   ENDIF
   IF ! EMPTY(PEDIDO->DATPAG2_V)
      I++
   ENDIF
   IF ! EMPTY(PEDIDO->DATPAG3_V)
      I++
   ENDIF
   IF ! EMPTY(PEDIDO->DATPAG4_V)
      I++
   ENDIF
   FRETEPARC = VALFRETE / I
   FRETEPARC = ROUND(FRETEPARC,2)
   RESTO = VALFRETE - (FRETEPARC * I)
   IF ! EMPTY(PEDIDO->DATPAG_V)
      @ 20,2 SAY DTOC(MDATE[1])
      @ 21,2 SAY TRANSFORM(VALPAR[1]+FRETEPARC+RESTO,"@R 999,999.99")
   ENDIF
   IF ! EMPTY(PEDIDO->DATPAG1_V)
      @ 20,14 SAY DTOC(MDATE[2])
      @ 21,14 SAY TRANSFORM(VALPAR[2]+FRETEPARC,"@R 999,999.99")
   ENDIF
   IF ! EMPTY(PEDIDO->DATPAG2_V)
      @ 20,26 SAY DTOC(MDATE[3])
      @ 21,26 SAY TRANSFORM(VALPAR[3]+FRETEPARC,"@R 999,999.99")
   ENDIF
   IF ! EMPTY(PEDIDO->DATPAG3_V)
      @ 20,38 SAY DTOC(MDATE[4])
      @ 21,38 SAY TRANSFORM(VALPAR[4]+FRETEPARC,"@R 999,999.99")
   ENDIF
   IF ! EMPTY(PEDIDO->DATPAG4_V)
      @ 20,50 SAY DTOC(MDATE[5])
      @ 21,50 SAY TRANSFORM(VALPAR[5]+FRETEPARC,"@R 999,999.99")
   ENDIF
ELSE
   @ 21,2 SAY TRANSFORM(VALPAR[1]+VALFRETE,"@R 999,999.99")
ENDIF
@ 23,01 SAY PADL("Itens : "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+"  Servi‡os : "+TRANSFORM(VALMO,"@R 999,999,999.99")+"  Total : "+TRANSFORM(PEDIDO->VALTOT_V+VALMO+VALFRETE,"@R 999,999,999.99")+" ",78) COLOR CORTIT
RETURN .T.

function verificaNota(nota, serie)
local lReturn := .t.
lReturn := !nota->(dbsetorder(7), dbseek(dtos(date())+str(nota,6)+serie))
nota->(dbsetorder(1))
return lReturn