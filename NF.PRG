FUNCTION NF(PED)
LOCAL TELA,COL,GETLIST:={}
LOCAL CONT,TOTAL,TELA2
LOCAL I,FRETEPARC,RESTO,DIVIDIR,nTotalFrete, mpagrec
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN

MEMVAR PEDIDO,LINSERV1,LINSERV2,LINSERV3,LINSERV4,VALMO,VALTOT,OBSERVA1

MEMVAR FRETE,PLACA,UF,QUANT,ESPECIE,MARCA,NUMERO,PESOBRU,PESOLIQ
MEMVAR NOTA,DATSAI,HORASAI,DATEMI,HORAEMI,CODTRAN,CFOP,VALFRETE,ICMFRETE,CUPOM,MSGFISC

MEMVAR MDATE,VALPAR, NATOPER

TELA:=SAVESCREEN()

WINDOW(0,0,24,79)

PEDIDO :=PED
CONT   :=.F.
NOTA   :=0
CUPOM  :=0
VALFRETE:=PEDIDO->FRETE_V
CODTRAN:=IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->CODTRAN_V,0)
CFOP   :=SPACE(len(cfop->cfop_v))
IF PEDIDO ->(DBSEEK(PEDIDO))
   CONT:=.T.
ENDIF
MDATE:={,,,,,}
VALPAR:={,,,,,}

VALMO:=PEDIDO->VALMO_V
LINSERV1:=PEDIDO->LINSERV1_V
LINSERV2:=PEDIDO->LINSERV2_V
LINSERV3:=PEDIDO->LINSERV3_V
LINSERV4:=PEDIDO->LINSERV4_V

OBSERVA1:= PEDIDO->OBSERVA1_V
FRETE  :=SPACE(1)
PLACA  :=SPACE(9)
UF     :=SPACE(2)
QUANT  :=0
ESPECIE:=SPACE(15)
MARCA  :=SPACE(15)
NUMERO :=SPACE(15)
PESOBRU:=0
PESOLIQ:=0
DATEMI :=DATE()
HORAEMI:=TIME()
DATSAI :=DATE()
HORASAI:=TIME()
ICMFRETE:=CONFIG->DEFICMS_V
MSGFISC:=CONFIG->MSGFISC_V
NATOPER := padr("VENDAS", LEN(NOTA->NATOPER_V))
NOTA->(DBSETORDER(7), dbgobottom())
NOTA=NOTA->CODIGO_V+1
NOTA->(dbsetorder(1))
DO WHILE CONT=.T.
   TOTAL   :=0
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 1,2   SAY "Nota Fiscal   :" GET NOTA PICT "999999" VALID(NOTA>0.AND. VerificaNota(Nota, "0"))
   @ 1,25  SAY "Cupom Fiscal  :" GET CUPOM PICT "999999" // VALID(CUPOM==0.OR.!NOTA->(DBSETORDER(6),DBSEEK(STR(CUPOM,6)+" ")))
   @ 2,2   SAY "Cliente       : "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->NOME_V,SPACE(50))
   @ 3,2   SAY "C.F.OP.Transp.:" GET CFOP VALID(LASTKEY()=5 .OR. SEA_CFOP(CFOP,3,28))
   if config->nfe_v=="S"
      @ 3,47 SAY "Nt.Operacao:" GET NATOPER PICT "@!S18"
   endif

   @ 4,2   SAY "Transportadora:" GET CODTRAN PICT "99999" VALID(LASTKEY()=5 .OR. SEA_CODTRAN(CODTRAN,4,25))
   @ 05,01 SAY PADC("Descricao dos Servicos Prestados",78) COLOR CORTIT
   @ 06,02 SAY LINSERV1
   @ 07,02 SAY LINSERV2
   @ 08,02 SAY LINSERV3
   @ 09,02 SAY LINSERV4
   @ 10,1  SAY PADC("Observacoes",78)
   @ 11,02 GET OBSERVA1 PICT "@S76"
   @ 12,1  SAY PADC("Volumes Transportados",78) COLOR CORTIT
   @ 13,2  SAY "Frete p/Conta :" GET FRETE VALID(FRETE$"12 ")
   @ 13,20 SAY "Valor : " + transform(VALFRETE,"@r 99,999.99") // VALID CORPARCS(VALFRETE)
   @ 13,38 SAY "ICMS :" GET ICMFRETE PICT "@R 99.9999%"
   @ 13,54 SAY "Placa :" GET PLACA PICT "@!r NNN-9999"
   @ 13,71 SAY "UF :" GET UF pict "@!"
   @ 14,2  SAY "Quantidade :" GET QUANT PICT "999,999,999"
   @ 14,31 SAY "Especie      :" GET ESPECIE
   @ 15,2  SAY "Marca      :" GET MARCA
   @ 15,31 SAY "Numero       :" GET NUMERO
   @ 16,2  SAY "Peso Bruto :" GET PESOBRU PICT "999,999.999"
   @ 16,31 SAY "Peso Liquido :" GET PESOLIQ PICT "999,999.999"
   @ 17,2  SAY "Dt. Emissao:" GET DATEMI
   @ 17,31 SAY "Data Saida   :" GET DATSAI
   @ 17,57 SAY "Hora Saˇda :" GET HORASAI
   @ 18,2  SAY "Msg.Fisco" GET MSGFISC pict "@s66"
   @ 19,1  SAY PADC("Faturamento",78) COLOR CORTIT
   IF ! EMPTY(PEDIDO->DATPAG_V)
      MDATE[1]:=PEDIDO->DATPAG_V
      VALPAR[1]:=PEDIDO->VALPAR_V
      @ 20,2 SAY DTOC(MDATE[1])
      @ 21,2 SAY TRANSFORM(VALPAR[1],"@R 999,999.99")
   ENDIF
   IF ! EMPTY(PEDIDO->DATPAG1_V)
      MDATE[2]:=PEDIDO->DATPAG1_V
      VALPAR[2]:=PEDIDO->VALPAR1_V
      @ 20,14 SAY DTOC(MDATE[2])
      @ 21,14 SAY TRANSFORM(VALPAR[2],"@R 999,999.99")
   ENDIF
   IF ! EMPTY(PEDIDO->DATPAG2_V)
      MDATE[3]:=PEDIDO->DATPAG2_V
      VALPAR[3]:=PEDIDO->VALPAR2_V
      @ 20,26 SAY DTOC(MDATE[3])
      @ 21,26 SAY TRANSFORM(VALPAR[3],"@R 999,999.99")
   ENDIF
   IF ! EMPTY(PEDIDO->DATPAG3_V)
      MDATE[4]:=PEDIDO->DATPAG3_V
      VALPAR[4]:=PEDIDO->VALPAR3_V
      @ 20,38 SAY DTOC(MDATE[4])
      @ 21,38 SAY TRANSFORM(VALPAR[4],"@R 999,999.99")
   ENDIF
   IF ! EMPTY(PEDIDO->DATPAG4_V)
      MDATE[5]:=PEDIDO->DATPAG4_V
      VALPAR[5]:=PEDIDO->VALPAR4_V
      @ 20,50 SAY DTOC(MDATE[5])
      @ 21,50 SAY TRANSFORM(VALPAR[5],"@R 999,999.99")
   ENDIF
   @ 22,1 TO 22,78
   @ 23,01 SAY PADL("Itens : "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+"  Servi‡os : "+TRANSFORM(VALMO,"@R 999,999,999.99")+"  Total : "+TRANSFORM(PEDIDO->VALTOT_V+VALMO,"@R 999,999,999.99")+" ",78) COLOR CORTIT
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   @ 23,01 SAY PADL("Itens : "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+"  Servi‡os : "+TRANSFORM(VALMO,"@R 999,999,999.99")+"  Total : "+TRANSFORM(PEDIDO->VALTOT_V+VALMO,"@R 999,999,999.99")+" ",78) COLOR CORTIT
   IF ! CONFIRMA(20,20,"Confirma todos os dados ?")
      LOOP
   ENDIF
   IF ! PEDVIMP(PEDIDO->CODIGO_V,.T.)
      LOOP
   ENDIF
   IF CONFIRMA(20,20,"Gerar faturamento ?")
      gernfped()      
      if config->nfe_v=="S"
         gernfe()
      else
         DO WHILE ! ISPRINTER()
            AVISO("Impressora fora de linha ou nao conectada")
         ENDDO
         IMPNF()
      endif
      EXIT
   ENDIF
ENDDO
CLOSEWIN(0,0,24,79)
RESTSCREEN(,,,,TELA)
RETURN(.T.)

function gernfped()
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN

MEMVAR PEDIDO,LINSERV1,LINSERV2,LINSERV3,LINSERV4,VALMO,VALTOT,OBSERVA1

MEMVAR FRETE,PLACA,UF,QUANT,ESPECIE,MARCA,NUMERO,PESOBRU,PESOLIQ
MEMVAR NOTA,DATSAI,HORASAI,DATEMI,HORAEMI,CODTRAN,CFOP,VALFRETE,ICMFRETE,CUPOM,MSGFISC

MEMVAR MDATE,VALPAR, NATOPER
IF NOTA->(ADDREC(5))
   NOTA->CODIGO_V  :=NOTA
   NOTA->SERIE_V   :="0"
   NOTA->CUPOM_V   :=CUPOM
   NOTA->PEDIDO_V  :=PEDIDO
   NOTA->CLIFOR_V  :=PEDIDO->CLIFOR_V
   NOTA->CODTRAN_V :=CODTRAN
   NOTA->CFOP_V    :=CFOP
   NOTA->DATEMI_V  :=DATEMI
   NOTA->HORAEMI_V :=HORAEMI
   NOTA->DATSAI_V  :=DATSAI
   NOTA->HORASAI_V :=HORASAI
   NOTA->FRETE_V   :=FRETE
   NOTA->PLACA_V   :=PLACA
   NOTA->UF_V      :=UF
   NOTA->QTD_V     :=QUANT
   NOTA->ESPECIE_V :=ESPECIE
   NOTA->MARCA_V   :=MARCA
   NOTA->NUMERO_V  :=NUMERO
   NOTA->PESOBRU_V :=alltrim(str(PESOBRU,15,3))
   NOTA->PESOLIQ_V :=alltrim(str(PESOLIQ,15,3))
   NOTA->VALMO_V   :=VALMO
   NOTA->VALITOT_V :=PEDIDO->VALTOT_V
   NOTA->VALFRETE_V:=VALFRETE
   NOTA->ICMFRETE_V:=ICMFRETE
   NOTA->MSGFISC_V :=MSGFISC
   NOTA->LINSERV1_V:=LINSERV1
   NOTA->LINSERV2_V:=LINSERV2
   NOTA->LINSERV3_V:=LINSERV3
   NOTA->LINSERV4_V:=LINSERV4
   NOTA->OBSERVA1_V:=OBSERVA1
   NOTA->NOMSEN_V  :=NOMSEN
   NOTA->NATOPER_V :=NATOPER
   nTotalFrete := 0
   pedido2->(dbsetorder(1), dbseek(pedido))
   do while !pedido2->(eof()) .and. pedido2->codigo_v == pedido
      nota2->(addrec())
      nota2->codigo_v := nota->codigo_v
      nota2->serie_v  := nota->serie_v
      nota2->datemi_v := nota->datemi_v
      nota2->item_v := pedido2->item_v
      nota2->valcus_v := pedido2->valcus_v
      nota2->valmin_v := pedido2->valmin_v
      nota2->valmed_v := pedido2->valmed_v
      nota2->valmax_v := pedido2->valmax_v
      nota2->valuni_v := pedido2->valuni_v
      nota2->qtd_v := pedido2->qtd_v
      nota2->icms_v := pedido2->icms_v
      nota2->ipi_v := pedido2->ipi_v
      nota2->valipi_v := pedido2->valipi_v
      nota2->bascal_v := pedido2->bascal_v
      nota2->tbascal_v := pedido2->tbascal_v
      nota2->frete_v := round( (nota->valfrete_v / nota->valitot_v) * (nota2->valuni_v * nota2->qtd_v) ,2)
      nota2->cfop_v    := pedido2->cfop_v
      nota2->sittabb_v := pedido2->sittabb_v
      nota2->modbc_v   := pedido2->modbc_v
      nota2->modbcst_v := pedido2->modbcst_v
      nota2->mgvradic_v:= pedido2->mgvradic_v
      nota2->bascalst_v:= pedido2->bascalst_v
      nota2->icmsst_v  := pedido2->icmsst_v
      nota2->modpis_v := pedido2->modpis_v
      nota2->pis_v := pedido2->pis_v
      nota2->mdcofins_v := pedido2->mdcofins_v
      nota2->cofins_v := pedido2->cofins_v
      nota2->(dbcommit(), dbunlock())
      nTotalFrete += nota2->frete_v
      pedido2->(dbskip())
   enddo
   nota2->(reclock())
   nota2->frete_v += (nota->valfrete_v - nTotalFrete)
   nota2->(dbcommit(), dbunlock())
   if (!empty(alltrim(pedido->pagrec_v)))
      PAGREC->(DBSETORDER(1))
      IF MDATE[1]#(NIL)
         IF PAGREC->(DBSEEK(PEDIDO->PAGREC_V))
            PAGREC->(RECLOCK(5))
            PAGREC->DOCINT_V:="NF."+ALLTRIM(STR(NOTA))+"-A"
            PAGREC->DATINT_V:=DATEMI
            PAGREC->(DBUNLOCK())
         ENDIF
         NOTA->DATPAR1_V:=MDATE[1]
         NOTA->VALPAR1_V:=VALPAR[1]
      ENDIF
      IF MDATE[2]#(NIL)
         IF PAGREC->(DBSEEK(PEDIDO->PAGREC1_V))
            PAGREC->(RECLOCK(5))
            PAGREC->DOCINT_V:="NF."+ALLTRIM(STR(NOTA))+"-B"
            PAGREC->DATINT_V:=DATEMI
            PAGREC->(DBUNLOCK())
         ENDIF
         NOTA->DATPAR2_V:=MDATE[2]
         NOTA->VALPAR2_V:=VALPAR[2]
      ENDIF
      IF MDATE[3]#(NIL)
         IF PAGREC->(DBSEEK(PEDIDO->PAGREC2_V))
            PAGREC->(RECLOCK(5))
            PAGREC->DOCINT_V:="NF."+ALLTRIM(STR(NOTA))+"-C"
            PAGREC->DATINT_V:=DATEMI
            PAGREC->(DBUNLOCK())
         ENDIF
         NOTA->DATPAR3_V:=MDATE[3]
         NOTA->VALPAR3_V:=VALPAR[3]
      ENDIF
      IF MDATE[4]#(NIL)
         IF PAGREC->(DBSEEK(PEDIDO->PAGREC3_V))
            PAGREC->(RECLOCK(5))
            PAGREC->DOCINT_V:="NF."+ALLTRIM(STR(NOTA))+"-D"
            PAGREC->DATINT_V:=DATEMI
            PAGREC->(DBUNLOCK())
         ENDIF
         NOTA->DATPAR4_V:=MDATE[4]
         NOTA->VALPAR4_V:=VALPAR[4]
      ENDIF
      IF MDATE[5]#(NIL)
         IF PAGREC->(DBSEEK(PEDIDO->PAGREC4_V))
            PAGREC->(RECLOCK(5))
            PAGREC->DOCINT_V:="NF."+ALLTRIM(STR(NOTA))+"-E"
            PAGREC->DATINT_V:=DATEMI
            PAGREC->(DBUNLOCK())
         ENDIF
         NOTA->DATPAR5_V:=MDATE[5]
         NOTA->VALPAR5_V:=VALPAR[5]
      ENDIF
   else
      if config->autven_v="P" .and. config->tipaut_v=='N'
         if confirma(20,20,"Registrar Contas Futuras ?")
            registrar:="S"
         else
            registrar:="N"
         endif
      else
         registrar:=if(config->autven_v=='S' .and. config->tipaut_v=='N', 'S', 'N')
      endif
      mpagrec := array(0)
      pedfat->(dbsetorder(2), dbseek(pedido->codigo_v))
      do while !pedfat->(eof()) .and. pedfat->codigo_v == pedido->codigo_v
         if registrar == "S"
            pagrec->(addrec(5))
            config->(reclock())
            pagrec:="R"+strzero(config->pagrec_v+1,5,0)
            config->pagrec_v:=config->pagrec_v+1
            config->(dbunlock())
            pagrec->codigo_v :=pagrec
            pagrec->clifor_v :=nota->clifor_v
            pagrec->codpla_v :=pedido->codpla_v
            pagrec->pedido_v :=pedido->codigo_v
            pagrec->valor_v  :=pedfat->vrparc_v
            pagrec->datven_v :=pedfat->dtparc_v
            pagrec->docext_v :=pedfat->docext_v
            pagrec->docint_v :="nf."+alltrim(str(nota->codigo_v))
            pagrec->datint_v :=nota->datemi_v
            pagrec->desc_v   :="Venda nf."+alltrim(str(nota->codigo_v))+" pedido "+pedido->codigo_v
            pagrec->(dbunlock())
            xmig_add_pagrec(@mpagrec)
         endif
         pedfat->(reclock(5))
         if registrar == "S"
            pedfat->pagrec_v :=pagrec
         endif
         pedfat->nota_v := nota->codigo_v
         pedfat->datnf_v := nota->datemi_v
         pedfat->(dbcommit(), dbunlock())
         pedfat->(dbskip())
      enddo
      if (!empty(mpagrec))
      	xmig_pagrec(mpagrec)
      endif
   endif
   NOTA->(DBUNLOCK())
   PEDIDO->(RECLOCK())
   PEDIDO->NOTA_V:=NOTA
   PEDIDO->CFOP_V:=CFOP
   IF EMPTY(PEDIDO->DATPAG_V)
      PEDIDO->DATPAG_V:=DATEMI
   ENDIF
   PEDIDO->(DBUNLOCK())
ENDIF
return nil

FUNCTION IMPNF()
LOCAL  VALBASE,VALICMS,MESSAGE,X,LIN,COL,VALBAS,ARQNF, NOMEPRO
MEMVAR PEDIDO

MEMVAR FRETE,PLACA,UF,QUANT,ESPECIE,MARCA,NUMERO,PESOBRU,PESOLIQ
MEMVAR NOTA,DATSAI,HORASAI,DATEMI,HORAEMI, NATOPER

MEMVAR MDATE,VALPAR
DBF_MECVEN()
VALBASE:=0
VALICMS:=0
MESSAGE:={,,,,,,,}
ARQNF = "notas\nf"+strzero(nota,6,0)+".txt"
//SET PRINTER TO &ARQNF
SET PRINTER TO LPT1
//LigaImpressora()
SET DEVICE TO PRINTER
IF EMPTY(CONFIG->MODNF_V)
   @ 0,0 SAY CHR(18)
   @ 1,85   SAY STRZERO(NOTA,7,0)
   @ 3,62   SAY "X"
   @ PROW(),PCOL() SAY CHR(15)
   @ 8,2    SAY IF(CFOP->(DBSEEK(NOTA->CFOP_V)),CFOP->MENSAGEM_V,SPACE(18))
   @ 8,30   SAY NOTA->CFOP_V
   @ 11,4   SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),CLIFOR->NOME_V,SPACE(50))
   @ 11,105  SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),CLIFOR->CGCCPF_V,SPACE(19))
   @ 11,145 SAY DTOC(NOTA->DATEMI_V)
   @ 13,4   SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),alltrim(CLIFOR->ENDERECO_V)+" "+alltrim(clifor->numero_v)+" "+alltrim(clifor->complem_v),SPACE(50))
   @ 13,85  SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),LEFT(CLIFOR->BAIRRO_V,27),SPACE(27))
   @ 13,118 SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),TRANSFORM(CLIFOR->CEP_V,"@R 99999-999"),SPACE(8))
   @ 13,145 SAY DTOC(NOTA->DATSAI_V)
   @ 15,4   SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),LEFT(CLIFOR->CIDADE_V,25),SPACE(25))
   @ 15,72  SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),TRANSFORM(CLIFOR->FONE1_V,"@R (#99) ###99-9999"),SPACE(12))
   @ 15,104 SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),CLIFOR->ESTADO_V,SPACE(2))
   @ 15,105  SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),CLIFOR->RGINSEST_V,SPACE(15))
   @ 15,145 SAY NOTA->HORASAI_V
   IF .NOT. EMPTY(PEDIDO->DATPAG_V)
      @ 18,4 SAY STRZERO(NOTA,6)+'-1'
      @ 18,32 SAY DTOC(PEDIDO->DATPAG_V)
      @ 18,60 SAY TRANSFORM(PEDIDO->VALPAR_V,'99,999.99')
   ENDIF
   IF .NOT. EMPTY(PEDIDO->DATPAG1_V)
      @ 18,89 SAY STRZERO(NOTA,6)+'-2'
      @ 18,117 SAY DTOC(PEDIDO->DATPAG1_V)
      @ 18,145 SAY TRANSFORM(PEDIDO->VALPAR1_V,'99,999.99')
   ENDIF
   IF .NOT. EMPTY(PEDIDO->DATPAG2_V)
      @ 19,4 SAY STRZERO(NOTA,6)+'-3'
      @ 19,32 SAY DTOC(PEDIDO->DATPAG2_V)
      @ 19,60 SAY TRANSFORM(PEDIDO->VALPAR2_V,'99,999.99')
   ENDIF
   IF .NOT. EMPTY(PEDIDO->DATPAG3_V)
      @ 19,89 SAY STRZERO(NOTA,6)+'-4'
      @ 19,117 SAY DTOC(PEDIDO->DATPAG3_V)
      @ 19,145 SAY TRANSFORM(PEDIDO->VALPAR3_V,'99,999.99')
   ENDIF
   PEDIDO2->(DBSETORDER(1))
   PEDIDO2->(DBSEEK(NOTA->PEDIDO_V))
   LIN:=22
   DO WHILE PEDIDO2->CODIGO_V=NOTA->PEDIDO_V
      VALBAS:=(PEDIDO2->BASCAL_V*PEDIDO2->QTD_V)*(PEDIDO2->BASCAL_V/100)
      X:=1
      DO WHILE .T.
         IF MESSAGE[X]=(NIL)
            MESSAGE[X]:=PEDIDO2->TBASCAL_V
            EXIT
         ENDIF
         IF MESSAGE[X]=PEDIDO2->TBASCAL_V
            EXIT
         ENDIF
         X++
      ENDDO
      VALBASE:=VALBASE+VALBAS
      VALICMS:=VALICMS+((PEDIDO2->ICMS_V/100)*VALBAS)
     
      @ LIN,4   SAY PEDIDO2->ITEM_V
      @ LIN,20  SAY IF(ESTOQUE->(DBSEEK(PEDIDO2->ITEM_V)),LEFT(ESTOQUE->NOME_V,35),SPACE(35))
      @ LIN,101 SAY IF(ESTOQUE->(DBSEEK(PEDIDO2->ITEM_V)),ALLTRIM(STR(ESTOQUE->SITTABA_V))+ALLTRIM(STR(ESTOQUE->SITTABB_V)),SPACE(2))
      @ LIN,107 SAY IF(PEDIDO2->QTD_V>0,TRANSFORM(PEDIDO2->QTD_V,"99,999"),SPACE(6))
      @ LIN,115 SAY IF(PEDIDO2->VALUNI_V>0,TRANSFORM(PEDIDO2->VALUNI_V,"999,999,999.99"),SPACE(9))
      @ LIN,138 SAY IF(PEDIDO2->VALUNI_V*PEDIDO2->QTD_V>0,TRANSFORM(PEDIDO2->VALUNI_V*PEDIDO2->QTD_V,"999,999,999.99"),SPACE(9))
      @ LIN,158 SAY IF(PEDIDO2->ICMS_V>0,TRANSFORM(PEDIDO2->ICMS_V,"@R 99%"),SPACE(4))
      PEDIDO2->(DBSKIP())
      LIN++
   ENDDO
   X:=1
   DO WHILE .T.
      IF MESSAGE[X]=(NIL)
         EXIT
      ENDIF
      @ LIN,14 SAY MESSAGE[X]
      LIN++
      X++
   ENDDO
   @ 39,4 SAY NOTA->LINSERV1_V
   @ 40,4 SAY NOTA->LINSERV2_V
   IF NOTA->VALMO_V*(5/100)>0
      @ 42,120 SAY NOTA->VALMO_V*(5/100) PICT "@R 999,999,999.99"
   ENDIF
   @ 41,4 SAY NOTA->LINSERV3_V
   @ 42,4 SAY NOTA->LINSERV4_V
   IF NOTA->VALMO_V>0
      @ 44,120 SAY NOTA->VALMO_V PICT "@R 999,999,999.99"
   ENDIF
   @ 44,40  SAY CONFIG->NFCOMPL_V
   @ 46,14  SAY IF(VALBASE>0,TRANSFORM(VALBASE,"@R 999,999,999.99")," ")
   @ 46,40  SAY IF(VALICMS>0,TRANSFORM(VALICMS,"@R 999,999,999.99")," ")
   @ 46,135 SAY IF(NOTA->VALITOT_V>0,TRANSFORM(NOTA->VALITOT_V,"@R 999,999,999.99")," ")
   @ 48,135 SAY IF((NOTA->VALITOT_V+NOTA->VALMO_V)>0,TRANSFORM(NOTA->VALITOT_V+NOTA->VALMO_V,"@R 999,999,999.99")," ")
   @ 51,4   SAY IF(TRANSP->(DBSEEK(NOTA->CODTRAN_V)),TRANSP->NOME_V,SPACE(50))
   @ 51,100  SAY NOTA->FRETE_V
   @ 51,111  SAY NOTA->PLACA_V
