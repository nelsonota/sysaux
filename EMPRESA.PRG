FUNCTION EMPRESA()
LOCAL TELA,GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN,TRABALHO
LOCAL NOME,ENDERECO,BAIRRO,CIDADE,ESTADO,FONE1,FONE2,FAX,CGC,INSEST,INSMUN, NUMERO, COMPLEM,CEP, CNAE, REGTRIB
TELA:=SAVESCREEN(0,0,24,80)
WINDOW(10,5,22,79)
DBF_CONFIG()
DBF_CADCID()
NOME    :=DECRIP(CONFIG->NOME_V)
ENDERECO:=DECRIP(CONFIG->ENDERECO_V)
NUMERO  :=DECRIP(CONFIG->NUMERO_V)
COMPLEM :=DECRIP(CONFIG->COMPLEM_V)
BAIRRO  :=DECRIP(CONFIG->BAIRRO_V)
CIDADE  :=DECRIP(CONFIG->CIDADE_V)
ESTADO  :=DECRIP(CONFIG->ESTADO_V)
CEP     :=DECRIP(CONFIG->CEP_V)
FONE1   :=DECRIP(CONFIG->FONE1_V)
FONE2   :=DECRIP(CONFIG->FONE2_V)
FAX     :=DECRIP(CONFIG->FAX_V)
CGC     :=DECRIP(CONFIG->CGC_V)
INSEST  :=DECRIP(CONFIG->INSEST_V)
INSMUN  :=DECRIP(CONFIG->INSMUN_V)
CNAE    :=DECRIP(CONFIG->CNAE_V)
REGTRIB :=CONFIG->REGTRIB_V
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 11,7  SAY "Empresa   :" GET NOME     PICT "@K"
   @ 13,7  SAY "Endereco  :" GET ENDERECO PICT "@s29!"
   @ 13,49 SAY "N.:" GET NUMERO
   @ 13,60 say "Compl.:" GET COMPLEM
   @ 14,7  SAY "Bairro    :" GET BAIRRO   PICT "@K"
   @ 15,7  SAY "Cidade    :" GET CIDADE   PICT "@K" valid sea_cidade(upper(cidade))
   @ 16,7  SAY "Estado    :" GET ESTADO   PICT "@K"
   @ 16,22 SAY "CEP:" GET CEP PICT "@R 99999-999"
   @ 17,7  SAY "C.G.C.    :" GET CGC      PICT "@K"
   @ 18,7  SAY "I.Estadual:" GET INSEST   PICT "@K"
   @ 18,36 SAY "I.Municipal:" GET INSMUN  PICT "@K"
   @ 19,7  SAY "Telefone1 :" GET FONE1    PICT "@K"
   @ 19,33  SAY "Telefone2 :" GET FONE2    PICT "@K"
   @ 20,7  SAY "TeleFax   :" GET FAX      PICT "@K"
   @ 21,7 say "CNAE:" get CNAE
   @ 21,21 say "Regime Tributario:" get REGTRIB
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(22,20,"Confirma Dados Da Empresa ?")
      IF CONFIG->(RECLOCK(5))
         CONFIG->NOME_V    :=CRIP(NOME)
         CONFIG->ENDERECO_V:=CRIP(ENDERECO)
         CONFIG->NUMERO_V  :=CRIP(NUMERO)
         CONFIG->COMPLEM_V :=CRIP(COMPLEM)
         CONFIG->BAIRRO_V  :=CRIP(BAIRRO)
         CONFIG->CIDADE_V  :=CRIP(CIDADE)
         CONFIG->CEP_V     :=CRIP(CEP)
         CONFIG->ESTADO_V  :=CRIP(ESTADO)
         CONFIG->FONE1_V   :=CRIP(FONE1)
         CONFIG->FONE2_V   :=CRIP(FONE2)
         CONFIG->FAX_V     :=CRIP(FAX)
         CONFIG->CGC_V     :=CRIP(CGC)
         CONFIG->INSEST_V  :=CRIP(INSEST)
         CONFIG->INSMUN_V  :=CRIP(INSMUN)
         CONFIG->CNAE_V    :=CRIP(CNAE)
         CONFIG->REGTRIB_V :=REGTRIB
         CONFIG->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
ENDDO
RESTSCREEN(0,0,24,80,TELA)
CONFIG->(DBCLOSEAREA())
CADCID->(DBCLOSEAREA())
RETURN(.T.)