FUNCTION ITRANSP()
LOCAL GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN
*** VARIAVEIS PARA CADASTRO DE TRANSPORTADORAS
MEMVAR CODIGO,NOME,ENDERECO,CIDADE,ESTADO,CGC,INSEST,FONE1,FONE2,FAX,CONTATO
MEMVAR CIDSERV1,CIDSERV2,CIDSERV3, NUMERO, COMPLEM
CODIGO  :=CONFIG->TRANSP_V+1
NOME    :=SPACE(LEN(NOME))
ENDERECO:=SPACE(LEN(ENDERECO))
CIDADE  :=SPACE(LEN(CIDADE))
ESTADO  :=SPACE(LEN(ESTADO))
CGC     :=SPACE(LEN(CGC))
INSEST  :=SPACE(LEN(INSEST))
FONE1   :=SPACE(LEN(TRANSP->FONE1_V))
FONE2   :=SPACE(LEN(TRANSP->FONE2_V))
FAX     :=SPACE(LEN(TRANSP->FAX_V))
CONTATO :=SPACE(LEN(TRANSP->CONTATO_V))
CIDSERV1:=SPACE(LEN(TRANSP->CIDSERV1_V))
CIDSERV2:=SPACE(LEN(TRANSP->CIDSERV2_V))
CIDSERV3:=SPACE(LEN(TRANSP->CIDSERV3_V))
DO WHILE .T.
   @ 11,13 SAY STRZERO(CODIGO,5,0)
   TRANSP->(DBSETORDER(2))
   @ 12,13 GET NOME     PICT "@K!" VALID(!EMPTY(NOME).AND.!TRANSP->(DBSEEK(NOME)))
   @ 13,13 GET ENDERECO PICT "@s35!"
   @ 13,53 GET NUMERO PICT "@!"
   @ 13,68 GET COMPLEM PICT "@!"
   @ 14,13 GET CIDADE   PICT "@K!" valid sea_cidade(cidade)
   @ 14,54 GET ESTADO   PICT "@K!"
   @ 15,13 GET CGC      valid empty(cgc) .or. cgccpf(cgc)
   @ 15,54 GET INSEST   valid if(len(sonumero(cgc))>11,ieok(insest, ESTADO),.t.)
   @ 16,13 GET FONE1    PICT "@R (#999) ##99-9999"
   @ 16,37 GET FONE2    PICT "@R (#999) ##99-9999"
   @ 16,59 GET FAX      PICT "@R (#999) ##99-9999"
   @ 17,13 GET CONTATO  PICT "@!"
   @ 19,13 GET CIDSERV1 PICT "@!"
   @ 20,13 GET CIDSERV2 PICT "@!"
   @ 21,13 GET CIDSERV3 PICT "@!"
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Confirma Inclusao de Transportadora ?")
      IF CONFIG->(RECLOCK(5))
         CONFIG->TRANSP_V:=CONFIG->TRANSP_V+1
         CODIGO:=CONFIG->TRANSP_V
         CONFIG->(DBUNLOCK())
      ENDIF
      IF TRANSP->(ADDREC(5))
         TRANSP->CODIGO_V  :=CODIGO
         TRANSP->NOME_V    :=NOME
         TRANSP->ENDERECO_V:=ENDERECO
         TRANSP->NUMERO_V  :=NUMERO
         TRANSP->COMPLEM_V :=COMPLEM
         TRANSP->CIDADE_V  :=CIDADE
         TRANSP->ESTADO_V  :=ESTADO
         TRANSP->CGC_V     :=CGC
         TRANSP->INSEST_V  :=INSEST
         TRANSP->FONE1_V   :=FONE1
         TRANSP->FONE2_V   :=FONE2
         TRANSP->FAX_V     :=FAX
         TRANSP->CONTATO_V :=CONTATO
         TRANSP->NOMSEN_V  :=NOMSEN
         TRANSP->CIDSERV1_V:=CIDSERV1
         TRANSP->CIDSERV2_V:=CIDSERV2
         TRANSP->CIDSERV3_V:=CIDSERV3
         TRANSP->(DBUNLOCK())
      ENDIF
      EXIT
   ENDIF
ENDDO
RETURN(.T.)