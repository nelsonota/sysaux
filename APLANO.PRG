FUNCTION APLANO()
LOCAL GETLIST:={},COD
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN

****** VARIAVEIS P/ CADASTRO DE PLANO DE CONTA
MEMVAR CODIGO,NOME
COD:=CODIGO
DO WHILE .T.
   @ 15,21 GET CODIGO VALID(LEFT(CODIGO,1)$"+-=".AND.!PLANO->(DBSEEK(CODIGO)).OR.CODIGO=COD)
   @ 16,21 GET NOME   PICT "@!" VALID(!EMPTY(NOME))
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Confirma Altera‡ao do Plano de Conta ?")
      PLANO->(DBSEEK(COD))
      IF FOUND()
         IF PLANO->(RECLOCK(10))
            PLANO->CODIGO_V:=CODIGO
            PLANO->NOME_V  :=NOME
            PLANO->(DBUNLOCK())
            EXIT
         ENDIF
      ENDIF
   ENDIF
ENDDO
RETURN(.T.)