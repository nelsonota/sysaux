FUNCTION PLANO()
LOCAL OP,TELA
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN

****** VARIAVEIS P/ CADASTRO DE PLANO DE CONTA
MEMVAR CODIGO,NOME
TELA:=SAVESCREEN(0,0,24,80)
WINDOW(17,8,19,43)
WINDOW(14,8,17,43)
@ 18,43 SAY CHR(219)
SETCOLOR(CORTIT)
@ 13,8 SAY "Tabela de Plano de Contas"
DBF_PLANO()
DO WHILE .T.
   SETCOLOR(CORTEX)
   CODIGO:=PLANO->CODIGO_V
   NOME  :=PLANO->NOME_V
   @ 15,10 SAY "Código   : " + CODIGO
   @ 16,10 SAY "Descrićao: " + NOME
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 18,9  PROMPT " Incluir "
   @ 18,18 PROMPT " Buscar "
   @ 18,26 PROMPT " Alterar "
   @ 18,35 PROMPT " Apagar "
   MENU TO OP
   DO CASE
      CASE OP=1
         IPLANO()
      CASE OP=2
         BPLANO()
      CASE OP=3
         APLANO()
      CASE OP=4
         EPLANO()
      OTHERWISE
         EXIT
   ENDCASE
ENDDO
PLANO->(DBCLOSEAREA())
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(14,8,17,43)
RETURN(.T.)