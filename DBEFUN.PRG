               TECNICA->(DBSETFILTER({|| !EMPTY(TECNICA->NOTA_V).OR.EMPTY(TECNICA->DATSAI_V).OR.TECNICA->DATSAI_V=DATE()},"!EMPTY(TECNICA->NOTA_V).OR.EMPTY(TECNICA->DATSAI_V).OR.TECNICA->DATSAI_V=DATE()"))
               KEYBOARD CHR(31)
            ENDIF
         ELSE
            IF LASTKEY()#27
               CLIFOR->(DBSETORDER(2))
               CLIFOR->(DBSEEK(PROCURA,.T.))
               DBE_CLIFOR(10,5,20,75)
               PROCURA:=CLIFOR->CODIGO_V
               CLIFOR->(DBSETORDER(1))
               TECNICA->(DBSETFILTER({|| TECNICA->CLIFOR_V=PROCURA},"TECNICA->CLIFOR_V=PROCURA"))
               KEYBOARD CHR(31)
            ELSE
               CLIFOR->(DBSETORDER(1))
               TECNICA->(DBCLEARFILTER())
               KEYBOARD CHR(31)
            ENDIF
         ENDIF
      CASE NKEY=80 .OR. NKEY=112
         TECNICA->(DBSETORDER(3))
         PROCURA:=SPACE(LEN(TECNICA->PLACA_V))
         SETCURSOR(1)
         @ 24,2 SAY "Placa/Patrimânio : " GET PROCURA PICT "@!"
         READ
         SETCURSOR(0)
         IF CONFIG->PROTECT_V="S"
            IF LASTKEY()#27
               TECNICA->(DBSETFILTER({|| ALLTRIM(PROCURA)$TECNICA->PLACA_V.AND.(!EMPTY(TECNICA->NOTA_V).OR.EMPTY(TECNICA->DATSAI_V).OR.TECNICA->DATSAI_V=DATE())},"ALLTRIM(PROCURA)$TECNICA->PLACA_V.AND.(!EMPTY(TECNICA->NOTA_V).OR.EMPTY(TECNICA->DATSAI_V).OR.TECNICA->DATSAI_V=DATE())"))
               KEYBOARD CHR(31)
            ELSE
               TECNICA->(DBSETFILTER({|| !EMPTY(TECNICA->NOTA_V).OR.EMPTY(TECNICA->DATSAI_V.OR.TECNICA->DATSAI_V=DATE())},"!EMPTY(TECNICA->NOTA_V).OR.EMPTY(TECNICA->DATSAI_V).OR.TECNICA->DATSAI_V=DATE()"))
               KEYBOARD CHR(31)
            ENDIF
         ELSE
            IF LASTKEY()#27
               TECNICA->(DBSETFILTER({|| ALLTRIM(PROCURA)$TECNICA->PLACA_V},"ALLTRIM(PROCURA)$TECNICA->PLACA_V"))
               KEYBOARD CHR(31)
            ELSE
               TECNICA->(DBCLEARFILTER())
               KEYBOARD CHR(31)
            ENDIF
         ENDIF
      CASE NKEY=68 .OR. NKEY=100
         TECNICA->(DBCLEARFILTER())
         TECNICA->(DBSETORDER(3))
         PROCURA:=CTOD("  /  /  ")
         SETCURSOR(1)
         @ 24,2 SAY "Data :" GET PROCURA
         READ
         SETCURSOR(0)
         TECNICA->(DBSEEK(PROCURA,.T.))
   ENDCASE
   restscreen(,,,,tela2)
enddo
TECNICA->(DBCLEARFILTER())
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(LIN-1,COL-1,LIN2+1,COL2+1)
SETCOLOR(OLD)
RETURN(.T.)


