**************** CLIENTES / FORNECEDORES
FUNCTION DBE_CLIFOR(LIN,COL,LIN2,COL2,CODVEN)
LOCAL VARIAVEIS,MASCARAS,TITULOS,OLD,LINHA1,COLUNA,TELA
local tela2, nKey, getlist := {}, nome
MEMVAR CORTIT,CORTEX,S,N,aCODVEN
OLD   :=SETCOLOR()
TELA  :=SAVESCREEN(0,0,24,80)
LINHA1:=CHR(220)
COLUNA:=CHR(219)
S:="Sim"
N:="Nao"
VARIAVEIS:={"CLIFOR->CODIGO_V",;
            "CLIFOR->NOME_V",;
            "CLIFOR->FANTASIA_V",;
            "CLIFOR->CGCCPF_V",;
            "IF(aCODVEN=NIL .OR. CLIFOR->CODVEN_V=aCODVEN,padr(alltrim(CLIFOR->ENDERECO_V)+' '+alltrim(clifor->numero_v)+' '+alltrim(clifor->complem_v),50),SPACE(LEN(CLIFOR->ENDERECO_V)))",;
            "IF(aCODVEN=NIL .OR. CLIFOR->CODVEN_V=aCODVEN,CLIFOR->CIDADE_V,SPACE(LEN(CLIFOR->CIDADE_V)))",;
            "IF(aCODVEN=NIL .OR. CLIFOR->CODVEN_V=aCODVEN,CLIFOR->ESTADO_V,SPACE(LEN(CLIFOR->ESTADO_V)))",;
            "IF(aCODVEN=NIL .OR. CLIFOR->CODVEN_V=aCODVEN,CLIFOR->FONE1_V,SPACE(LEN(CLIFOR->FONE1_V)))",;
            "IF(aCODVEN=NIL .OR. CLIFOR->CODVEN_V=aCODVEN,CLIFOR->FONE2_V,SPACE(LEN(CLIFOR->FONE1_V)))",;
            "IF(!EMPTY(CLIFOR->BLACK_V),S,N)"}
MASCARAS :={,,,,,,,"@R (#99) ###99-9999","@R (#99) ###99-9999"}
TITULOS  :={"C¢digo","Nome","Fantasia", "CGC/CPF","Endere‡o","Cidade",;
            "Estado","Telefone 1","Telefone 2","Lista Negra"}
WINDOW(LIN-1,COL-1,LIN2+1,COL2+1)
SETCOLOR(CORTIT)
@ LIN-1,COL SAY "Clientes , Fornecedores , Eventos"
@ LIN2+1,COL+1 SAY "Pressione Setas "+CHR(27)+CHR(18)+CHR(26)
SETCOLOR(CORTEX)
@ 24,0 CLEAR TO 24,79
@ 24,2 SAY "Busca por (N)ome  (S)obreNome  (F)antasia  (C)NPJ/CPF"
aCODVEN := CODVEN
tela2 := savescreen()
do while .t.
	CLIFOR->(DBEDIT(LIN,COL,LIN2,COL2,VARIAVEIS,"S_TECLAS",MASCARAS,TITULOS,LINHA1,COLUNA))
   tela2 := savescreen()
   nKey := lastkey()
   DO CASE
     CASE NKEY=27 .OR. NKEY=13
        exit
     CASE NKEY=78 .OR. NKEY=110
        CLIFOR->(DBCLEARFILTER())
        CLIFOR->(DBSETORDER(2))
        SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
        @ 24,0 CLEAR TO 24,79
        NOME:=SPACE(LEN(CLIFOR->NOME_V))
        SETCURSOR(1)
        @ 24,2 SAY "Nome :" GET NOME PICT "@K!"
        READ
        SETCURSOR(0)
        IF LASTKEY()#27
           CLIFOR->(DBSEEK(NOME,.T.))
        ENDIF
     CASE NKEY=83 .OR. NKEY=115
        CLIFOR->(DBSETORDER(2))
        SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
        @ 24,0 CLEAR TO 24,79
        NOME:=SPACE(LEN(CLIFOR->NOME_V))
        SETCURSOR(1)
        @ 24,2 SAY "Nome :" GET NOME PICT "@K!"
        READ
        SETCURSOR(0)
        IF LASTKEY()#27
           CLIFOR->(DBSETFILTER({|| ALLTRIM(NOME)$CLIFOR->NOME_V},"ALLTRIM(NOME)$CLIFOR->NOME_V"))
           KEYBOARD CHR(31)
        ELSE
           CLIFOR->(DBCLEARFILTER())
           KEYBOARD CHR(31)
        ENDIF
     CASE NKEY=70 .OR. NKEY=102
        CLIFOR->(DBCLEARFILTER())
        CLIFOR->(DBSETORDER(3))
        SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
        @ 24,0 CLEAR TO 24,79
        NOME:=SPACE(LEN(CLIFOR->NOME_V))
        SETCURSOR(1)
        @ 24,2 SAY "Nome :" GET NOME PICT "@K!"
        READ
        SETCURSOR(0)
        IF LASTKEY()#27
           CLIFOR->(DBSEEK(NOME,.T.))
        ENDIF
     CASE NKEY=67 .OR. NKEY=99
        CLIFOR->(DBCLEARFILTER())
        CLIFOR->(DBSETORDER(6))
        SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
        @ 24,0 CLEAR TO 24,79
        CGCCPF:=SPACE(LEN(CLIFOR->CGCCPF_V))
        SETCURSOR(1)
        @ 24,2 SAY "CNPJ / CPF:" GET CGCCPF PICT "@!"
        READ
        SETCURSOR(0)
        IF LASTKEY()#27
           CLIFOR->(DBSEEK(TRIM(CGCCPF),.T.))
        ENDIF
   ENDCASE
   restscreen(,,,,tela2)
enddo
CLIFOR->(DBCLEARFILTER())
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(LIN-1,COL-1,LIN2+1,COL2+1)
SETCOLOR(OLD)
RETURN(.T.)

