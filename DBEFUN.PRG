do while .t.
   TECNICA->(DBEDIT(LIN,COL,LIN2,COL2,VARIAVEIS,"S_TECLAS",MASCARAS,TITULOS,LINHA1,COLUNA))
   tela2 := savescreen()
   nKey := lastkey()
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 24,0 CLEAR TO 24,79
   DO CASE
      CASE NKEY=27 .OR. NKEY=13
         exit
      CASE NKEY=78 .OR. NKEY=110
