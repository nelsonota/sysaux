         IF CONFIG->PROTECT_V="S"
            IF LASTKEY()#27
               CLIFOR->(DBSETORDER(2))
               CLIFOR->(DBSEEK(PROCURA,.T.))
               DBE_CLIFOR(10,5,20,75)
               PROCURA:=CLIFOR->CODIGO_V
               CLIFOR->(DBSETORDER(1))
               TECNICA->(DBSETFILTER({|| TECNICA->CLIFOR_V=PROCURA.AND.(!EMPTY(TECNICA->NOTA_V).OR.EMPTY(TECNICA->DATSAI_V).OR.TECNICA->DATSAI_V=DATE())},"TECNICA->CLIFOR_V=PROCURA.AND.(!EMPTY(TECNICA->NOTA_V).OR.EMPTY(TECNICA->DATSAI_V).OR.TECNICA->DATSAI_V=DATE())"))
