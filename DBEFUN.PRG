FUNCTION S_TECLAS(NMODE,NCOL, oTBrowse)
LOCAL NKEY,NRETVAL,TELA,OLD,PROCURA,GETLIST:={},PROCURA2
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,M1,M2,S
OLD:=SETCOLOR()
TELA:=SAVESCREEN(0,0,24,80)
NRETVAL:=1
NKEY:=LASTKEY()
DO CASE
   CASE NMODE==0
      NRETVAL:=1
   CASE NMODE==1
      NRETVAL:=1
   CASE NMODE==2
      NRETVAL:=1
   CASE NMODE==3
      NRETVAL:=1
   CASE NMODE==4
   		if nKey == K_UP .or. nKey == K_DOWN .or. nKey == K_LEFT .or. nKey == K_RIGHT .or. ;
   			nKey == K_HOME .or. nKey == K_END .or. nKey == K_PGUP .or. nKey == K_PGDN .or. ;
   			nKey == K_CTRL_UP .or. nKey == K_CTRL_DOWN .or. nKey == K_CTRL_LEFT .or. nKey ==  K_CTRL_RIGHT .or. ;
   			nKey == K_CTRL_HOME .or. nKey == K_CTRL_END .or. nKey == K_CTRL_PGUP .or. nKey == K_CTRL_PGDN
   			NRETVAL := 1
   		else
				nRetVal := 0
			endif
ENDCASE
SETCOLOR(OLD)
RESTSCREEN(0,0,24,80,TELA)
RETURN NRETVAL
