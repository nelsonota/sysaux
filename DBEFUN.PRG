         TECNICA->(DBSETORDER(2))
         SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
         @ 24,0 CLEAR TO 24,79
         PROCURA:=SPACE(LEN(CLIFOR->NOME_V))
         SETCURSOR(1)
         @ 24,2 SAY "Nome :" GET PROCURA PICT "@K!"
         READ
         SETCURSOR(0)
         IF LASTKEY()#27
            CLIFOR->(DBSETORDER(2))
            CLIFOR->(DBSEEK(PROCURA,.T.))
            DBE_CLIFOR(10,5,20,75)
            CLIFOR->(DBSETORDER(1))
            TECNICA->(DBSEEK(CLIFOR->CODIGO_V))
         ENDIF
      CASE NKEY=83 .OR. NKEY=115
         CLIFOR->(DBSETORDER(2))
