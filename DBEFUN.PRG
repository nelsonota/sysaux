FUNCTION DBE_PAGREC(LIN,COL,LIN2,COL2)
LOCAL VARIAVEIS,MASCARAS,TITULOS,OLD,LINHA1,COLUNA,TELA,MUDA
local tela2, nKey, getlist := {}, procura
MEMVAR CORTIT,CORTEX
OLD   :=SETCOLOR()
TELA  :=SAVESCREEN(0,0,24,80)
LINHA1:=CHR(220)
COLUNA:=CHR(219)
CLIFOR->(DBSETORDER(1))
VARIAVEIS:={"PAGREC->CODIGO_V","IF(CLIFOR->(DBSEEK(PAGREC->CLIFOR_V)),CLIFOR->NOME_V,SPACE(50))",;
            "PAGREC->DOCEXT_V","PAGREC->DESC_V","PAGREC->DOCINT_V",;
            "PAGREC->VALOR_V","PAGREC->DATVEN_V","PAGREC->BOLETO_V",;
            "PAGREC->DUPLICA_V","PAGREC->COBCHQ_V"}
MASCARAS :={,,,,,"@R 999,999,999.99",}
TITULOS  :={"C¢digo","Nome","Doc.Externo","Descri‡ao",;
            "Doc.Interno","Valor","Vencimento","Boleto","Duplicata","Cheque"}
WINDOW(LIN-1,COL-1,LIN2+1,COL2+1)
SETCOLOR(CORTIT)
@ LIN-1,COL SAY "Contas … Pagar / Receber"
@ LIN2+1,COL+1 SAY "Pressione Setas "+CHR(27)+CHR(18)+CHR(26)
SETCOLOR(CORTEX)
@ 24,0 CLEAR TO 24,79
@ 24,2 SAY "(N)ome-E(S)pec¡fico Doc.(E)xterno Doc.(I)nterno (V)encimento (0)Valor (B)oleto"
do while .t.
   PAGREC->(DBEDIT(LIN,COL,LIN2,COL2,VARIAVEIS,"S_TECLAS",MASCARAS,TITULOS,LINHA1,COLUNA))
   tela2 := savescreen()
   nKey := lastkey()
   DO CASE
      CASE NKEY=27 .OR. NKEY=13
         exit
      CASE NKEY=78 .OR. NKEY=110
         PAGREC->(DBCLEARFIL())
         PAGREC->(DBSETORDER(2))
         SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
         @ 24,0 CLEAR TO 24,79
         PROCURA:=SPACE(LEN(CLIFOR->NOME_V))
         SETCURSOR(1)
         @ 24,2 SAY "Nome :" GET PROCURA PICT "@K!"
         READ
         SETCURSOR(0)
         IF LASTKEY()#27
            CLIFOR->(DBSETORDER(2))
            CLIFOR->(DBSEEK(PROCURA,.T.))
            DBE_CLIFOR(10,5,20,75)
            PAGREC->(DBSEEK(CLIFOR->CODIGO_V))
         ENDIF
         CLIFOR->(DBSETORDER(1))
      CASE NKEY=83 .OR. NKEY=115
         CLIFOR->(DBSETORDER(2))
         SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
         @ 24,0 CLEAR TO 24,79
         PROCURA:=SPACE(LEN(CLIFOR->NOME_V))
         SETCURSOR(1)
         @ 24,2 SAY "Nome :" GET PROCURA PICT "@K!"
         READ
         SETCURSOR(0)
         IF LASTKEY()#27
            CLIFOR->(DBSETORDER(2))
            CLIFOR->(DBSEEK(PROCURA,.T.))
            DBE_CLIFOR(10,5,20,75)
            PROCURA:=CLIFOR->CODIGO_V
            CLIFOR->(DBSETORDER(1))
            PAGREC->(DBSETFILTER({|| PAGREC->CLIFOR_V=PROCURA},"PAGREC->CLIFOR_V=PROCURA"))
            KEYBOARD CHR(31)
         ELSE
            CLIFOR->(DBSETORDER(1))
            PAGREC->(DBCLEARFILTER())
            KEYBOARD CHR(31)
         ENDIF
      CASE NKEY=69 .OR. NKEY=101
         PAGREC->(DBCLEARFILTER())
         PAGREC->(DBSETORDER(3))
         PROCURA:=SPACE(LEN(PAGREC->DOCEXT_V))
         SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
         @ 24,0 CLEAR TO 24,79
         SETCURSOR(1)
         @ 24,2 SAY "Doc.Externo :" GET PROCURA
         READ
         SETCURSOR(0)
         IF LASTKEY()#27
            PAGREC->(DBSEEK(PROCURA,.T.))
         ENDIF
      CASE NKEY=73 .OR. NKEY=105
         PAGREC->(DBCLEARFILTER())
         PAGREC->(DBSETORDER(4))
         PROCURA:=SPACE(LEN(PAGREC->DOCINT_V))
         SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
         @ 24,0 CLEAR TO 24,79
         SETCURSOR(1)
         @ 24,2 SAY "Doc.Interno :" GET PROCURA
         READ
         SETCURSOR(0)
         IF LASTKEY()#27
            PAGREC->(DBSEEK(PROCURA,.T.))
         ENDIF
      CASE NKEY=86 .OR. NKEY=118
         PAGREC->(DBCLEARFILTER())
         PAGREC->(DBSETORDER(5))
         PROCURA:=DATE()
         SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
         @ 24,0 CLEAR TO 24,79
         SETCURSOR(1)
         @ 24,2 SAY "Vencimento :" GET PROCURA
         READ
         SETCURSOR(0)
         IF LASTKEY()#27
            PAGREC->(DBSEEK(PROCURA,.T.))
         ENDIF
      CASE NKEY=48
         PAGREC->(DBCLEARFILTER())
         PAGREC->(DBSETORDER(6))
         PROCURA:=0
         SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
         @ 24,0 CLEAR TO 24,79
         SETCURSOR(1)
         @ 24,2 SAY "Valor :" GET PROCURA PICT "999,999,999.99"
         READ
         SETCURSOR(0)
         IF LASTKEY()#27
            PAGREC->(DBLOCATE("PAGREC->VALOR_V","=",PROCURA))
         ENDIF
      CASE NKEY=66 .OR. NKEY=98
         PAGREC->(DBCLEARFILTER())
         PROCURA:=SPACE(20)
         SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
         @ 24,0 CLEAR TO 24,79
         SETCURSOR(1)
         @ 24,2 SAY "Boleto :" GET PROCURA
         READ
         SETCURSOR(0)
         IF LASTKEY()#27
            PAGREC->(DBLOCATE("PAGREC->BOLETO_V","=",PROCURA))
         ENDIF
   ENDCASE
   restscreen(,,,,tela2)
enddo
PAGREC->(DBCLEARFILTER())
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(LIN-1,COL-1,LIN2+1,COL2+1)
SETCOLOR(OLD)
RETURN(.T.)


