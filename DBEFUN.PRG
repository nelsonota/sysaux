FUNCTION DBE_PEDIDO(LIN,COL,LIN2,COL2,CODVEN)
LOCAL VARIAVEIS,MASCARAS,TITULOS,OLD,LINHA1,COLUNA,TELA,V
local tela2, nKey, getlist := {}, procura
MEMVAR CORTIT,CORTEX,aCODVEN
V:="V"
OLD   :=SETCOLOR()
TELA  :=SAVESCREEN(0,0,24,80)
LINHA1:=CHR(220)
COLUNA:=CHR(219)
CLIFOR->(DBSETORDER(1))
VARIAVEIS:={"PEDIDO->CODIGO_V",;
            "IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),IF(aCODVEN=NIL .OR. (CLIFOR->CODVEN_V=aCODVEN .AND. LEFT(PEDIDO->CODIGO_V,1)='V'),CLIFOR->NOME_V,SPACE(50)),SPACE(50))",;
            "IF(aCODVEN=NIL .OR. (CLIFOR->CODVEN_V=aCODVEN .AND. LEFT(PEDIDO->CODIGO_V,1)='V'),DTOC(PEDIDO->DATEMI_V)+' '+PEDIDO->HORAEMI_V,'  /  /           ')",;
            "IF(aCODVEN=NIL .OR. (CLIFOR->CODVEN_V=aCODVEN .AND. LEFT(PEDIDO->CODIGO_V,1)='V'),PEDIDO->VALTOT_V,0)",;
            "IF(aCODVEN=NIL .OR. (CLIFOR->CODVEN_V=aCODVEN .AND. LEFT(PEDIDO->CODIGO_V,1)='V'),PEDIDO->VALMO_V,0)",;
            "IF(aCODVEN=NIL .OR. (CLIFOR->CODVEN_V=aCODVEN .AND. LEFT(PEDIDO->CODIGO_V,1)='V'),PEDIDO->FRETE_V,0)",;
            "IF(aCODVEN=NIL .OR. (CLIFOR->CODVEN_V=aCODVEN .AND. LEFT(PEDIDO->CODIGO_V,1)='V'),PEDIDO->VALTOT_V+PEDIDO->VALMO_V+PEDIDO->FRETE_V,0)",;
            "IF(aCODVEN=NIL .OR. (CLIFOR->CODVEN_V=aCODVEN .AND. LEFT(PEDIDO->CODIGO_V,1)='V'),PEDIDO->TIPO_V,' ')",;
            "IF(aCODVEN=NIL .OR. (CLIFOR->CODVEN_V=aCODVEN .AND. LEFT(PEDIDO->CODIGO_V,1)='V'),PEDIDO->DATBAI_V,CTOD('  /  /  '))",;
            "IF(aCODVEN=NIL .OR. (CLIFOR->CODVEN_V=aCODVEN .AND. LEFT(PEDIDO->CODIGO_V,1)='V'),PEDIDO->DATPAG_V,CTOD('  /  /  '))",;
