******* ESTOQUE
FUNCTION DBE_ESTOQUE(LIN,COL,LIN2,COL2)
LOCAL VARIAVEIS,MASCARAS,TITULOS,OLD,LINHA1,COLUNA,TELA
local tela2, nKey, getlist := {}, procura, procura2
MEMVAR CORTIT,CORTEX,M1,M2,S
OLD   :=SETCOLOR()
TELA  :=SAVESCREEN(0,0,24,80)
LINHA1:=CHR(220)
COLUNA:=CHR(219)
CLIFOR->(DBSETORDER(1))
M1:="@R 99,999.99"
M2:="@R 999,999.99"
S=SPACE(1)
VARIAVEIS:={"ESTOQUE->CODIGO_V","ESTOQUE->NOME_V","ESTOQUE->APLICA_V","ESTOQUE->MOEDA_V",;
            "TRANSFORM(ESTOQUE->VALVEN_V,M2)+S+TRANSFORM(ESTOQUE->VALMED_V,M2)+S+TRANSFORM(ESTOQUE->VALMAX_V,M2)+S+TRANSFORM(ESTOQUE->VALREV_V,M2)",;
            "ESTOQUE->FAMILIA_V","ESTOQUE->FABRICAN_V",;
            "TRANSFORM(ESTOQUE->QTD_V,M1)+S+TRANSFORM(ESTOQUE->RESERVA_V,M1)+S+TRANSFORM(ESTOQUE->QTD_V-ESTOQUE->RESERVA_V,M1)",;
            "IF(CLIFOR->(DBSEEK(ESTOQUE->CLIFOR_V)),CLIFOR->NOME_V,SPACE(50))",;
            "ESTOQUE->LOCALIZA_V"}
TITULOS  :={"C¢digo","Descri‡ao","Aplica‡ao","Moeda","Vlr.M¡nimo  Vlr.M‚dio Vlr.M ximo Vlr.Revenda","Fam¡lia","Fabricante","Qtd.em Estoque Reservado Qtd.Real",;
"Fornecedor","Localiza‡ao"}

WINDOW(LIN-1,COL-1,LIN2+1,COL2+1)
SETCOLOR(CORTIT)
@ LIN-1,COL SAY "Itens do Estoque"
@ LIN2+1,COL+1 SAY "Pressione Setas "+CHR(27)+CHR(18)+CHR(26)
SETCOLOR(CORTEX)
@ 24,0 CLEAR TO 24,80
@ 24,2 SAY "Busca por (C)odigo (N)ome (F)am¡lia C(o)d.Fabricante Or(d)em de C¢digo (A)lfab‚tica"
ESTOQUE->(DBSETORDER(2))
do while .t.
	ESTOQUE->(DBEDIT(LIN,COL,LIN2,COL2,VARIAVEIS,"S_TECLAS",,TITULOS,LINHA1,COLUNA))
	tela2 := savescreen()
	nKey := lastkey()
	DO CASE
     CASE NKEY==K_ESC .OR. NKEY==K_ENTER
        exit
     CASE NKEY=78 .OR. NKEY=110
        ESTOQUE->(DBSETORDER(2))
        SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
        @ 24,0 CLEAR TO 24,79
        PROCURA:=SPACE(LEN(ESTOQUE->NOME_V))
        SETCURSOR(1)
        @ 24,2 SAY "Nome :" GET PROCURA PICT "@K!"
        READ
        SETCURSOR(0)
        IF LASTKEY()#27
           ESTOQUE->(DBSEEK(PROCURA,.T.))
        ENDIF
     CASE NKEY=67 .OR. NKEY=99
        ESTOQUE->(DBSETORDER(1))
        PROCURA:=SPACE(LEN(ESTOQUE->CODIGO_V))
        @ 24,0 CLEAR TO 24,79
        SETCURSOR(1)
        @ 24,2 SAY "C¢digo :" GET PROCURA PICT "@K!"
        READ
        SETCURSOR(0)
        IF LASTKEY()#27
           ESTOQUE->(DBSEEK(PROCURA,.T.))
        ENDIF
     CASE NKEY=79 .OR. NKEY=111
        ESTOQUE->(DBSETORDER(6))
        PROCURA:=SPACE(LEN(ESTOQUE->CODIGO_V))
        @ 24,0 CLEAR TO 24,79
        SETCURSOR(1)
        @ 24,2 SAY "C¢digo :" GET PROCURA PICT "@K!"
        READ
        SETCURSOR(0)
        IF LASTKEY()#27
           ESTOQUE->(DBSEEK(PROCURA,.T.))
        ENDIF
     CASE NKEY=70 .OR. NKEY=102
        ESTOQUE->(DBSETORDER(4))
        PROCURA:=SPACE(LEN(ESTOQUE->FAMILIA_V))
        PROCURA2:=SPACE(LEN(ESTOQUE->FABRICAN_V))
        @ 24,0 CLEAR TO 24,79
        SETCURSOR(1)
        @ 24,2  SAY "Familia :" GET PROCURA PICT "@K!"
        @ 24,35 SAY "Fabricante :" GET PROCURA2 PICT "@K!"
        READ
        SETCURSOR(0)
        IF LASTKEY()#27
           IF ESTOQUE->(DBSEEK(PROCURA,.T.))
              DO WHILE TRIM(PROCURA)$ESTOQUE->FAMILIA_V
                 IF TRIM(PROCURA2)$ESTOQUE->FABRICAN_V
                    EXIT
                 ENDIF
                 ESTOQUE->(DBSKIP())
              ENDDO
           ENDIF
        ENDIF
     CASE NKEY=68 .OR. NKEY=100
        ESTOQUE->(DBSETORDER(1))
        KEYBOARD CHR(31)
     CASE NKEY=65 .OR. NKEY=97
        ESTOQUE->(DBSETORDER(2))
        KEYBOARD CHR(31)
  ENDCASE
  restscreen(,,,,tela2)
enddo
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(LIN-1,COL-1,LIN2+1,COL2+1)
SETCOLOR(OLD)
RETURN(.T.)


