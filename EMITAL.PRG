FUNCTION EMITAL()
LOCAL TELA,OP,GETLIST:={}

LOCAL INICIO,FIM
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN,TRABALHO
MEMVAR CODBAN
TELA:=SAVESCREEN(0,0,24,80)
SETCOLOR(CORTIT)
@ 11,8 SAY "Emissao de Talao"
WINDOW(12,8,16,45)
DBF_CHEQUE()
DBF_BANK()
INICIO:=0
FIM   :=0
CODBAN:=0
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 13,10 SAY "Banco          : " GET CODBAN PICT "99999" VALID(SEA_BANK(CODBAN,13,33).AND.CODBAN#0)
   CHEQUE->(DBSETORDER(2))
   @ 14,10 SAY "Cheque Inicial : " GET INICIO PICT "999999" VALID(!CHEQUE->(DBSEEK(STRZERO(INICIO,6,0))).AND.INICIO>0.OR.LASTKEY()=5)
   @ 15,10 SAY "Cheque Final   : " GET FIM    PICT "999999" VALID((!CHEQUE->(DBSEEK(STRZERO(FIM,6,0))).AND.INICIO>0.AND.FIM>=INICIO).OR.LASTKEY()=5)
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(18,20,"Confirma Inlcusao do Talao ?")
      DO WHILE INICIO<=FIM
         IF !CHEQUE->(DBSEEK(STRZERO(INICIO,6,0)))
            IF CHEQUE->(ADDREC(5))
               CHEQUE->CODBAN_V:=CODBAN
               CHEQUE->CHEQUE_V:=STRZERO(INICIO,6,0)
               CHEQUE->(DBUNLOCK())
            ENDIF  
         ENDIF
         INICIO++
      ENDDO
      EXIT
   ENDIF
ENDDO
CHEQUE->(DBCLOSEAREA())
BANK->(DBCLOSEAREA())
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(12,8,16,45)
RETURN(.T.)