FUNCTION BBANK()
LOCAL TELA,OP,GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN

***** VARIAVEIS PARA CADASTRO DE BANCOS
MEMVAR CODIGO,NOME,CONTA,AGENCIA,SALDO
TELA:=SAVESCREEN(0,0,24,80)
@ 10,10 PROMPT "CÂdigo  "
@ 11,10 PROMPT "Banco   "
@ 12,10 PROMPT "C/C     "
@ 13,10 PROMPT "Agncia "
MENU TO OP
RESTSCREEN(0,0,24,80,TELA)
DO CASE
   CASE OP=1
      BANK->(DBSETORDER(1))
      @ 10,20 GET CODIGO PICT "99999"
      READ
      BANK->(DBSEEK(CODIGO))
   CASE OP=2
      BANK->(DBSETORDER(2))
      @ 11,20 GET NOME PICT "@K!"
      READ
      BANK->(DBSEEK(NOME,.T.))
   CASE OP=3
      BANK->(DBSETORDER(3))
      @ 12,20 GET CONTA PICT "@K!"
      READ
      BANK->(DBSEEK(CONTA))
   CASE OP=4
      BANK->(DBSETORDER(4))
      @ 13,20 GET AGENCIA PICT "@K!"
      READ
      BANK->(DBSEEK(AGENCIA))
   OTHERWISE
      RETURN(.T.)
ENDCASE
DBE_BANK(10,5,20,75)
RETURN(.T.)