FUNCTION ATECNICA()
LOCAL  GETLIST:={},CODIGO2,TELA,TELA2
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN
MEMVAR FICHA,RECEBE,CLIFOR,DATENT,ITEM,ORCAMENT,DATORC
MEMVAR DATAPR,DATEXE,DATEXE2,DATSAI,MECVEN,GARANTIA,VALMO,VALITOT,NOTA
MEMVAR MARCA,MODELO,COR,ANO,NSERIE,TANQUE,AVAR1,AVAR2,AVAR3,SOLICLI1,SOLICLI2,SOLICLI3
MEMVAR ORIENT1,ORIENT2,ORIENT3,PLACA,VALOUTRO,VALTERC,SERV,TIPOKM,QTDKM
CODIGO2:=FICHA
DO WHILE .T.
   @ 01,15 GET FICHA PICT "99999" VALID(FICHA=CODIGO2 .OR. ! EMPTY(FICHA) .AND. !TECNICA->(DBSEEK(FICHA)))
   @ 01,21 SAY "Garantia :" GET GARANTIA PICT "@K!"
   IF ! EMPTY(DATORC)
      TELA:=SAVESCREEN()
      WINDOW(10,10,13,64)
      @ 11,12 SAY "Cuidado ao alterar o cliente, pois o or‡amento est "
      @ 12,12 SAY "registrado com os impostos do estado de "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->ESTADO_V,SPACE(2))
      IF ! CONFIRMA(20,20,"Continua ?")
         EXIT
      ENDIF
      RESTSCREEN(,,,,TELA)
      CLOSEWIN(10,10,13,64)
   ENDIF
   @ 05,01 CLEAR TO 05,78
   @ 05,02 SAY "Cliente    :" GET CLIFOR VALID(LASTKEY()=5 .OR. SEA_CLIFOR(CLIFOR,5,22,"C") .AND. TECFUN())
   @ 13,02 SAY "Fazer Or‡amento ?" GET ORCAMENT PICT "@!" VALID(ORCAMENT$"SN")
   @ 14,16 GET SERV VALID(SEA_SERV(SERV,14,20))
   IF ! EMPTY(TECNICA->MECVEN_V)
      @ 14,50 GET MECVEN VALID(!EMPTY(MECVEN).AND.SEA_MECVEN(MECVEN,14,57,"M"))
   ENDIF
   @ 15,16 GET VALMO PICT "@R 999,999,999.99" VALID(VALMO>=0 .AND. TECCALC())
   VALITOT:=TECNICA->VALITOT_V
   @ 15,50 GET VALITOT PICT "@R 999,999,999.99"
   @ 16,16 GET VALTERC PICT "@R 999,999,999.99" VALID(VALTERC>=0.AND. TECCALC())
   @ 16,50 GET VALOUTRO PICT "@R 999,999,999.99" VALID(TECCALC())
   @ 20,17 GET DATENT VALID(!EMPTY(DATENT))
//   IF ! EMPTY(TECNICA->DATORC_V)
      @ 20,43 GET DATORC // VALID(!EMPTY(DATORC))
//   ENDIF
   IF ! EMPTY(TECNICA->DATAPR_V)
      @ 20,68 GET DATAPR VALID(!EMPTY(DATAPR))
   ENDIF
   IF ! EMPTY(TECNICA->DATEXE_V)
      @ 21,17 GET DATEXE VALID(!EMPTY(DATEXE))
   ENDIF
   IF ! EMPTY(TECNICA->DATEXE2_V)
      @ 21,43 GET DATEXE2 VALID(!EMPTY(DATEXE2))
   ENDIF
   IF ! EMPTY(TECNICA->DATSAI_V)
      @ 21,68 GET DATSAI VALID(!EMPTY(DATSAI))
   ENDIF
   READ
   IF LASTKEY()=27
      @ 01,45 CLEAR TO 01,78
      EXIT
   ENDIF
   TELA2:=SAVESCREEN()
   DO WHILE .T.
      @ 01,01 CLEAR TO 21,78
      @ 01,01 SAY PADC("Descri‡ao do Servi‡o … Executar",78) COLOR CORTIT
      @ 02,01 TO 02,78
      @ 03,02 SAY "Servi‡o para :" GET ITEM PICT "@S20K!"
      @ 03,43 SAY "Marca :" GET MARCA PICT "@K!"
      @ 04,02 SAY "Modelo       :" GET MODELO PICT "@K!" 
      @ 04,45 SAY "Ano :" GET ANO PICT "@K!"
      @ 05,02 SAY "Cor          :" GET COR PICT "@K!"
      IF CONFIG->KMSERIE_V="S"
         @ 05,39 SAY "N§. S‚rie :" GET NSERIE PICT "@K!"
      ELSE
        @ 05,43 SAY "Km-Ml :" GET TIPOKM PICT "@K!" VALID(TIPOKM$"KM")
        @ 05,53 GET QTDKM PICT "@R 999999.9"
      ENDIF
      @ 06,02 SAY "Placa/Patrim.:" GET PLACA PICT "@K!"
      @ 06,42 SAY "Tanque :" GET TANQUE VALID(FUEL2(TANQUE))
      @ 07,01 TO 07,78
      @ 08,01 SAY PADC("Avarias / Observa‡oes",78) COLOR CORTIT
      @ 09,02 GET AVAR1
      @ 10,02 GET AVAR2
      @ 11,02 GET AVAR3
      @ 12,01 TO 12,78
      @ 13,01 SAY PADC("Servi‡os Solicitados pelo Cliente",78) COLOR CORTIT
      @ 14,02 GET SOLICLI1
      @ 15,02 GET SOLICLI2
      @ 16,02 GET SOLICLI3
      @ 17,01 TO 17,78
      @ 18,01 SAY PADC("Orienta‡ao ao Mecƒnico / Servi‡os … Executar",78) COLOR CORTIT
      @ 19,02 GET ORIENT1
      @ 20,02 GET ORIENT2
      @ 21,02 GET ORIENT3
      READ
      IF LASTKEY()=27
         EXIT
      ENDIF
      EXIT
   ENDDO
   RESTSCREEN(,,,,TELA2)
   IF LASTKEY()=27
      LOOP
   ENDIF
   IF CONFIRMA(20,20,"Confirma todos os dados ?")
      IF TECNICA->(RECLOCK())
         TECNICA->VALITOT_V :=VALITOT
         TECNICA->CODIGO_V  :=FICHA
         TECNICA->GARANTIA_V:=GARANTIA
         TECNICA->CLIFOR_V  :=CLIFOR
         TECNICA->ITEM_V    :=ITEM
         TECNICA->ORCAMENT_V:=ORCAMENT
         TECNICA->MECVEN_V  :=MECVEN
         TECNICA->SERV_V    :=SERV
         TECNICA->VALMO_V   :=VALMO
         TECNICA->VALTERC_V :=VALTERC
         TECNICA->VALOUTRO_V:=VALOUTRO
         TECNICA->DATENT_V  :=DATENT
         TECNICA->DATORC_V  :=DATORC
         TECNICA->DATAPR_V  :=DATAPR
         TECNICA->DATEXE_V  :=DATEXE
         TECNICA->DATEXE2_V :=DATEXE2
         TECNICA->DATSAI_V  :=DATSAI
         TECNICA->MARCA_V   :=MARCA
         TECNICA->MODELO_V  :=MODELO
         TECNICA->NSERIE_V  :=NSERIE
         TECNICA->TIPOKM_V  :=TIPOKM
         TECNICA->QTDKM_V   :=QTDKM
         TECNICA->ANO_V     :=ANO
         TECNICA->COR_V     :=COR
         TECNICA->TANQUE_V  :=TANQUE
         TECNICA->PLACA_V   :=PLACA
         TECNICA->AVAR1_V   :=AVAR1
         TECNICA->AVAR2_V   :=AVAR2
         TECNICA->AVAR3_V   :=AVAR3
         TECNICA->SOLICLI1_V:=SOLICLI1
         TECNICA->SOLICLI2_V:=SOLICLI2
         TECNICA->SOLICLI3_V:=SOLICLI3
         TECNICA->ORIENT1_V :=ORIENT1
         TECNICA->ORIENT2_V :=ORIENT2
         TECNICA->ORIENT3_V :=ORIENT3
         TECNICA->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
ENDDO
RETURN(.T.)