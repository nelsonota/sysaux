FUNCTION MECVEN(OPCAO)
LOCAL OP,TELA
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO

*** VARIAVEIS PARA CADASTRO DE MECANICOS/VENDEDORES
MEMVAR CODIGO,NOME,ENDERECO,BAIRRO,CIDADE,ESTADO,CEP,FONE1,FONE2,FAX
MEMVAR MECVEN,CGCCPF,RGINSEST,CONTATO,CALCULA,PERCENT,ALLCLI, NUMERO, COMPLEM
TELA:=SAVESCREEN(0,0,24,80)
WINDOW(13,0,15,35)
WINDOW(3,0,13,79)
@ 14,35 SAY CHR(219)
DBF_MECVEN()
DBF_CONFIG()
dbf_cadcid()
SETCOLOR(CORTIT)
DO CASE
   CASE OPCAO="M"
      @ 2,0 SAY "Tecnicos"
      MECVEN:="M"
   CASE OPCAO="V"
      @ 2,0 SAY "Vendedores"
      MECVEN:="V"
ENDCASE
CODIGO:=MECVEN
MECVEN->(DBSEEK(CODIGO,.T.))
DO WHILE .T.
   CODIGO  :=MECVEN->CODIGO_V
   NOME    :=MECVEN->NOME_V
   CGCCPF  :=MECVEN->CGCCPF_V
   RGINSEST:=MECVEN->RGINSEST_V
   ENDERECO:=MECVEN->ENDERECO_V
   NUMERO  :=MECVEN->NUMERO_V
   COMPLEM :=MECVEN->COMPLEM_V
   BAIRRO  :=MECVEN->BAIRRO_V
   CIDADE  :=MECVEN->CIDADE_V
   ESTADO  :=MECVEN->ESTADO_V
   CEP     :=MECVEN->CEP_V
   FONE1   :=MECVEN->FONE1_V
   FONE2   :=MECVEN->FONE2_V
   FAX     :=MECVEN->FAX_V
   CALCULA :=MECVEN->CALCULA_V
   PERCENT :=MECVEN->PERCENT_V
   CONTATO :=MECVEN->CONTATO_V
   ALLCLI  :=MECVEN->ALLCLI_V
   SETCOLOR(CORTEX)
   @ 04,02 SAY "Registrado por : "+MECVEN->NOMSEN_V
   @ 05,02 SAY "C˘digo   : " + CODIGO
   IF OPCAO="V"
      @ 05,20 SAY "Mostrar todos os clientes : "+ALLCLI
   ENDIF
   @ 06,02 SAY "Nome     : " + NOME
   @ 07,02 SAY "Endereco : " + LEFT(ENDERECO,35)
   @ 07,49 SAY "N.: " + NUMERO
   @ 07,60 say "Compl.: " + COMPLEM
   @ 08,02 SAY "Bairro   : " + BAIRRO
   @ 09,02 SAY "Cidade   : " + CIDADE
   @ 09,45 SAY "Estado : "   + ESTADO
   @ 09,57 SAY "C.E.P.: "    + TRANSFORM(CEP,"@R 99999-999")
   @ 10,02 SAY "CGC / CPF: " + CGCCPF
   @ 10,32 SAY "RG/I.Est.: " + RGINSEST
   @ 11,02 SAY "Fone1    : " + TRANSFORM(FONE1,"@R (#999) ##99-9999")
   @ 11,30 SAY "Fone2: " + TRANSFORM(FONE2,"@R (#999) ##99-9999")
   @ 11,54 SAY "Fax: "       + TRANSFORM(FAX,"@R (#999) ##99-9999")
   @ 12,02 SAY "Contato  : " + CONTATO
   SETCOLOR(CORTEX+","+CORBAR)
   @ 14,1  PROMPT " Incluir "
   @ 14,10 PROMPT " Buscar "
   @ 14,18 PROMPT " Alterar "
   @ 14,27 PROMPT " Apagar "
   MENU TO OP
   DO CASE
      CASE OP=1
         IMECVEN(OPCAO)
      CASE OP=2
         BMECVEN(OPCAO)
      CASE OP=3
         AMECVEN(OPCAO)
      CASE OP=4
         EMECVEN(OPCAO)
      OTHERWISE
         EXIT
   ENDCASE
ENDDO
MECVEN->(DBCLOSEAREA())
CONFIG->(DBCLOSEAREA())
cadcid->(dbclosearea())
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(3,0,16,79)
RETURN(.T.)