FUNCTION RESALBAN()
LOCAL  X,LIN,LIN2,VALCHQ,TELA,TSALDO,TVALCHQ,TREAL,TAPLICA,TBLOQUEIO
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR LINHA
TELA:=SAVESCREEN(0,0,24,80)
LINHA:={}
TSALDO:=0
TAPLICA:=0
TBLOQUEIO:=0
TVALCHQ:=0
TREAL:=0
X:=1
LIN2:=12
LIN:=8
DBF_CONFIG()
DBF_BANK()
DBF_CHEQUE()
BANK->(DBGOTOP())
DO WHILE BANK->(! EOF()) .AND. LIN2<=24
   LIN2++
   BANK->(DBSKIP())
ENDDO
WINDOW(5,0,LIN2,79)
BANK->(DBGOTOP())
SETCOLOR(CORTIT)
@ 6,1 SAY PADR(" Banco      Saldo Real   Saldo Banco  Compensa‡ao  Bloqueado    Aplicado",78)
SETCOLOR(CORTEX)
@ 7,1 TO 7,78
DO WHILE BANK->(!EOF()) .AND. LIN<=21
   CHEQUE->(DBSEEK(BANK->CODIGO_V))
   VALCHQ:=0
   DO WHILE CHEQUE->(!EOF()) .AND. CHEQUE->CODBAN_V=BANK->CODIGO_V
      IF EMPTY(CHEQUE->DATBAI_V) .AND. UPPER(CHEQUE->OBS_V)#"CANCELADO"
         VALCHQ:=VALCHQ+CHEQUE->VALOR_V
      ENDIF
      CHEQUE->(DBSKIP())
   ENDDO
   @ LIN,2  SAY BANK->NOME_V
   @ LIN,13 SAY BANK->SALDO_V-VALCHQ+BANK->BLOQUEIO_V PICT "9,999,999.99"
   @ LIN,26 SAY BANK->SALDO_V PICT "9,999,999.99"
   @ LIN,39 SAY VALCHQ PICT "9,999,999.99"
   @ LIN,52 SAY BANK->BLOQUEIO_V PICT "9,999,999.99"
   @ LIN,65 SAY BANK->APLICA_V PICT "9,999,999.99"
   IF EMPTY(BANK->NOBANK_V)
      TBLOQUEIO:=TBLOQUEIO+BANK->BLOQUEIO_V
      TSALDO:=TSALDO+BANK->SALDO_V
      TVALCHQ:=TVALCHQ+VALCHQ
      TAPLICA:=TAPLICA+BANK->APLICA_V
      TREAL:=TREAL+(BANK->SALDO_V-VALCHQ+BANK->BLOQUEIO_V)
   ENDIF
   BANK->(DBSKIP())
   LIN++
   IF X=1
      SETCOLOR(CORTIT)
      X=0
   ELSE
      SETCOLOR(CORTEX)
      X=1
   ENDIF
ENDDO
SETCOLOR(CORTEX)
@ LIN,1 TO LIN,78
LIN++
SETCOLOR(CORTIT)
@ LIN,2  SAY "Total    :"
@ LIN,13 SAY TREAL     PICT "9,999,999.99"
@ LIN,26 SAY TSALDO    PICT "9,999,999.99"
@ LIN,39 SAY TVALCHQ   PICT "9,999,999.99"
@ LIN,52 SAY TBLOQUEIO PICT "9,999,999.99"
@ LIN,65 SAY TAPLICA   PICT "9,999,999.99"
LIN++
SETCOLOR(CORTEX)
@ LIN,1 TO LIN,78
LIN++
@ LIN,2  SAY "Geral    : "+TRANSFORM(TREAL+TAPLICA,"@R 9,999,999.99")
INKEY(0)
CONFIG->(DBCLOSEAREA())
BANK->(DBCLOSEAREA())
CHEQUE->(DBCLOSEAREA())
RESTSCREEN(0,0,24,80,TELA)
RETURN(.T.)