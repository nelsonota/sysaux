FUNCTION IPLANO()
LOCAL OP,GETLIST:={},TELA,TIPO
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN

****** VARIAVEIS P/ CADASTRO DE PLANO DE CONTAS
MEMVAR CODIGO,NOME
CODIGO:=SPACE(3)
DO WHILE .T.
   TELA :=SAVESCREEN(0,0,24,80)
   @ 15,21 PROMPT "[+]"
   @ 15,25 PROMPT "[-]"
   @ 15,29 PROMPT "[=]"
   MENU TO OP
   DO CASE
      CASE OP=1
         TIPO="+"
      CASE OP=2
         TIPO="-"
      CASE OP=3
         TIPO="="
      OTHERWISE
         RESTSCREEN(0,0,24,80,TELA)
         RETURN(.F.)
   ENDCASE
   RESTSCREEN(0,0,24,80,TELA)
   TELA:=SAVESCREEN(0,0,24,80)
   @ 15,21 SAY TIPO
   @ 15,22 GET CODIGO VALID(!PLANO->(DBSEEK(TIPO+CODIGO)))
   @ 16,21 GET NOME PICT "@K!"
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   CODIGO:=TIPO+CODIGO
   IF CONFIRMA(20,20,"Confirma Inclusao do Plano de Conta ?")
      IF PLANO->(ADDREC(5))
         PLANO->CODIGO_V:=CODIGO
         PLANO->NOME_V  :=NOME
         PLANO->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
   @ 15,21 CLEAR TO 16,42
ENDDO
RETURN(.T.)