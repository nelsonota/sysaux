FUNCTION DIRETOV()
LOCAL  TELA,TELA2,X
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN
MEMVAR BLQVEN,SYSVEN
*** VARIAVEIS DO MODULO COMPRA/VENDA DIRETO
MEMVAR PEDIDO,CLIFOR,ICODIGO,VALOR,QTD,GETLIST,COMI
MEMVAR ITEM,T_VALUNI,T_QTD,TOTAL,CONT,MECVEN
MEMVAR MODULO
MODULO:="diretov"
TELA:=SAVESCREEN()
DBF_CONFIG()
DBF_PEDIDO()
DBF_2PEDIDO()
DBF_ESTOQUE()
DBF_MECVEN()
DBF_BASCAL()
DBF_CLIFOR()
DBF_MOEDA()
DBF_SYSTEM()
WINDOW(0,0,24,79)
@ 00,01 SAY "Venda Direta" COLOR CORTIT
CONT    :=.F.
CLIFOR  :=SPACE(LEN(PEDIDO->CLIFOR_V))
MECVEN  :=IF(BLQVEN="N",SPACE(LEN(PEDIDO->MECVEN_V)),SYSVEN)
ITEM    :=SPACE(LEN(ESTOQUE->CODIGO_V))
X       :=0
T_QTD   :=0
T_VALUNI:=0
TOTAL   :=0
ICODIGO  :={}
VALOR   :={}
QTD     :={}
COMI    :={}
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   PEDIDO:="V"+STRZERO(CONFIG->PEDVEN_V+1,5,0)
   @ 01,02 SAY "Venda               : "+PEDIDO
   IF BLQVEN<>"S"
      DO WHILE .T.
         MECVEN->(DBSEEK("V"))
         DBE_MECVEN(5,10,15,70)
         IF LEFT(MECVEN->CODIGO_V,1)="V" .OR. LASTKEY()=27
            MECVEN:=MECVEN->CODIGO_V
            EXIT
         ENDIF
         AVISO("É necessĀrio que seja selecionado um vendedor...")
      ENDDO
   ENDIF
   IF LASTKEY()=27
      EXIT
   ENDIF
   @ 01,32 SAY "Vendedor        : " + LEFT(MECVEN->NOME_V,28)
   CONT:=.T.
   EXIT
ENDDO
IF CONT=.T.
   SETCOLOR(CORDES)
   @ 05,02 CLEAR TO 21,13
   @ 05,15 CLEAR TO 21,45
   @ 05,47 CLEAR TO 21,55
   @ 05,57 CLEAR TO 21,64
   @ 05,66 CLEAR TO 21,77
ENDIF
DO WHILE CONT=.T. 
   SETCOLOR(CORDES)
   @ 05,02 CLEAR TO 05,13
   @ 05,15 CLEAR TO 05,45
   @ 05,47 CLEAR TO 05,55
   @ 05,57 CLEAR TO 05,64
   @ 05,66 CLEAR TO 05,77
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 3,1 TO 3,78
   @ 22,1 TO 22,78
   @ 04,01 SAY PADR(" Código       Descrićao                       Vl.Unit.  Qtd.     Vl.Total",78) COLOR CORTIT
   @ 23,01 SAY PADL("Valor Total dos Itens : "+TRANSFORM(TOTAL,"@R 999,999,999.99")+" ",78) COLOR CORTIT
   @ 24,02 SAY "ESC - Cancela Operaćao   F2 - Finaliza"
   @ 05,02 GET ITEM PICT "@K!" VALID(SEA_ESTOQUE(ITEM).AND.DIRETOV1())
   @ 05,47 GET T_VALUNI PICT "@R 99,999.99" VALID(LASTKEY()=5 .OR. T_VALUNI>0 .AND. PRECOVALID(T_VALUNI) .AND. DIRETOV2())
   @ 05,57 GET T_QTD    PICT "@R 9,999.99" VALID(LASTKEY()=5 .OR. T_QTD>0 .AND. DIRETOV2() .AND. AVISOEST("VT",T_QTD))
   READ
   IF LASTKEY()=27
      IF CONFIRMA(20,20,"Deseja realmente cancelar a operaćao ?")
         EXIT
      ELSE
         LOOP
      ENDIF
   ENDIF
   IF LASTKEY()=18 .OR. LASTKEY()=3
      LOOP
   ENDIF
   IF CONT=.F.
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Confirma este Item ?")
      X:=X+1
      AADD(ICODIGO,ITEM)
      AADD(QTD,T_QTD)
      AADD(VALOR,T_VALUNI)
      TOTAL:=TOTAL+(T_QTD*T_VALUNI)
      SET KEY -1 TO FIMDIRETOV()
      TELA2:=SAVESCREEN(5,1,20,79)
      RESTSCREEN(6,1,21,79,TELA2)
      IF X>=CONFIG->QTDITENS_V
         AVISO(TRIM(STR(CONFIG->QTDITENS_V))+" é o nŻmero mĀximo de itens para sua Nota Fiscal...")
         IF CONFIRMA(20,20,"Finaliza a Venda ?")
            FIMDIRETOV()
         ENDIF
      ENDIF
   ENDIF
   ITEM    :=SPACE(LEN(ESTOQUE->CODIGO_V))
   T_QTD   :=0
   T_VALUNI:=0
ENDDO
CONFIG->(DBCLOSEAREA())
PEDIDO->(DBCLOSEAREA())
PEDIDO2->(DBCLOSEAREA())
ESTOQUE->(DBCLOSEAREA())
CLIFOR->(DBCLOSEAREA())
MECVEN->(DBCLOSEAREA())
MOEDA->(DBCLOSEAREA())
BASCAL->(DBCLOSEAREA())
SYSTEM->(DBCLOSEAREA())
RESTSCREEN(,,,,TELA)
SET KEY -1 TO
CLOSEWIN(0,0,24,79)
RETURN(.T.)

FUNCTION FIMDIRETOV()
LOCAL  X,TELA,TELA2,TELA3,PARC,INTER,TOTPAR,ENT,ENT2,COL,MDATE,VALPAR,DOCEXT
LOCAL  PAGREC,VALMO,LINSERV1,LINSERV2,LINSERV3,LINSERV4,REGISTRAR
LOCAL  VALCUS,VALMIN,VALMED,VALMAX
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN
MEMVAR PEDIDO,CLIFOR,ICODIGO,VALOR,QTD,ICMS,GETLIST,T,O_SIGLA
MEMVAR ITEM,T_VALUNI,T_QTD,TOTAL,CONT,MECVEN
MEMVAR CODPLA
CLEAR GETS
SET KEY -1 TO
TELA:=SAVESCREEN()
TELA3:=SAVESCREEN(6,1,17,78)
RESTSCREEN(10,1,21,78,TELA3)
VALMO :=0
LINSERV1:=SPACE(LEN(PEDIDO->LINSERV1_V))
LINSERV2:=SPACE(LEN(PEDIDO->LINSERV2_V))
LINSERV3:=SPACE(LEN(PEDIDO->LINSERV3_V))
LINSERV4:=SPACE(LEN(PEDIDO->LINSERV4_V))
MOEDA->(DBCLOSEAREA())
DBF_PAGREC()
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 03,01 CLEAR TO 08,78
   @ 9,1 TO 9,78
   CLIFOR->(DBSETORDER(2))
   CLIFOR->(DBSEEK("CONSUMIDOR",.T.))
   DO WHILE .T.
      SET KEY -2 TO T_CLIFOR()
      DBE_CLIFOR(5,10,15,70,MECVEN)
      SET KEY -2 TO
      IF LASTKEY()=27
         RESTSCREEN(,,,,TELA)
         SET KEY -1 TO FIMDIRETOV()
         DBF_MOEDA()
         PAGREC->(DBCLOSEAREA())
         RETURN(.F.)
      ENDIF
      IF LEFT(CLIFOR->CODIGO_V,1)="F"
         AVISO("É necessĀrio que seja selecionado um cliente...")
         LOOP
      ELSE
         IF MECVEN->ALLCLI_V<>"S" .AND. CLIFOR->CODVEN_V<>MECVEN
            AVISO("Este cliente nao pertence ao vendedor selecionado.")
            RETURN(.F.)
         ENDIF
      ENDIF
      CLIFOR:=CLIFOR->CODIGO_V
      EXIT
   ENDDO
   @ 03,02 SAY "Cliente    : "+CLIFOR->NOME_V
   CLIFOR->(DBSETORDER(1))
   @ 4,2  SAY "Endereco   : "+IF(CLIFOR->(DBSEEK(CLIFOR)),alltrim(CLIFOR->ENDERECO_V)+" "+alltrim(clifor->numero_v)+" "+alltrim(clifor->complem_v),SPACE(50))
   @ 5,2  SAY "Bairro     : "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->BAIRRO_V,SPACE(30))
   @ 5,45 SAY "C.E.P. : "+ IF(CLIFOR->(DBSEEK(CLIFOR)),TRANSFORM(CLIFOR->CEP_V,"99999-9"),SPACE(9))
   @ 6,2  SAY "Cidade     : "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->CIDADE_V,SPACE(30))
   @ 6,45 SAY "Estado : "+ IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->ESTADO_V,SPACE(2))
   @ 7,2  SAY "Telefone   : "+IF(CLIFOR->(DBSEEK(CLIFOR)),TRANSFORM(CLIFOR->FONE1_V,"@R (#999) 9999-9999"),SPACE(15))
   @ 7,45 SAY "CGC/CPF: "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->CGCCPF_V,SPACE(18))
   @ 8,2  SAY "RG/Ins.Est.: "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->RGINSEST_V,SPACE(15))
   IF ! EMPTY(CLIFOR->BLACK_V)
      AVISO("Este Cliente estĀ Cadastrado na Lista Negra ...")
      IF CONFIRMA(20,20,"Deseja Visualizar o Texto ?")
         TELA2:=SAVESCREEN()
         SETCOLOR(CORTIT)
         @ 8,5 SAY "Lista Negra"
         WINDOW(9,5,16,75)
         SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
         MEMOEDIT(CLIFOR->BLACK_V,10,6,15,74,.F.)
         RESTSCREEN(,,,,TELA2)
         CLOSEWIN(9,0,21,79)
      ENDIF
      IF ! CONFIRMA(20,20,"Continua Operaćao ?")
         CONT:=.F.
         TELA:=RESTSCREEN(,,,,TELA)
         SET KEY -1 TO FIMDIRETOV()
         DBF_MOEDA()
         PAGREC->(DBCLOSEAREA())
         RETURN(.F.)
      ENDIF
   ENDIF
   IF ! VERIFIMP(ICODIGO,CLIFOR->ESTADO_V)
      CONT:=.F.
      TELA:=RESTSCREEN(,,,,TELA)
      SET KEY -1 TO FIMDIRETOV()
      DBF_MOEDA()
      PAGREC->(DBCLOSEAREA())
      RETURN(.F.)
   ENDIF
   @ 10,1 CLEAR TO 21,78
   @ 09,1 TO 09,78 
   @ 15,1 TO 15,78
   DBF_PLANO()
   CODPLA:=SPACE(LEN(PLANO->CODIGO_V))
   DO WHILE .T.
      @ 10,2 SAY "Mao de Obra :" GET VALMO PICT "@R 999,999.99"
      @ 11,2 GET LINSERV1 PICT "@!"
      @ 12,2 GET LINSERV2 PICT "@!"
      @ 13,2 GET LINSERV3 PICT "@!"
      @ 14,2 GET LINSERV4 PICT "@!"
      @ 16,1 SAY PADC("Faturamento",78) COLOR CORTIT
      @ 17,02 SAY "Plano de Conta :" GET CODPLA VALID(SEA_CODPLA(CODPLA,17,24,"+"))
      PARC:=0
      INTER:=0
      ENT:=SPACE(1)
      @ 18,2  SAY "Parcelas   :" GET PARC PICT "9" VALID(PARC>0 .AND. PARC<=5)
      @ 18,18 SAY "Intervalo de Dias :" GET INTER PICT "99" VALID(IF(PARC>1,INTER>0,INTER>=0))
      @ 18,43 SAY "1” Parc. ģ Vista ? :" GET ENT PICT "@!" VALID(LASTKEY()=5 .OR. ENT$"SN")
      @ 19,02 SAY "Vencimento         :"
      @ 20,02 SAY "Valor da Parcela   :"
      @ 21,02 SAY "Doc.Ext.da Parcela :"
      READ
      IF LASTKEY()=27
         EXIT
      ENDIF
      X:=1
      ENT2:=ENT
      TOTPAR:=0
      MDATE:={,,,,,}
      VALPAR:={,,,,,}
      DOCEXT:={,,,,,}
      DO WHILE X<=PARC
         IF ENT2="S"
            MDATE[X]=DATE()
            ENT2:="N"
         ELSE
            IF X>1
               MDATE[X]=MDATE[X-1]+INTER
            ELSE
               MDATE[X]=DATE()+INTER
            ENDIF
         ENDIF
         X++
      ENDDO
      X:=1
      COL:=23
      SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
      DO WHILE .T.
         IF MDATE[X]=(NIL)
            EXIT
         ENDIF
         VALPAR[X]:=ROUND((TOTAL+VALMO)/PARC,2)
         DOCEXT[X]:=SPACE(LEN(PAGREC->DOCEXT_V))
         @ 19,COL GET MDATE[X]
         @ 20,COL GET VALPAR[X] PICT "@R 999,999.99"
         @ 21,COL GET DOCEXT[X]
         READ
         IF LASTKEY()=27
            @ 20,1 CLEAR TO 21,78
            EXIT
         ENDIF
         TOTPAR:=TOTPAR+VALPAR[X]
         X++
         COL=COL+11
      ENDDO
      IF LASTKEY()=27
         LOOP
      ENDIF
      IF ROUND(TOTPAR,2)#ROUND(TOTAL+VALMO,2) .AND. TOTAL+VALMO#TOTPAR
         AVISO("O Valor Total das Parcelas nao Conferem com o Valor Total do Pedido ...")
         LOOP
      ENDIF
      IF ! CONFIRMA(20,20,"Todos os dados estao corretos ?")
         LOOP
      ENDIF
      IF CONFIG->AUTVEN_V="P"
         IF CONFIRMA(20,20,"Registrar Contas Futuras ?")
            REGISTRAR:="S"
         ELSE
            REGISTRAR:="N"
         ENDIF
      ELSE
         REGISTRAR:=CONFIG->AUTVEN_V
      ENDIF
      EXIT
   ENDDO
   PLANO->(DBCLOSEAREA())
   IF LASTKEY()=27
      LOOP
   ENDIF
   EXIT
ENDDO
AADD(ICODIGO,)
X:=1
CONT:=.F.
IF PEDIDO->(ADDREC())
   DO WHILE .NOT. CONFIG->(RECLOCK())
   ENDDO
   CONFIG->PEDVEN_V:=CONFIG->PEDVEN_V+1
   PEDIDO:="V"+STRZERO(CONFIG->PEDVEN_V,5,0)
   CONFIG->(DBCOMMIT(),DBUNLOCK())
   PEDIDO->CODIGO_V:=PEDIDO
   PEDIDO->CLIFOR_V:=CLIFOR
   PEDIDO->MECVEN_V:=MECVEN
   PEDIDO->CLIFOR_V  :=CLIFOR
   PEDIDO->DATEMI_V  :=DATE()
   PEDIDO->DATBAI_V  :=DATE()
   PEDIDO->VALTOT_V  :=TOTAL
   PEDIDO->VALMO_V   :=VALMO
   PEDIDO->LINSERV1_V:=LINSERV1
   PEDIDO->LINSERV2_V:=LINSERV2
   PEDIDO->LINSERV3_V:=LINSERV3
   PEDIDO->LINSERV4_V:=LINSERV4
   PEDIDO->TIPO_V    :="D"
   PEDIDO->NOMSEN_V  :=NOMSEN
   PEDIDO->MECVEN_V:=MECVEN
   IF MDATE[1]#(NIL)
      PEDIDO->DATPAG_V:=MDATE[1]
      PEDIDO->VALPAR_V:=VALPAR[1]
      PEDIDO->DOCEXT_V:=DOCEXT[1]
      IF REGISTRAR="S"
         PAGREC->(ADDREC(5))
         CONFIG->(RECLOCK())
         PAGREC:="R"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PEDIDO->PAGREC_V:=PAGREC
         PAGREC->CODIGO_V:=PAGREC
         PAGREC->CLIFOR_V:=CLIFOR
         PAGREC->CODPLA_V:=CODPLA
         PAGREC->PEDIDO_V:=PEDIDO
         PAGREC->VALOR_V :=VALPAR[1]
         PAGREC->DATVEN_V:=MDATE[1]
         PAGREC->DOCEXT_V:=DOCEXT[1]
         PAGREC->DATEXT_V :=DATE()
         PAGREC->DESC_V  :="Venda Direta "+PEDIDO
         PAGREC->(DBUNLOCK())
      ENDIF
   ENDIF
   IF MDATE[2]#(NIL)
      PEDIDO->DATPAG1_V:=MDATE[2]
      PEDIDO->VALPAR1_V:=VALPAR[2]
      PEDIDO->DOCEXT1_V:=DOCEXT[2]
      IF REGISTRAR="S"
         PAGREC->(ADDREC(5))
         CONFIG->(RECLOCK())
         PAGREC:="R"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PEDIDO->PAGREC1_V:=PAGREC
         PAGREC->CODIGO_V :=PAGREC
         PAGREC->CLIFOR_V :=CLIFOR
         PAGREC->CODPLA_V :=CODPLA
         PAGREC->PEDIDO_V :=PEDIDO
         PAGREC->VALOR_V  :=VALPAR[2]
         PAGREC->DATVEN_V :=MDATE[2]
         PAGREC->DOCEXT_V :=DOCEXT[2]
         PAGREC->DATEXT_V :=DATE()
         PAGREC->DESC_V   :="Venda Direta "+PEDIDO
         PAGREC->(DBUNLOCK())
      ENDIF
   ENDIF
   IF MDATE[3]#(NIL)
      PEDIDO->DATPAG2_V:=MDATE[3]
      PEDIDO->VALPAR2_V:=VALPAR[3]
      PEDIDO->DOCEXT2_V:=DOCEXT[3]
      IF REGISTRAR="S"
         PAGREC->(ADDREC(5))
         CONFIG->(RECLOCK())
         PAGREC:="R"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PEDIDO->PAGREC2_V:=PAGREC
         PAGREC->CODIGO_V :=PAGREC
         PAGREC->CLIFOR_V :=CLIFOR
         PAGREC->CODPLA_V :=CODPLA
         PAGREC->PEDIDO_V :=PEDIDO
         PAGREC->VALOR_V  :=VALPAR[3]
         PAGREC->DATVEN_V :=MDATE[3]
         PAGREC->DOCEXT_V :=DOCEXT[3]
         PAGREC->DATEXT_V :=DATE()
         PAGREC->DESC_V   :="Venda Direta "+PEDIDO
         PAGREC->(DBUNLOCK())
      ENDIF
   ENDIF
   IF MDATE[4]#(NIL)
      PEDIDO->DATPAG3_V:=MDATE[4]
      PEDIDO->VALPAR3_V:=VALPAR[4]
      PEDIDO->DOCEXT3_V:=DOCEXT[4]
      IF REGISTRAR="S"
         PAGREC->(ADDREC(5))
         CONFIG->(RECLOCK())
         PAGREC:="R"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PEDIDO->PAGREC3_V:=PAGREC
         PAGREC->CODIGO_V :=PAGREC
         PAGREC->CLIFOR_V :=CLIFOR
         PAGREC->CODPLA_V :=CODPLA
         PAGREC->PEDIDO_V :=PEDIDO
         PAGREC->VALOR_V  :=VALPAR[4]
         PAGREC->DATVEN_V :=MDATE[4]
         PAGREC->DOCEXT_V :=DOCEXT[4]
         PAGREC->DATEXT_V :=DATE()
         PAGREC->DESC_V   :="Venda Direta "+PEDIDO
         PAGREC->(DBUNLOCK())
      ENDIF
   ENDIF
   IF MDATE[5]#(NIL)
      PEDIDO->DATPAG4_V:=MDATE[5]
      PEDIDO->VALPAR4_V:=VALPAR[5]
      PEDIDO->DOCEXT4_V:=DOCEXT[5]
      IF REGISTRAR="S"
         PAGREC->(ADDREC(5))
         CONFIG->(RECLOCK())
         PAGREC:="R"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PEDIDO->PAGREC4_V:=PAGREC
         PAGREC->CODIGO_V :=PAGREC
         PAGREC->CLIFOR_V :=CLIFOR
         PAGREC->CODPLA_V :=CODPLA
         PAGREC->PEDIDO_V :=PEDIDO
         PAGREC->VALOR_V  :=VALPAR[5]
         PAGREC->DATVEN_V :=MDATE[5]
         PAGREC->DOCEXT_V :=DOCEXT[5]
         PAGREC->DATEXT_V :=DATE()
         PAGREC->DESC_V   :="Venda Direta "+PEDIDO
         PAGREC->(DBUNLOCK())
      ENDIF
   ENDIF
   IF CLIFOR->(DBSEEK(CLIFOR)) .AND. CLIFOR->(RECLOCK(5))
      CLIFOR->DATPED_V  :=DATE()
      CLIFOR->ULTPED_V  :=PEDIDO
      CLIFOR->VALPED_V  :=TOTAL
      IF CLIFOR->VALMAI_V<TOTAL
         CLIFOR->DATMAI_V  :=DATE()
         CLIFOR->PEDMAI_V  :=PEDIDO
         CLIFOR->VALMAI_V  :=TOTAL
      ENDIF
      CLIFOR->(DBUNLOCK())
   ENDIF
   VALCUS := 0
   VALMIN := 0
   VALMED := 0
   VALMAX := 0
   DO WHILE .T.
      IF ICODIGO[X]=NIL
         EXIT
      ENDIF
      DO WHILE .NOT. PEDIDO2->(ADDREC(5));ENDDO
      PEDIDO2->CODIGO_V :=PEDIDO
      PEDIDO2->ITEM_V   :=ICODIGO[X]
      PEDIDO2->VALUNI_V :=VALOR[X]
      PEDIDO2->QTD_V    :=QTD[X]
      IF ESTOQUE->(DBSEEK(ICODIGO[X]))
         PEDIDO2->VALCUS_V := ESTOQUE->VALCUS_V
         PEDIDO2->VALMIN_V := ESTOQUE->VALVEN_V
         PEDIDO2->VALMED_V := IF(CONFIG->MULTPRCV_V='S',ESTOQUE->VALMED_V,ESTOQUE->VALVEN_V)
         PEDIDO2->VALMAX_V := ESTOQUE->VALMAX_V
         VALCUS += ESTOQUE->VALCUS_V
         VALMIN += ESTOQUE->VALVEN_V
         VALMED += IF(CONFIG->MULTPRCV_V='S',ESTOQUE->VALMED_V,ESTOQUE->VALVEN_V)
         VALMAX += ESTOQUE->VALMAX_V
         movest("S",pedido2->item_v, "VM", pedido2->qtd_v, pedido2->codigo_v)
      ENDIF
      PEDIDO2->(DBCOMMIT(),DBUNLOCK())
      X++
   ENDDO
   PEDIDO->VALCUS_V := VALCUS
   PEDIDO->VALMED_V := VALMED
   IF CONFIG->MULTPRCV_V='S'
      PEDIDO->VALMIN_V := VALMIN
      PEDIDO->VALMAX_V := VALMAX
   ENDIF
   IF SYSTEM->(ADDREC()) .AND. CONFIG->(RECLOCK())
      CONFIG->SYSTEM_V+=1
      SYSTEM->CODIGO_V := CONFIG->SYSTEM_V
      SYSTEM->DATA_V   := DATE()
      SYSTEM->HORA_V   := TIME()
      SYSTEM->DESCR_V  := "Venda Direta"+PEDIDO
      SYSTEM->USUARIO_V:= NOMSEN
      PEDIDO->SYSTEM_V := SYSTEM->CODIGO_V
   ENDIF
   SYSTEM->(DBCOMMIT(),DBUNLOCK())
   PEDIDO->(DBCOMMIT(),DBUNLOCK())
   PEDVIMP(PEDIDO->CODIGO_V,.T.)
   IF CONFIRMA(20,20,"Deseja imprimir o comprovante de venda ?")
      DO WHILE ! ISPRINTER() .AND. LASTKEY()<>27
         AVISO("Impressora fora de linha ou nao conectada ...")
      ENDDO
      IF LASTKEY()<>27
         IMPPEDIDO(PEDIDO)
      ENDIF
   ENDIF
ENDIF
DBF_MOEDA()
PAGREC->(DBCLOSEAREA())
RETURN(.T.)

FUNCTION IMPDIRETO(PEDIDO)
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN
PEDIDO->(DBSETORDER(1))
PEDIDO2->(DBSETORDER(1))
PEDIDO->(DBSEEK(PEDIDO))
PEDIDO2->(DBSEEK(PEDIDO))
CABECA("Registro de Venda "+PEDIDO)
@ PROW()+1,1 SAY "Dt.Operacao: "+DTOC(PEDIDO->DATEMI_V) +" " + PEDIDO->HORAEMI_V
@ PROW()+1,1 SAY "Vendedor   : "+IF(MECVEN->(DBSEEK(PEDIDO->MECVEN_V)),MECVEN->NOME_V,SPACE(50))
@ PROW()+1,1 SAY "Cliente    : "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->NOME_V,SPACE(50))
@ PROW()+1,1 SAY "Endereco   : " +IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),alltrim(CLIFOR->ENDERECO_V)+" "+alltrim(clifor->numero_v)+" "+alltrim(clifor->complem_v),SPACE(50))
@ PROW()+1,1 SAY "Bairro     : "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->BAIRRO_V,SPACE(30))
@ PROW(),45  SAY "C.E.P. :"+ IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),TRANSFORM(CLIFOR->CEP_V,"@R 99999-999"),SPACE(9))
