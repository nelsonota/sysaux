FUNCTION BCLIFOR(OPCAO)
LOCAL GETLIST:={},TELA,OP
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR SYSVEN,BLQVEN
*** VARIAVEIS PARA CADASTRO CLIENTES/FORNECEDORES
MEMVAR CODIGO,NOME,FANTASIA,ENDERECO,BAIRRO,CIDADE,ESTADO,CEP,FONE1,FONE2,FAX
MEMVAR ENDCOB,BAICOB,CIDCOB,ESTCOB,CEPCOB,FONECOB1,FONECOB2,FAXCOB,CLIFOR
MEMVAR CGCCPF,RGINSEST
TELA:=SAVESCREEN(0,0,24,80)
@ 3,2  PROMPT "C˘digo   "
@ 4,2  PROMPT "Nome     "
@ 5,2  PROMPT "Fantasia "
MENU TO OP
DO CASE
   CASE OP=1
      CLIFOR->(DBSETORDER(1))
      CODIGO:=0
      @ 3,13 GET CODIGO PICT "99999"
      READ
      CODIGO:=OPCAO+STRZERO(CODIGO,5,0)
      CLIFOR->(DBSEEK(CODIGO,.F.))
   CASE OP=2
      CLIFOR->(DBSETORDER(2))
      @ 4,13 GET NOME PICT "@K!"
      READ
      CLIFOR->(DBSEEK(NOME,.T.))
   CASE OP=3
      CLIFOR->(DBSETORDER(3))
      CGCCPF:=SPACE(LEN(CLIFOR->CGCCPF_V))
      @ 5,13 GET FANTASIA PICT "@K!"
      READ
      CLIFOR->(DBSEEK(FANTASIA,.T.))
ENDCASE
RESTSCREEN(0,0,24,80,TELA)
IF LASTKEY()=27
   RETURN(.F.)
ENDIF
DBE_CLIFOR(10,10,20,70,SYSVEN)
RETURN(.T.)