FUNCTION ASENHA()
LOCAL SENHA1,GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN

*** VARIAVEIS P/ REGISTRO DE SENHA
MEMVAR NOMSEN,SENHA,NIVEL,CODIGO
DO WHILE .T.
   @ 8,54 GET NOMSEN PICT "@!"
   READ
   IF LASTKEY()=27
      RETURN(.F.)
   ENDIF
   SENHA :=SPACE(0)
   SENHA1:=SPACE(0)
   SETCOLOR(CORBAR)
   @ 9,54 CLEAR TO 9,62
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   DO WHILE EMPTY(SENHA)
      SENHA:=NEWGET(LEN(SENHA->SENHA_V),9,54,.F.)
      IF SENHA=".F."
         RETURN(.F.)
      ENDIF
   ENDDO
   SETCOLOR(CORBAR)
   @ 9,54 CLEAR TO 9,62
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   DO WHILE EMPTY(SENHA1)
      SENHA1:=NEWGET(LEN(SENHA->SENHA_V),9,54,.F.)
      IF SENHA1=".F."
         RETURN(.F.)
      ENDIF
      IF SENHA#SENHA1
         AVISO("Senha nao Confere ...")
         RETURN(.F.)
      ENDIF
   ENDDO
   IF LEVEL="SP" .OR. LEVEL="NE"
      @ 11,54 GET NIVEL PICT "@!"
      READ
      IF LASTKEY()=27
         LOOP
      ENDIF
   ENDIF
   IF CONFIRMA(20,20,"Confirma Altera‡oes ?")
      IF SENHA->(RECLOCK(5))
         SENHA->NOMSEN_V:=NOMSEN
         SENHA->SENHA_V :=CRIP(SENHA)
         SENHA->LEVEL_V :=NIVEL
         SENHA->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
ENDDO
RETURN(.T.)