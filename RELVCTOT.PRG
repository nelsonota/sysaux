FUNCTION RELVCTOT(TIPO,TIPO2)
LOCA   GETLIST:={},TELA,X,TITULO,TOTAL
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR LINHA,CLIFOR,MECVEN,INICIO,FIM
TELA:=SAVESCREEN(0,0,24,80)
INICIO:=CTOD("  /  /  ")
FIM   :=CTOD("  /  /  ")
DBF_PEDIDO()
DBF_CONFIG()
DBF_CLIFOR()
DBF_MECVEN()
DO WHILE .T.
   CLIFOR:=SPACE(LEN(CLIFOR->CODIGO_V))
   MECVEN:=SPACE(LEN(MECVEN->CODIGO_V))
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   IF TIPO2=="TOTC" .OR. TIPO2=="TOTCP" .OR. TIPO2=="TOTCNP"
      DATCFINIFIN(,"C")
   ELSE
      IF TIPO2=="TOTV" .OR. TIPO2=="TOTVP" .OR. TIPO2=="TOTVNP"
         DATMVINIFIN(,"V")
      ELSE
         IF TIPO2=="TOTF"
            DATCFINIFIN(,"F")
         ELSE
            DATINIFIN()
         ENDIF
      ENDIF
   ENDIF
   IF LASTKEY()=27
      EXIT
   ENDIF
   LINHA:={}
   X=1
   CLIFOR->(DBSETORDER(1))
   MECVEN->(DBSETORDER(1))
   TOTAL:=0
   DO CASE
      CASE TIPO2=="TOT"
         IF TIPO="V"
            TITULO:="Total de Vendas"
         ELSE
            TITULO:="Total de Compras"
         ENDIF
         PEDIDO->(DBSETORDER(4))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATBAI_V>=INICIO .AND. PEDIDO->DATBAI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,19),SPACE(19))+" "+PEDIDO->TIPO_V+" "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATBAI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="TOTP"
         IF TIPO="V"
            TITULO:="Total de Vendas Pagas"
         ELSE
            TITULO:="Total de Compras Pagas"
         ENDIF
         PEDIDO->(DBSETORDER(4))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATBAI_V>=INICIO .AND. PEDIDO->DATBAI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. ! EMPTY(PEDIDO->DATPAG_V)
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,19),SPACE(19))+" "+PEDIDO->TIPO_V+"     "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATBAI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))),STRZERO(PEDIDO->NOTACOM_V,7,0)))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="TOTNP"
         IF TIPO="V"
            TITULO:="Total de Vendas nao Pagas"
         ELSE
            TITULO:="Total de Compras nao Pagas"
         ENDIF
         PEDIDO->(DBSETORDER(4))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATBAI_V>=INICIO .AND. PEDIDO->DATBAI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. EMPTY(PEDIDO->DATPAG_V)
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,19),SPACE(19))+" "+PEDIDO->TIPO_V+"     "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATBAI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))),STRZERO(PEDIDO->NOTACOM_V,7,0)))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="TOTC" .OR. TIPO2=="TOTF"
         IF TIPO="V"
            TITULO:="Vendas Diretas"
         ELSE
            TITULO:="Compras Diretas"
         ENDIF
         PEDIDO->(DBSETORDER(4))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATBAI_V>=INICIO .AND. PEDIDO->DATBAI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->CLIFOR_V=CLIFOR
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,19),SPACE(19))+" "+PEDIDO->TIPO_V+"     "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATBAI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))),STRZERO(PEDIDO->NOTACOM_V,7,0)))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="TOTCP"
         IF TIPO="V"
            TITULO:="Vendas Diretas Pagas"
         ELSE
            TITULO:="Compras Diretas Pagas"
         ENDIF
         PEDIDO->(DBSETORDER(4))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATBAI_V>=INICIO .AND. PEDIDO->DATBAI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->CLIFOR_V=CLIFOR .AND. ! EMPTY(PEDIDO->DATPAG_V)
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,19),SPACE(19))+" "+PEDIDO->TIPO_V+"     "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATBAI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))),STRZERO(PEDIDO->NOTACOM_V,7,0)))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="TOTCNP"
         IF TIPO="V"
            TITULO:="Vendas Diretas"
         ELSE
            TITULO:="Compras Diretas"
         ENDIF
         PEDIDO->(DBSETORDER(4))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATBAI_V>=INICIO .AND. PEDIDO->DATBAI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->CLIFOR_V=CLIFOR .AND. EMPTY(PEDIDO->DATPAG_V)
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,19),SPACE(19))+" "+PEDIDO->TIPO_V+"     "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATBAI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))),STRZERO(PEDIDO->NOTACOM_V,7,0)))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="TOTV"
         IF TIPO="V"
            TITULO:="Vendas Diretas"
         ELSE
            TITULO:="Compras Diretas"
         ENDIF
         PEDIDO->(DBSETORDER(4))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATBAI_V>=INICIO .AND. PEDIDO->DATBAI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->MECVEN_V=MECVEN
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,19),SPACE(19))+" "+PEDIDO->TIPO_V+"     "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATBAI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))),STRZERO(PEDIDO->NOTACOM_V,7,0)))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="TOTVP"
         IF TIPO="V"
            TITULO:="Vendas Diretas Pagas"
         ELSE
            TITULO:="Compras Diretas Pagas"
         ENDIF
         PEDIDO->(DBSETORDER(4))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATBAI_V>=INICIO .AND. PEDIDO->DATBAI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->MECVEN_V=MECVEN .AND. !EMPTY(PEDIDO->DATPAG_V)
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,19),SPACE(19))+" "+PEDIDO->TIPO_V+"     "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATBAI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))),STRZERO(PEDIDO->NOTACOM_V,7,0)))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
      CASE TIPO2=="TOTVNP"
         IF TIPO="V"
            TITULO:="Vendas Diretas nao Pagas"
         ELSE
            TITULO:="Compras Diretas nao Pagas"
         ENDIF
         PEDIDO->(DBSETORDER(4))
         PEDIDO->(DBSEEK(INICIO,.T.))
         DO WHILE PEDIDO->DATBAI_V>=INICIO .AND. PEDIDO->DATBAI_V<=FIM .AND. PEDIDO->(!EOF()) .AND. X<=4090
            IF LEFT(PEDIDO->CODIGO_V,1)=TIPO .AND. PEDIDO->MECVEN_V=MECVEN .AND. EMPTY(PEDIDO->DATPAG_V)
               AADD(LINHA,PEDIDO->CODIGO_V+" "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),LEFT(CLIFOR->NOME_V,19),SPACE(19))+" "+PEDIDO->TIPO_V+"     "+DTOC(PEDIDO->DATEMI_V)+" "+DTOC(PEDIDO->DATBAI_V)+" "+DTOC(PEDIDO->DATPAG_V)+" "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+" "+IF(TIPO="V",IF(TIPO="V",IF(EMPTY(PEDIDO->NOTA_V),SPACE(6),STRZERO(PEDIDO->NOTA_V,6,0)),IF(EMPTY(PEDIDO->NOTACOM_V),SPACE(6),STRZERO(PEDIDO->NOTACOM_V,7,0))),STRZERO(PEDIDO->NOTACOM_V,7,0)))
               TOTAL:=TOTAL+PEDIDO->VALTOT_V
               X++
            ENDIF
            PEDIDO->(DBSKIP())
         ENDDO
   ENDCASE
   WINDOW(5,0,22,79)
   SETCOLOR(CORTIT)
   @ 6,1 SAY PADC(TITULO+" no Perˇodo de "+DTOC(INICIO)+" … "+DTOC(FIM),78)
   @ 7,1 SAY PADR(" Codigo Nome           Tipo  Dt.Emissao Dt.Baixa Dt.Pagto.       Valor Nota",78)
   @ 21,1 SAY PADR(" Valor Total : "+TRANSFORM(TOTAL,"@R 999,999,999.99"),78)
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 8,1 TO 8,78
   @ 20,1 TO 20,78
   ACHOICE(9,1,19,78,LINHA,.T.,"RELACHOFUN")
   IF CONFIRMA(20,20,"Deseja Imprimir o Relat˘rio ?")
      AADD(LINHA,REPLICATE("-",79))
      AADD(LINHA," Valor Total : "+TRANSFORM(TOTAL,"@R 999,999,999.99"))
      IMPREL(TITULO+" no Perˇodo de "+DTOC(INICIO)+" … "+DTOC(FIM)," Codigo Nome           Tipo  Dt.Emissao Dt.Baixa Dt.Pagto.       Valor Nota",50)
   ENDIF
   EXIT
ENDDO
CLIFOR->(DBCLOSEAREA())
MECVEN->(DBCLOSEAREA())
CONFIG->(DBCLOSEAREA())
PEDIDO->(DBCLOSEAREA())
RESTSCREEN(,,,,TELA)
RETURN(.T.)