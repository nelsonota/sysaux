FUNCTION IBANK()
LOCAL CAMPOS,GETLIST:={},BANCO
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN,NOMSEN
***** VARIAVEIS PARA CADASTRO DE BANCOS
MEMVAR CODIGO,NOME,CONTA,AGENCIA,SALDO
CODIGO  :=CONFIG->BANK_V+1
NOME   :=SPACE(LEN(BANK->NOME_V))
CONTA  :=SPACE(LEN(BANK->CONTA_V))
AGENCIA:=SPACE(LEN(BANK->AGENCIA_V))
SALDO  :=0
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 10,20 SAY STRZERO(CODIGO,5,0)
   @ 11,20 GET NOME    PICT "@!" VALID(!EMPTY(NOME))
   @ 12,20 GET CONTA   PICT "@!" VALID(!EMPTY(CONTA).OR.LASTKEY()=5)
   @ 13,20 GET AGENCIA PICT "@!" VALID(!EMPTY(AGENCIA).OR.LASTKEY()=5)
   @ 14,20 GET SALDO   PICT "@R 999,999,999.99"
   READ
   IF LASTKEY()=27
      RETURN(.F.)
   ENDIF
   IF CONFIRMA(18,10,"Confirma Inclusao do Banco ?")
      IF BANK->(ADDREC(5))
         IF CONFIG->(RECLOCK(5))
            CONFIG->BANK_V:=CONFIG->BANK_V+1
            CODIGO:=CONFIG->BANK_V
            CONFIG->(DBUNLOCK())
         ELSE
            EXIT
         ENDIF
         BANK->CODIGO_V :=CODIGO
         BANK->NOME_V   :=NOME
         BANK->CONTA_V  :=CONTA
         BANK->AGENCIA_V:=AGENCIA
         BANK->SALDO_V  :=SALDO
         BANK->NOMSEN_V :=NOMSEN
         BANK->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
ENDDO
RETURN(.T.)