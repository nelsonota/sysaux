FUNCTION BASCAL()
LOCAL OP,TELA
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO

*** MEMVAR P/ CADASTRO DE BASE DE CALCULO DO ICMS
MEMVAR CODIGO,BASCAL,MENSAGEM,SIGLA,ESTADO
TELA:=SAVESCREEN(0,0,24,80)
WINDOW(19,8,21,43)
WINDOW(13,8,19,72)
@ 20,43 SAY CHR(219)
DBF_BASCAL()
DBF_CONFIG()
SETCOLOR(CORTIT)
@ 12,8 SAY "Tabelas de Al¡quota de Base de C lculo"
DO WHILE .T.
   SETCOLOR(CORTEX)
   CODIGO  :=BASCAL->CODIGO_V
   BASCAL  :=BASCAL->BASCAL_V
   MENSAGEM:=BASCAL->MENSAGEM_V
   SIGLA   :=BASCAL->SIGLA_V
   ESTADO  :=BASCAL->ESTADO_V
   @ 14,10 SAY "C¢digo  : " + STRZERO(CODIGO,5,0)
   @ 15,10 SAY "% Al¡q. : " + TRANSFORM(BASCAL,"@R 9,999.99")
   @ 16,10 SAY "Estado  : " + ESTADO
   @ 17,10 SAY "Sigla   : " + SIGLA
   @ 18,10 SAY "Mensagem: " + LEFT(MENSAGEM,50)
   SETCOLOR(CORTEX+","+CORBAR)
   @ 20,9 PROMPT " Incluir "
   @ 20,18 PROMPT " Buscar "
   @ 20,26 PROMPT " Alterar "
   @ 20,35 PROMPT " Apagar "
   MENU TO OP
   DO CASE
      CASE OP=1
         IBASCAL()
      CASE OP=2
         BBASCAL()
      CASE OP=3
         ABASCAL()
      CASE OP=4
         EBASCAL()
      OTHERWISE
         EXIT
   ENDCASE
ENDDO
BASCAL->(DBCLOSEAREA())
CONFIG->(DBCLOSEAREA())
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(13,8,19,72)
RETURN(.T.)