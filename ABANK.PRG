FUNCTION ABANK()
LOCAL GETLIST:={}
MEMVAR CORTEX,CORBAR,CORDES
***** VARIAVEIS PARA CADASTRO DE BANCOS
MEMVAR NOME,CONTA,AGENCIA
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 11,20 GET NOME
   @ 12,20 GET CONTA
   @ 13,20 GET AGENCIA
   READ
   IF LASTKEY()=27
      RETURN(.T.)
   ENDIF
   IF CONFIRMA(20,20,"Confirma Altera‡oes ?")
      IF BANK->(RECLOCK(5))
         BANK->NOME_V   :=NOME
         BANK->CONTA_V  :=CONTA
         BANK->AGENCIA_V:=AGENCIA
         BANK->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
ENDDO
RETURN(.T.)