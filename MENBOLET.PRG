FUNCTION MENBOLET()
LOCAL  TELA,LINHA1,LINHA2,LINHA3,LINHA4,GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
TELA:=SAVESCREEN()
DBF_CONFIG()
SETCOLOR(CORTIT)
LINHA1:=CONFIG->LINBOL1_V
LINHA2:=CONFIG->LINBOL2_V
LINHA3:=CONFIG->LINBOL3_V
LINHA4:=CONFIG->LINBOL4_V
@ 9,5 SAY "Instru‡oes do Boleto"
WINDOW(10,5,15,56)
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 11,7 GET LINHA1
   @ 12,7 GET LINHA2
   @ 13,7 GET LINHA3
   @ 14,7 GET LINHA4
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Confirma Instrucoes do Boleto ?")
      IF CONFIG->(RECLOCK(5))
         CONFIG->LINBOL1_V:=LINHA1
         CONFIG->LINBOL2_V:=LINHA2
         CONFIG->LINBOL3_V:=LINHA3
         CONFIG->LINBOL4_V:=LINHA4
         CONFIG->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
ENDDO
RESTSCREEN(,,,,TELA)
CLOSEWIN(10,5,15,56)
CONFIG->(DBCLOSEAREA())
RETURN(.T.)