FUNCTION BOLETO()
LOCAL  GETLIST:={},OPCOES,OP,TELA2
MEMVAR LINHA1,LINHA2,LINHA3,LINHA4,LOCAL,ESPECIE,ACEITE,BOLETO,CODBANBO
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO

*** VARIAVEIS P/ CADASTRO DE CONTAS A PAGAR/RECEBER
MEMVAR PAGREC,CODIGO,CLIFOR,DOCEXT,DESC,DOCINT,DATVEN,VALOR,CODPLA
MEMVAR DATEXT,DATINT
TELA:=SAVESCREEN(0,0,24,80)
LOCAL  :='PAGAVEL EM QUALQUER BANCO ATE O VENCIMENTO     '
ESPECIE:=SPACE(6)
ACEITE :=SPACE(3)
IF EMPTY(PAGREC->BOLETO_V)
   BOLETO :="EMITIDO"+SPACE(13)
ELSE
   BOLETO :=PAGREC->BOLETO_V
ENDIF
LINHA1 :=CONFIG->LINBOL1_V
LINHA2 :=CONFIG->LINBOL2_V
LINHA3 :=CONFIG->LINBOL3_V
LINHA4 :=CONFIG->LINBOL4_V
WINDOW(2,3,24,75)
SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
@ 4,4   TO 4,74
@ 6,4   TO 6,74
@ 8,4   TO 8,74
@ 10,4  TO 10,74
@ 12,54 TO 12,74
@ 14,54 TO 14,74
@ 16,54 TO 16,74
@ 18,54 TO 18,74
@ 20,4  TO 20,74
@ 3,53  TO 19,53
@ 7,13  SAY CHR(179)
@ 7,26  SAY CHR(179)
@ 7,34  SAY CHR(179)
@ 7,41  SAY CHR(179)
@ 9,13 SAY CHR(179)
@ 9,20 SAY CHR(179)
@ 9,28 SAY CHR(179)
@ 9,37 SAY "x"
SETCOLOR(CORTIT)
@ 2,5   SAY "Local de Pagamento"
@ 2,54  SAY "Vencimento"
@ 4,5   SAY "Cedente"
@ 4,54  SAY "Agˆncia/C¢d.Cedente"
@ 6,54  SAY "Nosso N£mero"
@ 6,5   SAY "Dt.Doc."
@ 6,14  SAY "N§ Doc."
@ 6,27  SAY "Esp.Doc."
@ 6,35  SAY "Aceite"
@ 6,42  SAY "Dt.Proc."
@ 8,5   SAY "U.Banco"
@ 8,54  SAY "Valor Documento"
@ 8,14  SAY "Cart."
@ 8,21  SAY "Esp‚cie"
@ 8,29  SAY "Quantidade Valor"
@ 11,5  SAY "Instru‡oes"
@ 10,54 SAY "Desconto"
@ 12,54 SAY "Outras Dedu‡oes"
@ 14,54 SAY "Mora/Multa"
@ 16,54 SAY "Outros Acr‚scimos"
@ 18,54 SAY "Valor Cobrado"
@ 20,5  SAY "Sacado"
DO WHILE .T.
   IF LEFT(PAGREC->CODIGO_V,1)#"R"
      AVISO("Imposs¡vel Emitir Boleto para Conta … Pagar ...")
      Exit
   ENDIF
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 3,5  GET LOCAL
   @ 3,54 SAY DATVEN
   @ 5,5  SAY DECRIP(LEFT(CONFIG->NOME_V,47))
   @ 7,5  SAY DATINT
   @ 7,14 SAY DOCINT
   @ 7,27 GET ESPECIE
   @ 7,35 GET ACEITE
   @ 7,54 GET BOLETO
   @ 7,42 SAY DATE()
   @ 9,54 SAY VALOR PICT "999,999,999.99"
   @ 14,5 GET LINHA1
   @ 15,5 GET LINHA2
   @ 16,5 GET LINHA3
   @ 17,5 GET LINHA4
   @ 21,5 SAY IF(CLIFOR->(DBSEEK(PAGREC->CLIFOR_V)),CLIFOR->NOME_V,SPACE(50))
   @ 22,5 SAY ALLTRIM(IF(CLIFOR->(DBSEEK(PAGREC->CLIFOR_V)),IF(EMPTY(CLIFOR->ENDCOB_V),alltrim(CLIFOR->ENDERECO_V)+" "+alltrim(clifor->numero_v)+" "+alltrim(clifor->complem_v),alltrim(CLIFOR->ENDCOB_V)+" "+alltrim(clifor->numcob_v)+" "+alltrim(clifor->compcob_v)),SPACE(50)))+" "+ALLTRIM(IF(CLIFOR->(DBSEEK(PAGREC->CLIFOR_V)),IF(EMPTY(CLIFOR->ENDCOB_V),CLIFOR->BAIRRO_V,CLIFOR->BAICOB_V),SPACE(30)))
   @ 23,5 SAY IF(CLIFOR->(DBSEEK(PAGREC->CLIFOR_V)),TRANSFORM(IF(EMPTY(CLIFOR->ENDCOB_V),CLIFOR->CEP_V,CLIFOR->CEPCOB_V),"@R 99999-999"),SPACE(9))+SPACE(20)+"CPF / CGC : "+IF(CLIFOR->(DBSEEK(PAGREC->CLIFOR_V)),CLIFOR->CGCCPF_V,SPACE(18))
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF ! CONFIRMA(20,20,"Confirma Impressao do Boleto ?")
      LOOP
   ENDIF
   OPCOES:={" Brasil      "," Bamerindus  "," Bradesco    "," Nossa Caixa "," Finasa      ",;
            " Bank Boston "}
   WINDOW(14,4,21,18)
   OP:=ACHOICE(15,5,20,17,OPCOES,.T.,"ACHOFUN")
   SET CENTURY OFF
   DO CASE
      CASE OP=1
         BRASIL()
      CASE OP=2
         BAMERINDUS()
      CASE OP=3
         BRADESCO()
      CASE OP=4
         NCNB()
      CASE OP=5
         FINASA()
      CASE OP=6
         BOSTON()
      OTHERWISE
         SET CENTURY ON
         LOOP
   ENDCASE
   SET CENTURY ON
   TELA2:=SAVESCREEN()
   @ 24,0 SAY PADC("O modelo selecionado refere-se ao seu banco ...",78) COLOR CORTIT
   DBE_BANK(14,4,20,16)
   IF LASTKEY()=27
      RESTSCREEN(,,,,TELA2)
      LOOP
   ENDIF
   RESTSCREEN(,,,,TELA2)
   IF PAGREC->(RECLOCK(5))
      PAGREC->BOLETO_V:=BOLETO
      PAGREC->CODBANBO_V:=BANK->CODIGO_V
      PAGREC->(DBUNLOCK())
   ENDIF
   EXIT
ENDDO
RESTSCREEN(,,,,TELA)
CLOSEWIN(2,3,24,75)
RETURN(.T.)

FUNCTION BRASIL()
LOCAL  GETLIST:={}
MEMVAR LINHA1,LINHA2,LINHA3,LINHA4,LOCAL,ESPECIE,ACEITE

*** VARIAVEIS P/ CADASTRO DE CONTAS A PAGAR/RECEBER
MEMVAR PAGREC,CODIGO,CLIFOR,DOCEXT,DESC,DOCINT,DATVEN,VALOR,CODPLA
MEMVAR DATEXT,DATINT
LigaImpressora()
@ PROW(),PCOL() SAY CHR(18)
@ 1,0    SAY LOCAL
@ 1,52   SAY DATVEN
@ 5,0  SAY DATINT
@ 5,10 SAY DOCINT
@ 5,29 SAY ESPECIE
@ 5,36 SAY ACEITE
@ 5,41 SAY DATE()
@ 6,52 SAY VALOR PICT "999,999,999.99"
@ 10,0   SAY LINHA1
@ 11,0   SAY LINHA2
@ 12,0   SAY LINHA3
@ 13,0   SAY LINHA4
@ 15,4 SAY IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->NOME_V,SPACE(50))
@ 16,4 SAY ALLTRIM(IF(CLIFOR->(DBSEEK(CLIFOR)),ALLTRIM(IF(EMPTY(CLIFOR->ENDCOB_V),alltrim(CLIFOR->ENDERECO_V)+" "+alltrim(clifor->numero_v)+" "+alltrim(clifor->complem_v),alltrim(CLIFOR->ENDCOB_V)+" "+alltrim(clifor->numcob_v)+" "+alltrim(clifor->compcob_v))),SPACE(50)))+" - "+ALLTRIM(IF(CLIFOR->(DBSEEK(CLIFOR)),ALLTRIM(IF(EMPTY(CLIFOR->ENDCOB_V),CLIFOR->BAIRRO_V,CLIFOR->BAICOB_V)),SPACE(30)))+SPACE(2)+IF(CLIFOR->(DBSEEK(CLIFOR)),ALLTRIM(IF(EMPTY(CLIFOR->ENDCOB_V),CLIFOR->CIDADE_V,CLIFOR->CIDCOB_V)),SPACE(1))+SPACE(2)+IF(CLIFOR->(DBSEEK(CLIFOR)),IF(EMPTY(CLIFOR->ENDCOB_V),CLIFOR->ESTADO_V,CLIFOR->ESTCOB_V),SPACE(2))
@ 17,4 SAY IF(CLIFOR->(DBSEEK(CLIFOR)),TRANSFORM(IF(EMPTY(CLIFOR->ENDCOB_V),CLIFOR->CEP_V,CLIFOR->CEPCOB_V),"@R 99999-999"),SPACE(9))+SPACE(20)+"CPF / CGC : "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->CGCCPF_V,SPACE(18))
EJECT
SET PRINTER TO
SET DEVICE TO SCREEN
RETURN(.T.)


