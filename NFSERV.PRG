FUNCTION NFSERV()
LOCAL TELA,ENT,ENT2,X,COL,GETLIST:={},INTER,PARCELAS
LOCAL TOTAL,TELA2
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN

MEMVAR LINSERV1,LINSERV2,LINSERV3,LINSERV4,VALMO,VALTOT

MEMVAR FRETE,PLACA,UF,QUANT,ESPECIE,MARCA,NUMERO,PESOBRU,PESOLIQ
MEMVAR NOTA,DATSAI,HORASAI,DATEMI,CODTRAN,CFOP,CLIFOR

MEMVAR MDATE,VALPAR

TELA:=SAVESCREEN()

WINDOW(0,0,24,79)
NOTA   :=0
CODTRAN:=0
CFOP   :=SPACE(6)
MDATE:={,,,,,}
VALPAR:={,,,,,}
CLIFOR:=SPACE(LEN(CLIFOR->CODIGO_V))

VALMO:=0
LINSERV1:=SPACE(LEN(NOTA->LINSERV1_V))
LINSERV2:=SPACE(LEN(NOTA->LINSERV2_V))
LINSERV3:=SPACE(LEN(NOTA->LINSERV3_V))
LINSERV4:=SPACE(LEN(NOTA->LINSERV4_V))

PARCELAS:=0
INTER   :=0
ENT     :=SPACE(1)

FRETE  :=SPACE(1)
PLACA  :=SPACE(9)
UF     :=SPACE(2)
QUANT  :=0
ESPECIE:=SPACE(15)
MARCA  :=SPACE(15)
NUMERO :=SPACE(15)
PESOBRU:=SPACE(15)
PESOLIQ:=SPACE(15)
DATEMI :=DATE()
DATSAI :=DATE()
HORASAI:=TIME()

NOTA->(DBSETORDER(1))
DO WHILE .T.
   TOTAL   :=0
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 1,2   SAY "Nota Fiscal   :" GET NOTA PICT "999999" VALID(NOTA>0.AND.!NOTA->(DBSEEK(NOTA)))
   @ 2,2   SAY "C.F.OP.       :" GET CFOP VALID(LASTKEY()=5 .OR. SEA_CFOP(CFOP,2,25))
   @ 2,43  SAY "Cliente :" GET CLIFOR PICT "@K!" VALID(SEA_CLIFOR(CLIFOR,,,"C").AND.NFSERV1())
   @ 3,2   SAY "Transportadora:" GET CODTRAN PICT "99999" VALID(LASTKEY()=5 .OR. SEA_CODTRAN(CODTRAN,3,25).AND.NF1())
   @ 7,1   TO 7,78
   @ 8,1   SAY PADC("Volumes Transportados",78) COLOR CORTIT
   @ 09,1  TO 09,78
   @ 10,2  SAY "Frete por Conta :" GET FRETE VALID(FRETE$"12 ")
   @ 10,22 SAY "Placa do VeÀculo:" GET PLACA PICT "NNN-9999"
   @ 10,49 SAY "Estado :" GET UF
   @ 11,2  SAY "Quantidade :" GET QUANT PICT "999,999,999.99"
   @ 11,31 SAY "Espcie      :" GET ESPECIE
   @ 12,2  SAY "Marca      :" GET MARCA
   @ 12,31 SAY "NÈmero       :" GET NUMERO
   @ 13,2  SAY "Peso Bruto :" GET PESOBRU
   @ 13,31 SAY "Peso LÀquido :" GET PESOLIQ
   @ 14,2  SAY "Dt. Emissao:" GET DATEMI
   @ 14,31 SAY "Data SaÀda   :" GET DATSAI
   @ 14,57 SAY "Hora SaÀda :" GET HORASAI
   @ 15,1  TO 15,78
   @ 16,1  SAY PADC("Faturamento",78) COLOR CORTIT
   @ 17,1  TO 17,78
   @ 18,2  SAY "Parcelas   :" GET PARCELAS PICT "9" VALID(PARCELAS>0 .AND. PARCELAS<=5)
   @ 18,18 SAY "Intervalo de Dias :" GET INTER PICT "99" VALID(IF(PARCELAS>1,INTER>0,INTER>=0))
   @ 18,43 SAY "1Î Parc.  Vista ? :" GET ENT PICT "@!" VALID(LASTKEY()=5 .OR. ENT$"SN")
   @ 19,1  TO 19,78
   @ 22,1 TO 22,78
   @ 23,01 SAY PADL(" Total : "+TRANSFORM(VALMO,"@R 999,999,999.99")+" ",78) COLOR CORTIT
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   DBF_PAGREC()
   PAGREC->(DBCLOSEAREA())
   TELA2:=SAVESCREEN()
   WINDOW(10,10,16,78)
   @ 10,11 SAY "Servios Prestados" COLOR CORTIT
   @ 11,12 GET LINSERV1 PICT "@!"
   @ 12,12 GET LINSERV2 PICT "@!"
   @ 13,12 GET LINSERV3 PICT "@!"
   @ 14,12 GET LINSERV4 PICT "@!"
   @ 15,12 SAY "Valor dos Servios :" GET VALMO PICT "@R 999,999,999.99" VALID(VALMO>0)
   READ
   RESTSCREEN(,,,,TELA2)
   IF LASTKEY()=27
      LOOP
   ENDIF
   @ 23,01 SAY PADL(" Total : "+TRANSFORM(VALMO,"@R 999,999,999.99")+" ",78) COLOR CORTIT
   X:=1
   ENT2:=ENT
   DO WHILE X<=PARCELAS
      IF ENT2="S"
         MDATE[X]=DATEMI
         ENT2:="N"
      ELSE
         IF X>1
            MDATE[X]=MDATE[X-1]+INTER
         ELSE
            MDATE[X]=DATEMI+INTER
         ENDIF
      ENDIF
      X++
   ENDDO
   X:=1
   COL:=2
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   DO WHILE .T.
      IF MDATE[X]=(NIL)
         EXIT
      ENDIF
      @ 20,COL+4 GET MDATE[X]
      VALPAR[X]:=VALMO/PARCELAS
      @ 21,COL GET VALPAR[X] PICT "@R 999,999,999.99"
      READ
      IF LASTKEY()=27
         @ 20,1 CLEAR TO 21,78
         EXIT
      ENDIF
      TOTAL:=TOTAL+VALPAR[X]
      X++
      COL=COL+15
   ENDDO
   IF LASTKEY()=27
      LOOP
   ENDIF
   IF ROUND(TOTAL,2)#ROUND(VALMO,2) .AND. TOTAL#VALMO
      AVISO("O Valor Total das Parcelas nao Conferem com o Valor Total da Nota ...")
      LOOP
   ENDIF
   IF ! CONFIRMA(20,20,"Confirma todos os dados ?")
      LOOP
   ENDIF
   IF CONFIRMA(20,20,"A impressora est  preparada ?")
      DBF_PAGREC()
      DBF_PLANO()
      DO WHILE .T.
         DBE_PLANO(10,5,20,50)
         IF LASTKEY()=27
            EXIT
         ENDIF
         IF LEFT(PLANO->CODIGO_V,1)#"+"
            AVISO(" Necess rio Selecionar Uma Conta Para Recebimentos")
            LOOP
         ELSE
            EXIT
         ENDIF
      ENDDO
      IF LASTKEY()=27
         LOOP
      ENDIF
      IF MDATE[1]#(NIL)
         PAGREC->(DBAPPEND())
         PAGREC->CODIGO_V:="R"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->(RLOCK())
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PAGREC->CLIFOR_V:=CLIFOR
         PAGREC->DOCINT_V:=STRZERO(NOTA,6,0)+"-A"
         PAGREC->DATINT_V:=DATEMI
         PAGREC->DATVEN_V:=MDATE[1]
         PAGREC->CODPLA_V:=PLANO->CODIGO_V
         PAGREC->DESC_V  :="DUPLICATA DE SERVICO"
         PAGREC->VALOR_V :=VALPAR[1]
         PAGREC->(DBUNLOCK())
      ENDIF
      IF MDATE[2]#(NIL)
         PAGREC->(DBAPPEND())
         PAGREC->CODIGO_V:="R"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->(RLOCK())
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PAGREC->CLIFOR_V:=CLIFOR
         PAGREC->DOCINT_V:=STRZERO(NOTA,6,0)+"-B"
         PAGREC->DATINT_V:=DATEMI
         PAGREC->DATVEN_V:=MDATE[2]
         PAGREC->CODPLA_V:=PLANO->CODIGO_V
         PAGREC->DESC_V  :="DUPLICATA DE SERVICO"
         PAGREC->VALOR_V :=VALPAR[2]
         PAGREC->(DBUNLOCK())
      ENDIF
      IF MDATE[3]#(NIL)
         PAGREC->(DBAPPEND())
         PAGREC->CODIGO_V:="R"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->(RLOCK())
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PAGREC->CLIFOR_V:=CLIFOR
         PAGREC->DOCINT_V:=STRZERO(NOTA,6,0)+"-C"
         PAGREC->DATINT_V:=DATEMI
         PAGREC->DATVEN_V:=MDATE[3]
         PAGREC->CODPLA_V:=PLANO->CODIGO_V
         PAGREC->DESC_V  :="DUPLICATA DE SERVICO"
         PAGREC->VALOR_V :=VALPAR[3]
         PAGREC->(DBUNLOCK())
      ENDIF
      IF MDATE[4]#(NIL)
         PAGREC->(DBAPPEND())
         PAGREC->CODIGO_V:="R"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->(RLOCK())
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PAGREC->CLIFOR_V:=CLIFOR
         PAGREC->DOCINT_V:=STRZERO(NOTA,6,0)+"-D"
         PAGREC->DATINT_V:=DATEMI
         PAGREC->DATVEN_V:=MDATE[4]
         PAGREC->CODPLA_V:=PLANO->CODIGO_V
         PAGREC->DESC_V  :="DUPLICATA DE SERVICO"
         PAGREC->VALOR_V :=VALPAR[4]
         PAGREC->(DBUNLOCK())
      ENDIF
      IF MDATE[5]#(NIL)
         PAGREC->(DBAPPEND())
         PAGREC->CODIGO_V:="R"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->(RLOCK())
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PAGREC->CLIFOR_V:=CLIFOR
         PAGREC->DOCINT_V:=STRZERO(NOTA,6,0)+"-E"
         PAGREC->DATINT_V:=DATEMI
         PAGREC->DATVEN_V:=MDATE[5]
         PAGREC->CODPLA_V:=PLANO->CODIGO_V
         PAGREC->DESC_V  :="DUPLICATA DE SERVICO"
         PAGREC->VALOR_V :=VALPAR[5]
         PAGREC->(DBUNLOCK())
      ENDIF
      PLANO->(DBCLOSEAREA())
      PAGREC->(DBCLOSEAREA())
      IF NOTA->(ADDREC(5))
         NOTA->CODIGO_V  :=NOTA
         NOTA->CLIFOR_V  :=CLIFOR
         NOTA->CODTRAN_V :=CODTRAN
         NOTA->CFOP_V    :=CFOP
         NOTA->DATEMI_V  :=DATEMI
         NOTA->DATSAI_V  :=DATSAI
         NOTA->HORASAI_V :=HORASAI
         NOTA->FRETE_V   :=FRETE
         NOTA->PLACA_V   :=PLACA
         NOTA->UF_V      :=UF
         NOTA->QTD_V     :=QUANT
         NOTA->ESPECIE_V :=ESPECIE
         NOTA->MARCA_V   :=MARCA
         NOTA->NUMERO_V  :=NUMERO
         NOTA->PESOBRU_V :=PESOBRU
         NOTA->PESOLIQ_V :=PESOLIQ
         NOTA->VALMO_V   :=VALMO
         NOTA->LINSERV1_V:=LINSERV1
         NOTA->LINSERV2_V:=LINSERV2
         NOTA->LINSERV3_V:=LINSERV3
         NOTA->LINSERV4_V:=LINSERV4
         NOTA->NOMSEN_V  :=NOMSEN
         IF MDATE[1]#(NIL)
            NOTA->DATPAR1_V:=MDATE[1]
            NOTA->VALPAR1_V:=VALPAR[1]
         ENDIF
         IF MDATE[2]#(NIL)
            NOTA->DATPAR2_V:=MDATE[2]
            NOTA->VALPAR2_V:=VALPAR[2]
         ENDIF
         IF MDATE[3]#(NIL)
            NOTA->DATPAR3_V:=MDATE[3]
            NOTA->VALPAR3_V:=VALPAR[3]
         ENDIF
         IF MDATE[4]#(NIL)
            NOTA->DATPAR4_V:=MDATE[4]
            NOTA->VALPAR4_V:=VALPAR[4]
         ENDIF
         IF MDATE[5]#(NIL)
            NOTA->DATPAR5_V:=MDATE[5]
            NOTA->VALPAR5_V:=VALPAR[5]
         ENDIF
         NOTA->(DBUNLOCK())
      ENDIF
      if config->nfs_v=="S"
      
      else
         DO WHILE ! ISPRINTER()
            AVISO("Impressora fora de linha ou nao conectada")
         ENDDO
         IMPNFSERV()
    	endif
      EXIT
   ENDIF
ENDDO
RESTSCREEN(,,,,TELA)
RETURN(.T.)

FUNCTION NFSERV1()
MEMVAR CLIFOR
@ 2,60 SAY IF(CLIFOR->(DBSEEK(CLIFOR)),LEFT(CLIFOR->NOME_V,18),SPACE(18))
RETURN(.T.)

FUNCTION IMPNFSERV()
LOCAL  VALBASE,VALICMS,MESSAGE,X,COL,ARQNF
MEMVAR PEDIDO

MEMVAR FRETE,PLACA,UF,QUANT,ESPECIE,MARCA,NUMERO,PESOBRU,PESOLIQ
MEMVAR NOTA,DATSAI,HORASAI,DATEMI

MEMVAR MDATE,VALPAR
VALBASE:=0
VALICMS:=0
MESSAGE:={,,,,,,,}
CLIFOR->(DBSETORDER(1))
ARQNF = "notas\nf"+strzero(nota,6,0)+".txt"
//SET PRINTER TO &ARQNF
SET PRINTER TO LPT1
SET DEVICE TO PRINTER
@ 0,0 SAY CHR(18)
@ 1,56   SAY "X"
@ 1,74   SAY STRZERO(NOTA,7,0)
@ 6,9    SAY IF(CFOP->(DBSEEK(NOTA->CFOP_V)),CFOP->MENSAGEM_V,SPACE(18))
@ 6,32   SAY NOTA->CFOP_V
@ PROW(),PCOL() SAY CHR(15)
@ 9,14   SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),CLIFOR->NOME_V,SPACE(50))
@ 9,95   SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),CLIFOR->CGCCPF_V,SPACE(19))
@ 9,132  SAY DTOC(NOTA->DATEMI_V)
@ 11,14  SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),CLIFOR->ENDERECO_V,SPACE(50))
@ 11,85  SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),LEFT(CLIFOR->BAIRRO_V,27),SPACE(27))
@ 11,115 SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),TRANSFORM(CLIFOR->CEP_V,"@R 99999-999"),SPACE(8))
@ 11,132 SAY DTOC(NOTA->DATSAI_V)
@ 13,14  SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),LEFT(CLIFOR->CIDADE_V,25),SPACE(25))
@ 13,87  SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),CLIFOR->ESTADO_V,SPACE(2))
@ 13,63  SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),TRANSFORM(CLIFOR->FONE1_V,"@R (##99) ##99-9999"),SPACE(12))
@ 13,95  SAY IF(CLIFOR->(DBSEEK(NOTA->CLIFOR_V)),CLIFOR->RGINSEST_V,SPACE(15))
@ 13,132 SAY NOTA->HORASAI_V
X:=1
COL:=14
DO WHILE .T.
   IF MDATE[X]=(NIL)
      EXIT
   ENDIF
   @ 15,COL+4 SAY MDATE[X]
   X++
   COL:=COL+20
ENDDO
X:=1
COL:=14
DO WHILE .T.
   IF MDATE[X]=(NIL)
      EXIT
   ENDIF
   @ 16,COL SAY VALPAR[X] PICT "999,999,999.99"
   X++
   COL:=COL+20
ENDDO
@ 37.5,14 SAY NOTA->LINSERV1_V
@ 38.5,14 SAY NOTA->LINSERV2_V
@ 39.5,14 SAY NOTA->LINSERV3_V
IF NOTA->VALMO_V*(5/100)>0
   @ 39.5,120 SAY NOTA->VALMO_V*(5/100) PICT "@R 999,999,999.99"
ENDIF
@ 40.5,14 SAY NOTA->LINSERV4_V
IF NOTA->VALMO_V>0
   @ 41.5,120 SAY NOTA->VALMO_V PICT "@R 999,999,999.99"
ENDIF
@ 42.8,40  SAY CONFIG->NFCOMPL_V
@ 44.8,120 SAY IF(NOTA->VALITOT_V>0,TRANSFORM(NOTA->VALITOT_V,"@R 999,999,999.99")," ")
@ 46.5,120 SAY IF((NOTA->VALITOT_V+NOTA->VALMO_V)>0,TRANSFORM(NOTA->VALITOT_V+NOTA->VALMO_V,"@R 999,999,999.99")," ")
@ 49.5,14  SAY IF(TRANSP->(DBSEEK(NOTA->CODTRAN_V)),TRANSP->NOME_V,SPACE(50))
@ 49.5,93  SAY NOTA->FRETE_V
@ 49.5,99  SAY NOTA->PLACA_V
@ 49.5,113 SAY NOTA->UF_V
@ 49.5,120 SAY IF(TRANSP->(DBSEEK(NOTA->CODTRAN_V)),TRANSP->CGC_V,SPACE(18))
@ 51.5,14  SAY IF(TRANSP->(DBSEEK(NOTA->CODTRAN_V)),LEFT(TRANSP->ENDERECO_V,30),SPACE(30))
@ 51.5,75  SAY IF(TRANSP->(DBSEEK(NOTA->CODTRAN_V)),LEFT(TRANSP->CIDADE_V,30),SPACE(30))
@ 51.5,113 SAY IF(TRANSP->(DBSEEK(NOTA->CODTRAN_V)),LEFT(TRANSP->ESTADO_V,30),SPACE(30))
@ 51.5,120 SAY IF(TRANSP->(DBSEEK(NOTA->CODTRAN_V)),TRANSP->INSEST_V,SPACE(15))
@ 53.5,14  SAY IF(NOTA->QTD_V#0,TRANSFORM(NOTA->QTD_V,"@R 999,999.99"),SPACE(2))
@ 53.5,36  SAY NOTA->ESPECIE_V
@ 53.5,59  SAY NOTA->MARCA_V
@ 53.5,76  SAY NOTA->NUMERO_V
@ 53.5,101 SAY NOTA->PESOBRU_V
@ 53.5,125 SAY NOTA->PESOLIQ_V
@ 0,PCOL() SAY CHR(18)+" "
//?? CHR(26)
SET PRINTER TO
SET DEVICE TO SCREEN
//SET PRINTER TO
//RUN("TYPE "+ARQNF+" > PRN")
RETURN(.T.)