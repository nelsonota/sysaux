FUNCTION APORTA()
LOCAL GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN

****** VARIAVEIS P/ CADASTRO DE PORTADORES
MEMVAR CODIGO,NOME
DO WHILE .T.
   @ 16,21 GET NOME PICT "@K!"
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Confirma Altera‡ao do Portador ?")
      IF PORTA->(RECLOCK(5))
         PORTA->NOME_V  :=NOME
         PORTA->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
   @ 15,21 CLEAR TO 16,42
ENDDO
RETURN(.T.)