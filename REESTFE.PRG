FUNCTION REESTFE(TIPO)
LOCAL  TELA,TELA2,X
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR LINHA
LINHA:={}
TELA:=SAVESCREEN()
DBF_CONFIG()
DBF_CLIFOR()
DBF_ESTOQUE()
ESTOQUE->(DBGOTOP())
WINDOW(10,0,23,79)
X:=0
DO WHILE ESTOQUE->(!EOF()) .AND. X<=4050
   @ 24,2 SAY ESTOQUE->CODIGO_V+" "+LEFT(ESTOQUE->NOME_V,33)+" "+TRANSFORM(ESTOQUE->QTD_V,"@R 99,999")+" "+TRANSFORM(ESTOQUE->FALTA_V,"@R 99,999")+"  "+TRANSFORM(ESTOQUE->EXCESSO_V,"@R 99,999")+"  "+TRANSFORM(ESTOQUE->RESERVA_V,"@R 99,999") COLOR CORTIT
   DO CASE
      CASE TIPO="FAL"
         IF ESTOQUE->QTD_V-ESTOQUE->RESERVA_V<ESTOQUE->FALTA_V
            AADD(LINHA," "+ESTOQUE->CODIGO_V+" "+LEFT(ESTOQUE->NOME_V,33)+" "+TRANSFORM(ESTOQUE->QTD_V,"@R 99,999")+" "+TRANSFORM(ESTOQUE->FALTA_V,"@R 99,999")+"  "+TRANSFORM(ESTOQUE->EXCESSO_V,"@R 99,999")+"  "+TRANSFORM(ESTOQUE->RESERVA_V,"@R 99,999"))
            @ 11,2 SAY ESTOQUE->CODIGO_V+" "+LEFT(ESTOQUE->NOME_V,33)+" "+TRANSFORM(ESTOQUE->QTD_V,"@R 99,999")+" "+TRANSFORM(ESTOQUE->FALTA_V,"@R 99,999")+"  "+TRANSFORM(ESTOQUE->EXCESSO_V,"@R 99,999")+"  "+TRANSFORM(ESTOQUE->RESERVA_V,"@R 99,999")
            TELA2:=SAVESCREEN(11,1,21,78)
            RESTSCREEN(12,1,22,78,TELA2)
            X++
         ENDIF
      CASE TIPO="EXC"
         IF ESTOQUE->QTD_V-ESTOQUE->RESERVA_V>ESTOQUE->EXCESSO_V .AND. ESTOQUE->EXCESSO_V>0
            AADD(LINHA," "+ESTOQUE->CODIGO_V+" "+LEFT(ESTOQUE->NOME_V,33)+" "+TRANSFORM(ESTOQUE->QTD_V,"@R 99,999")+" "+TRANSFORM(ESTOQUE->FALTA_V,"@R 99,999")+"  "+TRANSFORM(ESTOQUE->EXCESSO_V,"@R 99,999")+"  "+TRANSFORM(ESTOQUE->RESERVA_V,"@R 99,999"))
            @ 11,2 SAY ESTOQUE->CODIGO_V+" "+LEFT(ESTOQUE->NOME_V,33)+" "+TRANSFORM(ESTOQUE->QTD_V,"@R 99,999")+" "+TRANSFORM(ESTOQUE->FALTA_V,"@R 99,999")+"  "+TRANSFORM(ESTOQUE->EXCESSO_V,"@R 99,999")+"  "+TRANSFORM(ESTOQUE->RESERVA_V,"@R 99,999")
            TELA2:=SAVESCREEN(11,1,21,78)
            RESTSCREEN(12,1,22,78,TELA2)
            X++
         ENDIF
   ENDCASE
   ESTOQUE->(DBSKIP())
ENDDO
IF X>4050
   AVISO("Memória Insuficiente...")
ENDIF
RESTSCREEN(,,,,TELA)
CLOSEWIN(10,0,23,79)
WINDOW(2,0,23,79)
@ 3,1 SAY PADC("Relatório do estoque com itens em "+IF(TIPO="FAL","falta","excesso"),78) COLOR CORTIT
@ 4,1 SAY PADR(" Código       Descrićao                           Qtd.  Falta Excesso Reserva",78) COLOR CORTIT
@ 5,1 TO 5,78
@ 21,1 TO 21,78
@ 22,1 SAY PADR(" "+TRANSFORM(X,"@R 99,999")+" Itens",78) COLOR CORTIT
ACHOICE(6,1,20,78,LINHA,.T.,"RELACHOFUN")
IF CONFIRMA(20,20,"Deseja Imprimir ?")
   IMPREL("Relatorio do estoque com itens em "+IF(TIPO="FAL","falta","excesso")," Código       Descrićao                           Qtd.  Falta Excesso Reserva",50)
ENDIF
RESTSCREEN(,,,,TELA)
CLOSEWIN(10,0,23,79)
CONFIG->(DBCLOSEAREA())
CLIFOR->(DBCLOSEAREA())
ESTOQUE->(DBCLOSEAREA())
RETURN(.T.)