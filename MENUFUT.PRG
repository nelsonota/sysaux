FUNCTION MENUFUT()
LOCAL OPCOES,TELA,OP
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
TELA:=SAVESCREEN(0,0,24,80)
WINDOW(9,20,12,40)
DO WHILE .T.
   OPCOES:={"  Contas … Receber ",;
            "  Contas … Pagar   " }
   OP:=ACHOICE(10,21,11,39,OPCOES,.T.,"ACHOFUN")
   DO CASE
      CASE OP=1
         PAGREC("R")
      CASE OP=2
         PAGREC("P")
      OTHERWISE
         EXIT
   ENDCASE
ENDDO
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(9,20,12,40)
RETURN(.T.)