FUNCTION COMPENSA()
LOCAL TELA,GETLIST:={},CODBAN,TELA1,OP,LIN
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR CHEQUE,CHEQUES
TELA:=SAVESCREEN(0,0,24,80)
DBF_BANK()
DBF_CHEQUE()
WINDOW(11,18,16,45)
SETCOLOR(CORTIT)
@ 10,18 SAY "Compensa‡ao de Cheques"
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   CHEQUE:=SPACE(6)
   DO WHILE .T.
      DBE_BANK(10,5,20,75)
      IF LASTKEY()#27
         IF BANK->CODIGO_V=0
            AVISO("Selecione Um Banco")
            LOOP
         ENDIF
      ENDIF
      EXIT
   ENDDO
   IF LASTKEY()=27
      EXIT
   ENDIF
   CODBAN:=BANK->CODIGO_V
   CHEQUE->(DBSETORDER(1))
   CHEQUE->(DBSEEK(CODBAN))
   CHEQUES:={}
   LIN:=6
   DO WHILE CHEQUE->(.NOT. EOF()) .AND. CHEQUE->CODBAN_V=CODBAN
      IF ! EMPTY(CHEQUE->DATEMI_V) .AND. EMPTY(CHEQUE->DATBAI_V) .AND. UPPER(CHEQUE->OBS_V)#"CANCELADO"
         AADD(CHEQUES,CHEQUE->CHEQUE_V)
         LIN++
      ENDIF
      CHEQUE->(DBSKIP())
   ENDDO
   IF LIN>23
      LIN:=23
   ENDIF
   TELA1:=SAVESCREEN()
   WINDOW(5,60,LIN,68)
   OP:=ACHOICE(6,61,LIN-1,67,CHEQUES,.T.,"RELACHOFUN")
   RESTSCREEN(,,,,TELA1)
   CLOSEWIN(5,60,LIN,68)
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF EMPTY(CHEQUES)
      AVISO("Nao Existe Cheques … Compensar")
      LOOP
   ENDIF
   CHEQUE->(DBSETORDER(2))
   IF ! CHEQUE->(DBSEEK(CHEQUES[OP]))
      AVISO("Outro Terminal Deve ter Compensado")
      LOOP
   ENDIF
   @ 12,20 SAY "Banco   : "+BANK->NOME_V
   @ 13,20 SAY "Cheque  : " + CHEQUES[OP]
   READ
   @ 14,20 SAY "Emissao : "+DTOC(CHEQUE->DATEMI_V)
   @ 15,20 SAY "Valor   : "+TRANSFORM(CHEQUE->VALOR_V,"@R 999,999,999.99")
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Confirma Compensa‡ao do Cheque ?")
      IF BANK->(RECLOCK(5))
         BANK->SALDO_V:=BANK->SALDO_V-CHEQUE->VALOR_V
         BANK->(DBUNLOCK())
      ENDIF
      IF CHEQUE->(RECLOCK(5))
         CHEQUE->DATBAI_V:=TRABALHO
         CHEQUE->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
ENDDO
CHEQUE->(DBCLOSEAREA())
BANK->(DBCLOSEAREA())
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(11,18,16,45)
RETURN(.T.)