FUNCTION MSENHA()
LOCAL OP,TELA
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN,MECVEN

*** VARIAVEIS P/ REGISTRO DE SENHA
MEMVAR NOMSEN,SENHA,NIVEL,CODIGO
TELA:=SAVESCREEN(0,0,24,80)
WINDOW(12,31,14,79)
WINDOW(6,41,12,79)
@ 13,79 SAY CHR(219)
DBF_SENHA()
DBF_ACCCOM()
DBF_CONFIG()
DBF_MECVEN()
SENHA->(DBSEEK(CODSEN))
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   CODIGO:=SENHA->CODSEN_V
   NOMSEN:=SENHA->NOMSEN_V
   SENHA :=SENHA->SENHA_V
   NIVEL :=SENHA->LEVEL_V
   MECVEN:=SENHA->CODVEN_V
   @ 7 ,43 SAY "C˘digo   : " + STRZERO(CODIGO,5,0)
   @ 8 ,43 SAY "Nome     : " + NOMSEN
   @ 9 ,43 SAY "Senha    : " + IF(LEVEL#"NE",SENHA,DECRIP(SENHA))
   @ 10,43 SAY "Vendedor : " + MECVEN + ' ' + IF(MECVEN->(DBSEEK(MECVEN)),LEFT(MECVEN->NOME_V,15),SPACE(15))
   @ 11,43 SAY "Nˇvel    : " + NIVEL
   @ 13,32 PROMPT " Incluir "
   @ 13,41 PROMPT " Alterar "
   @ 13,50 PROMPT " Buscar "
   @ 13,58 PROMPT " Apagar "
   @ 13,66 PROMPT " Privilegios "
   MENU TO OP
   DO CASE
      CASE OP=1
         ISENHA()
      CASE OP=2
         ASENHA()
      CASE OP=3
         BSENHA()
      CASE OP=4
         IF CONFIRMA(20,20,"Confirma exclusao de usuario ?")
            IF SENHA->(RECLOCK(5))
               SENHA->(DBDELETE())
               SENHA->(DBUNLOCK())
            ENDIF
         ENDIF
      CASE OP=5
         PRIVIL()
      OTHERWISE
         EXIT
   ENDCASE
ENDDO
SENHA->(DBCLOSEAREA())
CONFIG->(DBCLOSEAREA())
ACCCOM->(DBCLOSEAREA())
MECVEN->(DBCLOSEAREA())
RESTSCREEN(0,0,24,80,TELA)
RETURN(.T.)