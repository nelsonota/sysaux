FUNCTION OUTRENT()
LOCAL TELA,NITEM,GETLIST := {},ARQTMP
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR CFOP,NOTACOM,PEDIDO,CLIFOR,MASCARAS,TITULOS,VARIAVEIS
MEMVAR AITENS,QTDITENS
TELA := SAVESCREEN()
DBF_CONFIG()
DBF_PEDIDO()
DBF_2PEDIDO()
DBF_ESTOQUE()
DBF_CLIFOR()
DBF_CFOP()
WINDOW(0,0,24,79)
@ 00,01 SAY "Outras Entradas de Estoque" COLOR CORTIT
NOTACOM := 0
CFOP := SPACE(LEN(PEDIDO->CFOP_V))
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   SCROLL(1,1,23,78,0)
   PEDIDO:="E"+STRZERO(CONFIG->PEDCOM_V+1,5,0)
   @ 01,02 SAY "Compra         : "+PEDIDO
   CLIFOR->(DBSETORDER(2))
   DBE_CLIFOR(5,10,15,70)
   @ 02,02 SAY "Fornecedor     : "+CLIFOR->NOME_V
   IF LASTKEY()=27
    EXIT
   ENDIF
   CLIFOR:=CLIFOR->CODIGO_V
   CLIFOR->(DBSETORDER(1))
   @ 3,2  SAY "Endereço   : "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->ENDERECO_V,SPACE(50))
   @ 4,2  SAY "Bairro     : "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->BAIRRO_V,SPACE(30))
   @ 4,45 SAY "C.E.P. : "+ IF(CLIFOR->(DBSEEK(CLIFOR)),TRANSFORM(CLIFOR->CEP_V,"99999-9"),SPACE(9))
   @ 5,2  SAY "Cidade     : "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->CIDADE_V,SPACE(30))
   @ 5,45 SAY "Estado : "+ IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->ESTADO_V,SPACE(2))
   @ 6,2  SAY "Telefone   : "+IF(CLIFOR->(DBSEEK(CLIFOR)),TRANSFORM(CLIFOR->FONE1_V,"@R (#99) #9999-9999"),SPACE(15))
   @ 6,45 SAY "CGC/CPF: "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->CGCCPF_V,SPACE(18))
   @ 7,2  SAY "RG/Ins.Est.: "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->RGINSEST_V,SPACE(15))
   @ 8,1 TO 8,78
   IF ! CONFIRMA(20,20,"Confirma o Fornecedor ?")
      LOOP
   ENDIF
   CLIFOR:=CLIFOR->CODIGO_V
   @ 01,26 SAY "Nota Fiscal:" GET NOTACOM PICT "99999999"
   @ 01,48 SAY "C.F.OP.:" GET CFOP VALID(LASTKEY()=5 .OR. SEA_CFOP(CFOP,3,25))
   READ
   IF LASTKEY()=27
      LOOP
   ENDIF
   @ 03,01 CLEAR TO 22,78
   AITENS:={" "}
   QTDITENS:=1
   @ 3,1 TO 3,78
   @ 04,01 SAY " Codigo       Descri‡ao               Vl.Unit rio     Qtd.   Vl.Total     ICMS" COLOR CORTIT
                *123456789012 123456789012345678901234 999,999.99 999.9999 999,999.99 999.9999
   KEYBOARD(CHR(22))
   ARQTMP := CRIADBFITEMTMP()
   IF EMPTY(ARQTMP)
      AVISO("O Sistema nao conseguiu criar o arquivo temporario")
      LOOP
   ENDIF
   DO WHILE .T.
         VARIAVEIS:={"TMP->ITEM_V",;
                     "IF(ESTOQUE->(DBSEEK(TMP->ITEM_V)),LEFT(ESTOQUE->NOME_V,20),SPACE(20))",;
                     "TMP->VALUNI_V",;
                     "TMP->QTD_V",;
                     "TMP->VALUNI_V * TMP->QTD_V",;
                     "TMP->ICMS_V"}
         MASCARAS :={"","","@R 99,999.99","999.9999","@R 999,999.99","@R 999.9999"}
         TITULOS  :={"Codigo","Descricao","Vl.Unit.","Qtd","Vl.Total","ICMS"}
      TMP->(DBEDIT(04,01,20,78,VARIAVEIS,"DBEOUTRENT",MASCARAS,TITULOS,CHR(220),CHR(219)))
      IF LASTKEY()=27
         EXIT
      ENDIF
   ENDDO
   TMP->(DBCLOSEAREA())
   FERASE(ARQTMP)
ENDDO
CONFIG->(DBCLOSEAREA())
CFOP->(DBCLOSEAREA())
PEDIDO->(DBCLOSEAREA())
PEDIDO2->(DBCLOSEAREA())
CLIFOR->(DBCLOSEAREA())
ESTOQUE->(DBCLOSEAREA())
RESTSCREEN(0,0,24,79,TELA)
RETURN NIL

FUNCTION DBEOUTRENT(nMode,Col)
LOCAL NRETVAL
LOCAL TELA
LOCAL GETLIST := {}
LOCAL TECLA := LASTKEY()
LOCAL ITEM,T_VALUNI,T_QTD,T_ICMS
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR AITENS,CFOP,NOTACOM,PEDIDO,CLIFOR,QTDITENS
#INCLUDE "INKEY.CH"
#INCLUDE "DBEDIT.CH"
NRETVAL := DE_CONT
DO CASE
   CASE nMode = DE_EXCEPT
      DO CASE
         CASE TECLA = K_ESC
            nRetVal := DE_ABORT
         CASE TECLA = K_RETURN
            *nRetVal := DE
         CASE TECLA = K_INS
            TELA := SAVESCREEN()
            DO WHILE .T.
               WINDOW(18,00,20,79)
               ITEM := SPACE(LEN(ESTOQUE->CODIGO_V))
               T_VALUNI := 0
               T_QTD := 0
               T_ICMS := 0
               @ 19,01 GET ITEM PICT "@K!" VALID(SEA_ESTOQUE(ITEM) .AND. CALCOUTENT(T_QTD,T_VALUNI))
               @ 19,40 GET T_VALUNI PICT "999,999.99" VALID(T_VALUNI>0 .AND. CALCOUTENT(T_QTD,T_VALUNI))
               @ 19,51 GET T_QTD PICT "999.9999" VALID(T_QTD>0 .AND. CALCOUTENT(T_QTD,T_VALUNI))
               @ 19,71 GET T_ICMS PICT "999,9999"
               READ
               IF LASTKEY() = 27
                  EXIT
               ENDIF
               IF TMP->(DBSETORDER(1),DBSEEK(ITEM))
                  AVISO("Este item ja foi incluido.")
               ENDIF
            ENDDO
            RESTSCREEN(0,0,24,79,TELA)
         OTHERWISE
            nRetVal := DE_CONT
      ENDCASE
ENDCASE
RETURN NRETVAL

FUNCTION CALCOUTENT(QTD,VALUNI)
MEMVAR CORDES
@19,14 SAY LEFT(ESTOQUE->NOME_V,24) COLOR CORDES
@19,60 SAY TRANSFORM(QTD*VALUNI,"@R 999,999.99") COLOR CORDES
RETURN .T.

FUNCTION CRIADBFITEMTMP()
LOCAL CAMPOS,ARQ
CAMPOS:={}
AADD(CAMPOS,{"ITEM_V"      ,"C",12,0 })
AADD(CAMPOS,{"VALOR_V"     ,"N",14,2 })
AADD(CAMPOS,{"QTD_V"       ,"N",6 ,0 })
AADD(CAMPOS,{"VALUNI_V"    ,"N",14,2 })
AADD(CAMPOS,{"ICMS_V"      ,"N",14,2 })
ARQ:=NOMETEMP()
DBCREATE(ARQ,CAMPOS)
IF ! FILE(ARQ+".DBF")
   RETURN ""
ENDIF
ABRIR(ARQ ,"ITEM_V" ,ARQ )
DBF_TMP(ARQ)
SET INDEX TO &ARQ
RETURN ARQ+".DBF"