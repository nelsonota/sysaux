FUNCTION REPAGREC()
LOCAL GETLIST:={},RTOTAL,PTOTAL,TELA,RTOTAL2,PTOTAL2,INICIO2,X
MEMVAR LINHA,INICIO,FIM
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
LINHA:={}
TELA:=SAVESCREEN(0,0,24,80)
WINDOW(10,10,12,60)
INICIO:=TRABALHO
FIM   :=TRABALHO
DBF_CONFIG()
DBF_PLANO()
DBF_PAGREC()
DBF_CLIFOR()
RTOTAL2:=0
PTOTAL2:=0
X:=0
DO WHILE .T.
   DATINIFIN("RelatÂrio de Totais  Pagar e  Receber")
   IF LASTKEY()=27
      EXIT
   ENDIF
   INICIO2:=INICIO
   PAGREC->(DBSETORDER(5))
   DO WHILE INICIO<=FIM .AND. X<=4090
      PAGREC->(DBSEEK(INICIO))
      PTOTAL:=0
      RTOTAL:=0
      DO WHILE PAGREC->DATVEN_V=INICIO
         DO CASE
            CASE LEFT(PAGREC->CODIGO_V,1)="R"
               RTOTAL:=RTOTAL+PAGREC->VALOR_V
            CASE LEFT(PAGREC->CODIGO_V,1)="P"
               PTOTAL:=PTOTAL+PAGREC->VALOR_V
         ENDCASE
         PAGREC->(DBSKIP())
      ENDDO
      RTOTAL2:=RTOTAL2+RTOTAL
      PTOTAL2:=PTOTAL2+PTOTAL
      AADD(LINHA," "+DTOC(INICIO)+"     "+TRANSFORM(RTOTAL,"@R 999,999,999.99")+"  "+TRANSFORM(PTOTAL,"@R 999,999,999.99"))
      X++
      INICIO++
   ENDDO
   WINDOW(3,0,22,79)
   SETCOLOR(CORTIT)
   @ 4,1 SAY PADC("Total de contas  pagar e  receber no perÀodo de "+DTOC(INICIO2)+"  "+DTOC(FIM),78)
   @ 6,1 CLEAR TO 6,78
   @ 6,1  SAY "  Data         Receber          Pagar"
   @ 21,1 CLEAR TO 21,78
   @ 21,1 SAY "  Totais    : "+TRANSFORM(RTOTAL2,"@R 999,999,999.99")+"  "+TRANSFORM(PTOTAL2,"@R 999,999,999.99")
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 5,1  TO 5,78
   @ 7,1  TO 7,78
   @ 20,1 TO 20,78
   ACHOICE(8,1,19,78,LINHA,.T.,"RELACHOFUN")
   IF CONFIRMA(20,20,"Deseja Imprimir o RelatÂrio ?")
      AADD(LINHA,REPLICATE("-",78))
      AADD(LINHA,"  Totais    : "+TRANSFORM(RTOTAL2,"@R 999,999,999.99")+"  "+TRANSFORM(PTOTAL2,"@R 999,999,999.99"))
      AADD(LINHA,REPLICATE("=",78))
      IMPREL("Total de contas  pagar e  receber no perÀodo de "+DTOC(INICIO2)+"  "+DTOC(FIM),"  Data         Receber          Pagar",52)
   ENDIF
   EXIT
ENDDO
PAGREC->(DBCLOSEAREA())
PLANO->(DBCLOSEAREA())
CLIFOR->(DBCLOSEAREA())
CONFIG->(DBCLOSEAREA())
RESTSCREEN(0,0,24,80,TELA)
RETURN(.T.)