FUNCTION RESTAURA()
LOCAL DRIVE,TELA,GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN,TRABALHO
TELA:=SAVESCREEN(0,0,24,80)
WINDOW(10,10,12,39)
DRIVE:=SPACE(1)
@ 11,12 SAY "Restaura‡ao Pelo Drive :" GET DRIVE PICT "@!" VALID(DRIVE$"AB")
READ
IF LASTKEY()=27
   RESTSCREEN(0,0,24,80,TELA)
   RETURN(.T.)
ENDIF
SETCOLOR("W/N")
CLS
IF FILE("ACCCOM.DBF") .AND. FILE("ACCCOM.DBT")
   ACCCOM->(DBCLOSEAREA())
ENDIF
RUN("PKUNZIP "+DRIVE+":\DATACOML *.DB? -S250596")
RESTSCREEN(0,0,24,80,TELA)
INDICE()
DBF_ACCCOM()
RETURN(.T.)