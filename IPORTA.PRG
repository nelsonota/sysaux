FUNCTION IPORTA()
LOCAL OP,GETLIST:={},TELA,TIPO
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN

****** VARIAVEIS P/ CADASTRO DE PORTADORES
MEMVAR CODIGO,NOME
CODIGO:=SPACE(LEN(PORTA->CODIGO_V))
NOME  :=SPACE(LEN(PORTA->NOME_V))
DO WHILE .T.
   @ 15,21 GET CODIGO VALID(!PORTA->(DBSEEK(CODIGO)))
   @ 16,21 GET NOME PICT "@K!"
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Confirma Inclusao do Portador ?")
      IF PORTA->(ADDREC(5))
         PORTA->CODIGO_V:=CODIGO
         PORTA->NOME_V  :=NOME
         PORTA->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
   @ 15,21 CLEAR TO 16,42
ENDDO
RETURN(.T.)