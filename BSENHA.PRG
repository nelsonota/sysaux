FUNCTION BSENHA()
LOCAL OP,TELA,GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN

*** VARIAVEIS P/ REGISTRO DE SENHA
MEMVAR NOMSEN,SENHA,NIVEL,CODIGO
TELA:=SAVESCREEN(0,0,24,80)
DO WHILE .T.
   @ 7,43 PROMPT "Cḃdigo "
   @ 8,43 PROMPT "Nome   "
   @ 9,43 PROMPT "Senha  "
   MENU TO OP
   RESTSCREEN(0,0,24,80,TELA)
   DO CASE
      CASE OP=1
         SENHA->(DBSETORDER(1))
         @ 7,52 GET CODIGO PICT "99999"
         READ
         SENHA->(DBSEEK(CODIGO))
      CASE OP=2
         SENHA->(DBSETORDER(2))
         @ 8,52 GET NOMSEN PICT "@!"
         READ
         SENHA->(DBSEEK(NOMSEN,.T.))
      CASE OP=3
         SENHA->(DBSETORDER(3))
         SENHA:=SPACE(0)
         SENHA:=CRIP(NEWGET(LEN(SENHA->SENHA_V),8,52))
         SENHA->(DBSEEK(SENHA))
      OTHERWISE
         EXIT
   ENDCASE
   DBE_SENHA(10,5,20,50)
   EXIT
ENDDO
RETURN(.T.)