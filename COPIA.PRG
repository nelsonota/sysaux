FUNCTION COPIA()
LOCAL DRIVE,TELA,GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN,TRABALHO
TELA:=SAVESCREEN(0,0,24,80)
WINDOW(10,10,12,44)
DRIVE:=SPACE(1)
@ 11,12 SAY "Cópia de Seguranća no Drive :" GET DRIVE PICT "@!" VALID(DRIVE$"AB")
READ
IF LASTKEY()=27
   RESTSCREEN(0,0,24,80,TELA)
   RETURN(.T.)
ENDIF
SETCOLOR("W/N")
CLS
IF FILE("ACCCOM.DBF") .AND. FILE("ACCCOM.DBT")
   ACCCOM->(DBCLOSEAREA())
ENDIF
RUN("PKZIP "+DRIVE+":\DATACOML *.DB? -EX -S250596 -&")
DBF_ACCCOM()
RESTSCREEN(0,0,24,80,TELA)
RETURN(.T.)