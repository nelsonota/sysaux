FUNCTION BANK()
LOCAL TELA,OP
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN

***** VARIAVEIS PARA CADASTRO DE BANCOS
MEMVAR CODIGO,NOME,CONTA,AGENCIA,SALDO
TELA:=SAVESCREEN(0,0,24,80)
WINDOW(15,8,17,43)
WINDOW(8,8,15,43)
@ 16,43 SAY CHR(219)
DBF_BANK()
DBF_CONFIG()
SETCOLOR(CORTIT)
@ 7,8 SAY "Bancos"
DO WHILE .T.
   SETCOLOR(CORTEX)
   CODIGO :=BANK->CODIGO_V
   NOME   :=BANK->NOME_V
   CONTA  :=BANK->CONTA_V
   AGENCIA:=BANK->AGENCIA_V
   SALDO  :=BANK->SALDO_V
   @ 09,10 SAY "Registrado por: "+BANK->NOMSEN_V
   @ 10,10 SAY "Código  : " + STRZERO(CODIGO,5,0)
   @ 11,10 SAY "Banco   : " + NOME
   @ 12,10 SAY "C/C     : " + CONTA
   @ 13,10 SAY "Agłncia : " + AGENCIA
   @ 14,10 SAY "Saldo   : " + TRANSFORM(SALDO,"@R 999,999,999.99")
   SETCOLOR(CORTEX+","+CORBAR)
   @ 16,9  PROMPT " Incluir "
   @ 16,18 PROMPT " Buscar "
   @ 16,26 PROMPT " Alterar "
   @ 16,35 PROMPT " Apagar "
   MENU TO OP
   DO CASE
      CASE OP=1
         IBANK()
      CASE OP=2
         BBANK()
      CASE OP=3
         ABANK()
      CASE OP=4
         EBANK()
      OTHERWISE
         EXIT
   ENDCASE
ENDDO
CONFIG->(DBCLOSEAREA())
BANK->(DBCLOSEAREA())
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(8,8,15,43)
RETURN(.T.)