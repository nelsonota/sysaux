FUNCTION RECHQPRE()
LOCAL GETLIST:={},X,TOTAL,TELA
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN
MEMVAR LINHA,INICIO,FIM
TELA:=SAVESCREEN()
DBF_CONFIG()
DBF_PAGREC()
DBF_CLIFOR()
INICIO:=TRABALHO
FIM   :=TRABALHO
WINDOW(10,10,12,60)
DO WHILE .T.
   DATINIFIN("Relat¢rio de Cheques Pr‚ Datados … Receber")
   IF LASTKEY()=27
      EXIT
   ENDIF
   LINHA:={}
   X:=0
   TOTAL:=0
   PAGREC->(DBSETORDER(5))
   PAGREC->(DBSEEK(INICIO,.T.))
   DO WHILE PAGREC->DATVEN_V>=INICIO .AND. PAGREC->DATVEN_V<=FIM .AND. X<4090 .AND. ! PAGREC->(EOF())
      IF ! EMPTY(PAGREC->COBCHQ_V)
         AADD(LINHA," "+IF(CLIFOR->(DBSEEK(PAGREC->CLIFOR_V)),LEFT(CLIFOR->NOME_V,20),SPACE(20))+;
                    " "+PAGREC->COBBANCO_V+" "+PAGREC->CBCODBAN_V+" "+PAGREC->COBCHQ_V+" "+;
                    PAGREC->COBAGEN_V+" "+PAGREC->COBCONTA_V+" "+TRANSFORM(PAGREC->VALOR_V,"@R 99,999.99")+" "+DTOC(PAGREC->DATVEN_V))
         TOTAL:=TOTAL+PAGREC->VALOR_V
         X++
      ENDIF
      PAGREC->(DBSKIP())
   ENDDO
   WINDOW(3,0,22,79)
   @ 4,1 SAY PADC("Cheques Pr‚ Datados",78) COLOR CORTIT
   @ 5,1 SAY " Nome                 Banco      Num. Cheque Ag.  Conta    Valor      Vencto. " COLOR CORTIT
   @ 6,1 TO 6,78
   @ 20,1 TO 20,78
   @ 21,1 SAY PADR(" Total   : "+TRANSFORM(TOTAL,"@R 999,999,999.99"),78) COLOR CORTIT
   ACHOICE(7,1,19,78,LINHA,.T.,"RELACHOFUN")
   IF CONFIRMA(20,20,"Deseja Imprimir ?")
      AADD(LINHA,REPLICATE("-",80))
      AADD(LINHA,"Total : "+TRANSFORM(TOTAL,"@R 999,999,999.99"))
      IMPREL("Cheques Pr‚-Datados"," Nome                 Banco      Num. Cheque Ag.  Conta    Valor      Vencto. ",49)
   ENDIF
   EXIT
ENDDO
RESTSCREEN(,,,,TELA)
CONFIG->(DBCLOSEAREA())
PAGREC->(DBCLOSEAREA())
CLIFOR->(DBCLOSEAREA())
RETURN(.T.)