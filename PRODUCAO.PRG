FUNCTION PRODUCAO()
LOCAL TELA,PROD,QTD,VALCUS,TELA2
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,INSMUN,NOMSEN
MEMVAR ITEM,MECVEN,M_ITEM,M_QTD,M_CUS,CONT,DATA,TOTAL,GETLIST
TELA:=SAVESCREEN()
WINDOW(0,0,24,79)
CONT:=.T.
DBF_CONFIG()
DBF_PROD()
DBF_PROD2()
DBF_ESTOQUE()
DBF_CLIFOR()
DBF_MECVEN()
DBF_DEFMAT()
SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
DO WHILE .T.
   MECVEN:=SPACE(LEN(MECVEN->CODIGO_V))
   DATA:=DATE()
   PROD:=CONFIG->PRODUCAO_V+1
   @ 1,2 SAY "Produ놹o : "+STRZERO(PROD,7,0)
   @ 2,2 SAY "T괹nico  :" GET MECVEN PICT "@!" VALID(SEA_MECVEN(MECVEN,2,20))
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   @ 3,1 TO 3,78
   @ 4,1 SAY PADR(" C줰igo       Descri놹o                        Custo Unit. Qtd.   Custo Total ",78) COLOR CORTIT
   M_ITEM:={}
   M_QTD:={}
   M_CUS:={}
   TOTAL:=0
   SETCOLOR(CORDES)
   @ 5,2  CLEAR TO 22,13
   @ 5,15 CLEAR TO 22,47
   @ 5,49 CLEAR TO 22,58
   @ 5,60 CLEAR TO 22,66
   @ 5,68 CLEAR TO 22,77
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 23,1 TO 23,78
   @ 24,1 SAY PADR(" ESC: Cancela   F2: Finaliza",78) COLOR CORTIT
   DO WHILE .T.
      ITEM:=SPACE(LEN(ESTOQUE->CODIGO_V))
      QTD:=0
      VALCUS:=0
      SETCOLOR(CORDES)
      @ 5,15 CLEAR TO 5,47
      @ 5,68 CLEAR TO 5,77
      SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
      @ 5,2 GET ITEM PICT "@!" VALID(SEA_ESTOQUE(ITEM).AND.PROD1(ITEM))
      @ 5,49 GET VALCUS PICT "@R 999,999.99" VALID(PROD2(VALCUS,QTD))
      @ 5,60 GET QTD PICT "@R 999,999" VALID(PROD2(VALCUS,QTD))
      READ
      IF LASTKEY()=27
         EXIT
      ENDIF
      IF CONT=.F.
         EXIT
      ENDIF
      IF ! CONFIRMA(20,20,"Confirma este item ?!")
         LOOP
      ENDIF
      TELA2:=SAVESCREEN(5,1,21,78)
      RESTSCREEN(6,1,22,78,TELA2)
      SET KEY -1 TO FINALPROD()
      @ 24,1 SAY PADR(" ESC: Cancela   F2: Finaliza",78) COLOR CORTIT
      AADD(M_ITEM,ITEM)
      AADD(M_QTD,QTD)
      AADD(M_CUS,VALCUS)
      TOTAL:=TOTAL+(QTD*VALCUS)
   ENDDO
   IF LASTKEY()=27
      LOOP
   ENDIF
   EXIT
ENDDO
CONFIG->(DBCLOSEAREA())
PROD->(DBCLOSEAREA())
PROD2->(DBCLOSEAREA())
CLIFOR->(DBCLOSEAREA())
ESTOQUE->(DBCLOSEAREA())
MECVEN->(DBCLOSEAREA())
DEFMAT->(DBCLOSEAREA())
RESTSCREEN(,,,,TELA)
CLOSEWIN(0,0,24,79)
RETURN(.T.)

FUNCTION PROD1(CODIGO)
MEMVAR CORDES
@ 5,15 SAY LEFT(ESTOQUE->NOME_V,33) COLOR CORDES
IF ! DEFMAT->(DBSEEK(CODIGO))
   AVISO("Item sem defini놹o de material")
   RETURN(.F.)
ENDIF
RETURN(.T.)

FUNCTION PROD2(VALOR,QTD)
MEMVAR CORDES
@ 5,68 SAY TRANSFORM(VALOR*QTD,"@R 999,999.99") COLOR CORDES
RETURN(.T.)

FUNCTION FINALPROD()
LOCAL  CODIGO,X
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,INSMUN,NOMSEN
MEMVAR ITEM,MECVEN,M_ITEM,M_QTD,M_CUS,CONT,TOTAL,DATA,GETLIST
CLEAR GETS
IF ! CONFIRMA(20,20,"Concluir produ놹o ?")
   RETURN(.T.)
ENDIF
SET KEY -1 TO
CONT:=.F.
X:=1
AADD(M_ITEM,)
DO WHILE M_ITEM[X]#NIL
   IF ! DEFMAT->(DBSEEK(M_ITEM[X])) .OR. ! ESTOQUE->(DBSEEK(M_ITEM[X]))
      X++
      LOOP
   ENDIF
   DO WHILE DEFMAT->ITEM_V==M_ITEM[X] .AND. ! DEFMAT->(EOF())
      IF ! ESTOQUE->(DBSEEK(DEFMAT->CODIGO_V))
         DEFMAT->(DBSKIP())
         LOOP
      ENDIF
      movest("S",estoque->codigo_v, "PR", (DEFMAT->QTD_V*M_QTD[X]), "")
      DEFMAT->(DBSKIP())
   ENDDO
   movest("E",estoque->codigo_v, "PR", M_QTD[X], "")
   X++
ENDDO
X:=1
IF CONFIG->(RECLOCK())
   CODIGO:=CONFIG->PRODUCAO_V+1
   CONFIG->PRODUCAO_V:=CODIGO
ENDIF
IF PROD->(ADDREC())
   PROD->CODIGO_V:=CODIGO
   PROD->MECVEN_V:=MECVEN
   PROD->DATA_V  :=DATA
   PROD->VALTOT_V:=TOTAL
   PROD->(DBUNLOCK())
ENDIF
DO WHILE M_ITEM[X]#NIL
   IF PROD2->(ADDREC())
      PROD2->CODIGO_V:=CODIGO
      PROD2->ITEM_V  :=M_ITEM[X]
      PROD2->VALCUS_V:=M_CUS[X]
      PROD2->QTD_V   :=M_QTD[X]
      PROD2->VALTOT_V:=M_QTD[X]*M_CUS[X]
      PROD2->(DBUNLOCK())
   ENDIF
   X++
ENDDO
RETURN(.T.)