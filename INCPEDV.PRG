FUNCTION INCPEDV()
LOCAL TELA
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN
MEMVAR BLQVEN,SYSVEN
MEMVAR MECVEN
TELA:=SAVESCREEN()
WINDOW(0,0,24,79)
DBF_MECVEN()
DO WHILE .T.
   MECVEN := SYSVEN
   IF .NOT. MECVEN->(DBSEEK(MECVEN))

   ENDIF
   @ 01,02 SAY "Vendedor: "+MECVEN->CODIGO_V+"-"+MECVEN->NOME_V
ENDDO
MECVEN->(DBCLOSEAREA())
CLOSEWIN(0,0,24,79)
RESTSCREEN(,,,,TELA)
RETURN NIL