@ PROW()+1,0 SAY CLIFOR->CODIGO_V+' '+IF(CLIFOR->(DBSETORDER(1),DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->NOME_V,SPACE(50))
@ PROW()+1,0 SAY IF(CLIFOR->(DBSETORDER(1),DBSEEK(PEDIDO->CLIFOR_V)),alltrim(CLIFOR->ENDERECO_V)+" "+alltrim(clifor->numero_v)+" "+alltrim(clifor->complem_v),SPACE(50))
