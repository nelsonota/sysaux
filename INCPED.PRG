         @ PROW()  ,IF(CONFIG->IMPCVEN_V="N",38,51) SAY PEDIDO2->VALUNI_V PICT "@R 9,999.99"
         @ PROW()  ,IF(CONFIG->IMPCVEN_V="N",47,60) SAY PEDIDO2->QTD_V    PICT "@R 9,999.99"
         @ PROW()  ,IF(CONFIG->IMPCVEN_V="N",56,69) SAY PEDIDO2->VALUNI_V*PEDIDO2->QTD_V PICT "@R 999,999.99"
