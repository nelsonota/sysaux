@ PROW()+1,0 SAY IF(CLIFOR->(DBSETORDER(1),DBSEEK(PEDIDO->CLIFOR_V)),TRANSFORM(CLIFOR->CEP_V,"@R 99999-999"),SPACE(9))
@ PROW(),10  SAY IF(CLIFOR->(DBSETORDER(1),DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->CIDADE_V,SPACE(30))
@ PROW(),42  SAY IF(CLIFOR->(DBSETORDER(1),DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->ESTADO_V,SPACE(2))
@ PROW()+1,0 SAY IF(CLIFOR->(DBSETORDER(1),DBSEEK(PEDIDO->CLIFOR_V)),TRANSFORM(CLIFOR->FONE1_V,"@R (#999) 9999-9999"),SPACE(15))
@ PROW(),17  SAY IF(CLIFOR->(DBSETORDER(1),DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->CGCCPF_V,SPACE(18))
@ PROW(),37  SAY IF(CLIFOR->(DBSETORDER(1),DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->RGINSEST_V,SPACE(15))
IF LEFT(PEDIDO,1)="V"
   @ PROW()+1,0 SAY "Entrega: "
   @ PROW()+1,0 SAY IF(CLIFOR->(DBSETORDER(1),DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->ENDENT_V,SPACE(50))
   @ PROW(),50  SAY IF(CLIFOR->(DBSETORDER(1),DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->BAIENT_V,SPACE(30))
   @ PROW()+1,0 SAY IF(CLIFOR->(DBSETORDER(1),DBSEEK(PEDIDO->CLIFOR_V)),TRANSFORM(CLIFOR->CEPENT_V,"@R 99999-999"),SPACE(9))
   @ PROW(),10  SAY IF(CLIFOR->(DBSETORDER(1),DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->CIDENT_V,SPACE(30))
   @ PROW(),42  SAY IF(CLIFOR->(DBSETORDER(1),DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->ESTENT_V,SPACE(2))
ENDIF
@ PROW()+1,0 SAY REPLICATE("-",79)
IF ! EMPTY(PEDIDO->DATPAG_V)
   @ PROW()+1,0 SAY DTOC(PEDIDO->DATPAG_V)+" "+DTOC(PEDIDO->DATPAG1_V)+" "+DTOC(PEDIDO->DATPAG2_V)+" "+DTOC(PEDIDO->DATPAG3_V)+" "+DTOC(PEDIDO->DATPAG4_V)
   @ PROW()+1,0 SAY TRANSFORM(PEDIDO->VALPAR_V,"@R 999,999.99")+" "+TRANSFORM(PEDIDO->VALPAR1_V,"@R 999,999.99")+" "+TRANSFORM(PEDIDO->VALPAR2_V,"@R 999,999.99")+" "+TRANSFORM(PEDIDO->VALPAR3_V,"@R 999,999.99")+" "+TRANSFORM(PEDIDO->VALPAR4_V,"@R 999,999.99")
   @ PROW()+1,0 SAY PEDIDO->DOCEXT_V+" "+PEDIDO->DOCEXT1_V+" "+PEDIDO->DOCEXT2_V+" "+PEDIDO->DOCEXT3_V+" "+PEDIDO->DOCEXT4_V
ENDIF
@ PROW()+1,0 SAY REPLICATE("-",79)
IF LEFT(PEDIDO,1)="V"
   IF CONFIG->MODPED_V=2
      IF CONFIG->IMPCVEN_V="N"
         @ PROW()+1,0 SAY "It Quantidade Un Descricao                          Vl.Unit.  V.Total " COLOR CORTIT
      ELSE
         @ PROW()+1,0 SAY "It Cod.    Quantidade Un Descricao                            Vl.Unit.  V.Total " COLOR CORTIT
      ENDIF
   ELSEIF CONFIG->MODPED_V=3
      IF CONFIG->IMPCVEN_V="N"
         @ PROW()+1,0 SAY "It Quantidade Un Descricao                       Vl.Unit.  V.Total " COLOR CORTIT
      ELSE
         @ PROW()+1,0 SAY "It Cod.       Quantidade Un Descricao                         Vl.Unit.  V.Total " COLOR CORTIT
      ENDIF
   ELSEIF CONFIG->MODPED_V=4
      IF CONFIG->IMPCVEN_V="N"
         @ PROW()+1,0 SAY "Descricao                          Vl.Unitario      Qtd    V.Total" COLOR CORTIT
      ELSE
         @ PROW()+1,0 SAY "Codigo       Descricao                          Vl.Unitario      Qtd    V.Total" COLOR CORTIT
      ENDIF
   ELSE
      IF CONFIG->IMPCVEN_V="N"
         @ PROW()+1,0 SAY "Descricao                     Loc. Vl.Unitario      Qtd    V.Total" COLOR CORTIT
      ELSE
         @ PROW()+1,0 SAY "Codigo       Descricao                     Loc. Vl.Unitario      Qtd    V.Total" COLOR CORTIT
