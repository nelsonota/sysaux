FUNCTION PEDIDO(TIPO)
LOCAL  TELA,TELA2,X,CAMPOS,ANTORDEM,ARQ
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN
MEMVAR SYSVEN,BLQVEN
*** VARIAVEIS DO MODULO COMPRA/VENDA DIRETO
MEMVAR PEDIDO,CLIFOR,CODIGO,VALOR,QTD,ICMS,IPI,GETLIST,T,PEDCLI
MEMVAR ITEM,T_VALUNI,T_QTD,T_ICMS,TOTAL,CONT,MECVEN,T_BASCAL,BASCAL,O_BASCAL
MEMVAR T_TBASCAL,TBASCAL,O_TBASCAL,T_IPI,T_VALIPI,VALIPI,MODULO
MODULO:="pedido"
TELA:=SAVESCREEN()
T:=TIPO
X:=0
DBF_CONFIG()
DBF_PEDIDO()
DBF_2PEDIDO()
DBF_ESTOQUE()
DBF_CLIFOR()
DBF_MOEDA()
DBF_SYSTEM()
IF TIPO="V"
   DBF_MECVEN()
   DBF_BASCAL()
ENDIF
WINDOW(0,0,24,79)
@ 00,01 SAY IF(TIPO="V","Venda","Compra")+" por Pedido : Inclusao de Pedidos"  COLOR CORTIT
CONT    :=.F.
CLIFOR  :=SPACE(LEN(PEDIDO->CLIFOR_V))
MECVEN  :=IF(BLQVEN="N" .OR. TIPO="C",SPACE(LEN(PEDIDO->MECVEN_V)),SYSVEN)
ITEM    :=SPACE(LEN(ESTOQUE->CODIGO_V))
PEDCLI  :=SPACE(LEN(PEDIDO->PEDCLI_V))
T_QTD   :=0
T_VALUNI:=0
T_ICMS  :=CONFIG->DEFICMS_V
T_IPI   :=0
T_VALIPI:=0
IF T="V"
   T_BASCAL:=0
   T_TBASCAL:=""
   BASCAL  :={}
   TBASCAL :={}
ENDIF
TOTAL   :=0
CODIGO  :={}
VALOR   :={}
QTD     :={}
ICMS    :={}
IPI     :={}
VALIPI  :={}
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   DO CASE
      CASE TIPO="V"
         PEDIDO:="V"+STRZERO(CONFIG->PEDVEN_V+1,5,0)
      CASE TIPO="C"
         PEDIDO:="C"+STRZERO(CONFIG->PEDCOM_V+1,5,0)
      OTHERWISE
         EXIT
   ENDCASE
   @ 01,02 SAY "Pedido     : "+PEDIDO
   IF TIPO="V"
      SET KEY -2 TO T_CLIFOR()
      @ 01,22 SAY "Pedido Cliente :" GET PEDCLI
      @ 01,50 SAY "Vendedor :" GET MECVEN VALID(LASTKEY()=5.OR.SEA_MECVEN(MECVEN,1,68,"V")) WHEN BLQVEN="N"
   ENDIF
   @ 02,02 SAY IF(TIPO="V","Cliente    :","Fornecedor :") GET CLIFOR VALID(IF(TIPO="V",SEA_CLIFOR(CLIFOR,2,22,"C",IF(MECVEN->ALLCLI_V="S",NIL,MECVEN)),SEA_CLIFOR(CLIFOR,2,22,"F")))
   READ
   SET KEY -2 TO
   @ 1,78 SAY " "+CHR(219)
   IF LASTKEY()=27
      EXIT
   ENDIF
   CLIFOR->(DBSETORDER(1))
   @ 3,2  SAY "Endereco   : "+IF(CLIFOR->(DBSEEK(CLIFOR)),alltrim(CLIFOR->ENDERECO_V)+" "+alltrim(clifor->numero_v)+" "+alltrim(clifor->complem_v),SPACE(50))
   @ 4,2  SAY "Bairro     : "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->BAIRRO_V,SPACE(30))
   @ 4,45 SAY "C.E.P. : "+ IF(CLIFOR->(DBSEEK(CLIFOR)),TRANSFORM(CLIFOR->CEP_V,"99999-9"),SPACE(9))
   @ 5,2  SAY "Cidade     : "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->CIDADE_V,SPACE(30))
   @ 5,45 SAY "Estado : "+ IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->ESTADO_V,SPACE(2))
   @ 6,2  SAY "Telefone   : "+IF(CLIFOR->(DBSEEK(CLIFOR)),TRANSFORM(CLIFOR->FONE1_V,"@R (#999) 9999-9999"),SPACE(15))
   @ 6,45 SAY "CGC/CPF: "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->CGCCPF_V,SPACE(18))
   @ 7,2  SAY "RG/Ins.Est.: "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->RGINSEST_V,SPACE(15))
   @ 8,1 TO 8,78
   IF ! CONFIRMA(20,20,"Confirma o Cliente ?")
      @ 03,01 CLEAR TO 08,78
      LOOP
   ENDIF
   IF TIPO="V"
      IF ! EMPTY(CLIFOR->BLACK_V)
         AVISO("Este Cliente est  Cadastrado na Lista Negra ...")
         IF CONFIRMA(20,20,"Deseja Visualizar o Texto ?")
            TELA2:=SAVESCREEN()
            SETCOLOR(CORTIT)
            @ 8,5 SAY "Lista Negra"
            WINDOW(9,5,16,75)
            SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
            MEMOEDIT(CLIFOR->BLACK_V,10,6,15,74,.F.)
            RESTSCREEN(,,,,TELA2)
            CLOSEWIN(9,0,21,79)
         ENDIF
         IF ! CONFIRMA(20,20,"Continua Opera‡ao ?")
            EXIT
         ENDIF
      ENDIF
   ENDIF
   SETCOLOR(CORTEX)
   @ 03,01 CLEAR TO 08,78
   IF TIPO="V"
      O_BASCAL:=""
      O_TBASCAL:=""
   *   IF BASCAL->(DBSEEK(CLIFOR->ESTADO_V))
   *      O_BASCAL:=BASCAL->BASCAL_V
   *      O_TBASCAL:=BASCAL->MENSAGEM_V
   *   ELSE
   *      AVISO("Impossˇvel realizar a venda para este cliente sem conhecer o seu Estado")
   *      LOOP
   *   ENDIF
   ENDIF
   CONT:=.T.
   EXIT
ENDDO
IF CONT=.T.
   SETCOLOR(CORDES)
   IF T="V"
      @ 05,02 CLEAR TO 21,13
      @ 05,15 CLEAR TO 21,45
      @ 05,47 CLEAR TO 21,55
      @ 05,57 CLEAR TO 21,64
      @ 05,66 CLEAR TO 21,77   
   ELSE
      @ 05,02 CLEAR TO 21,13
      @ 05,15 CLEAR TO 21,37
      @ 05,39 CLEAR TO 21,49
      @ 05,51 CLEAR TO 21,60
      @ 05,62 CLEAR TO 21,71
      @ 05,73 CLEAR TO 21,74
      @ 05,76 CLEAR TO 21,77
   ENDIF
ENDIF
ANTORDEM:=PEDIDO->(ORDNUMBER())
TELA2:=SAVESCREEN()
DO WHILE .T.
   @ 24,0 SAY PADC("Aguarde, verificando os Łltimos pedidos",80) COLOR CORTIT
   CAMPOS:={}
   AADD(CAMPOS,{"CODIGO_V"  ,"C",12,0 })
   AADD(CAMPOS,{"NOME_V"    ,"C",50,0 })
   AADD(CAMPOS,{"VALUNI_V"  ,"N",14,2 })
   AADD(CAMPOS,{"QTD_V"     ,"N",14,2 })
   AADD(CAMPOS,{"PEDIDO_V"  ,"C",6 ,0 })
   AADD(CAMPOS,{"DATEMI_V"  ,"D",8 ,0 })
   AADD(CAMPOS,{"DATPAG_V"  ,"D",8 ,0 })
   AADD(CAMPOS,{"DATPAG1_V" ,"D",8 ,0 })
   AADD(CAMPOS,{"DATPAG2_V" ,"D",8 ,0 })
   AADD(CAMPOS,{"DATPAG3_V" ,"D",8 ,0 })
   AADD(CAMPOS,{"DATPAG4_V" ,"D",8 ,0 })
   AADD(CAMPOS,{"DOCEXT_V"  ,"C",10,0 })
   AADD(CAMPOS,{"DOCEXT1_V" ,"C",10,0 })
   AADD(CAMPOS,{"DOCEXT2_V" ,"C",10,0 })
   AADD(CAMPOS,{"DOCEXT3_V" ,"C",10,0 })
   AADD(CAMPOS,{"DOCEXT4_V" ,"C",10,0 })
   ARQ:=NOMETEMP()
   DBCREATE(ARQ,CAMPOS)
   IF ! FILE(ARQ+".DBF")
      AVISO("O Sistema nao conseguiu criar o arquivo temporario")
      LOOP
   ENDIF
   DBF_TMP(ARQ)
   INDEX ON TMP->DATEMI_V TO &ARQ
   EXIT
ENDDO
/*PEDIDO->(DBSETORDER(2),DBSEEK(CLIFOR->CODIGO_V))
DO WHILE PEDIDO->CLIFOR_V==CLIFOR->CODIGO_V .AND. .NOT. PEDIDO->(EOF())
   IF EMPTY(PEDIDO->DATPAG_V)
   PEDIDO->(DBSKIP())
      LOOP
   ENDIF
   PEDIDO2->(DBSETORDER(1),DBSEEK(PEDIDO->CODIGO_V))
   DO WHILE PEDIDO2->CODIGO_V==PEDIDO->CODIGO_V .AND. .NOT. PEDIDO2->(EOF())
      DO WHILE ! TMP->(ADDREC(5));ENDDO
      TMP->CODIGO_V  := PEDIDO2->ITEM_V
      TMP->NOME_V    := IF(ESTOQUE->(DBSETORDER(1),DBSEEK(PEDIDO2->ITEM_V)),ESTOQUE->NOME_V,'')
      TMP->VALUNI_V  := PEDIDO2->VALUNI_V
      TMP->QTD_V     := PEDIDO2->QTD_V
      TMP->PEDIDO_V  := PEDIDO->CODIGO_V
      TMP->DATEMI_V  := PEDIDO->DATEMI_V
      TMP->DATPAG_V  := PEDIDO->DATPAG_V
      TMP->DATPAG1_V := PEDIDO->DATPAG1_V
      TMP->DATPAG2_V := PEDIDO->DATPAG2_V
      TMP->DATPAG3_V := PEDIDO->DATPAG3_V
      TMP->DATPAG4_V := PEDIDO->DATPAG4_V
      TMP->DOCEXT_V  := PEDIDO->DOCEXT_V
      TMP->DOCEXT1_V := PEDIDO->DOCEXT1_V
      TMP->DOCEXT2_V := PEDIDO->DOCEXT2_V
      TMP->DOCEXT3_V := PEDIDO->DOCEXT3_V
      TMP->DOCEXT4_V := PEDIDO->DOCEXT4_V
      TMP->(DBCOMMIT(),DBUNLOCK())
      PEDIDO2->(DBSKIP())
   ENDDO
   PEDIDO->(DBSKIP())
ENDDO
PEDIDO->(DBSETORDER(ANTORDEM))*/
RESTSCREEN(0,0,24,79,TELA2)
DO WHILE CONT=.T. .AND. X<26
   SETCOLOR(CORDES)
   IF T="V"
      @ 05,02 CLEAR TO 05,13
      @ 05,15 CLEAR TO 05,45
      @ 05,47 CLEAR TO 05,55
      @ 05,57 CLEAR TO 05,64
      @ 05,66 CLEAR TO 05,77
   ELSE
      @ 05,02 CLEAR TO 05,13
      @ 05,15 CLEAR TO 05,37
      @ 05,39 CLEAR TO 05,49
      @ 05,51 CLEAR TO 05,60
      @ 05,62 CLEAR TO 05,71
      @ 05,73 CLEAR TO 05,74
      @ 05,76 CLEAR TO 05,77
   ENDIF
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 3,1 TO 3,78
   @ 22,1 TO 22,78
   IF T="V"
      @ 04,01 SAY PADR(" C˘digo       Descri‡ao                       Vl.Unit.  Qtd.     Vl.Total",78) COLOR CORTIT
      @ 23,01 SAY PADL("Valor Total dos Itens : "+TRANSFORM(TOTAL,"@R 999,999,999.99")+" ",78) COLOR CORTIT
   ELSE
      @ 04,01 SAY " C˘digo       Descri‡ao               Vl.Unit rio Qtd.       Vl.Total ICMS IPI" COLOR CORTIT
      @ 23,01 SAY PADL("Valor Total do IPI : "+TRANSFORM(T_VALIPI,"@R 999,999.99")+"       Valor Total dos Itens : "+TRANSFORM(TOTAL,"@R 999,999,999.99")+" ",78) COLOR CORTIT
   ENDIF
   SET KEY -9 TO ULTIMACOMPRA()
   //@ 24,01 SAY "ESC - Cancela Opera‡ao   F2 - Finaliza   F10 - éltima Compra"
   @ 24,01 SAY "ESC - Cancela Operacao   F2 - Finaliza"
   @ 05,02 GET ITEM PICT "@K!" VALID(SEA_ESTOQUE(ITEM).AND.PEDIDO1())
   IF T="V"
      @ 05,47 GET T_VALUNI PICT "@R 99,999.99" VALID(LASTKEY()=5 .OR. T_VALUNI>0 .AND. PRECOVALID(T_VALUNI) .AND. PEDIDO2())
      @ 05,57 GET T_QTD    PICT "@R 9,999.99" VALID(LASTKEY()=5 .OR. T_QTD>0 .AND. PEDIDO2() .AND. AVISOEST(TIPO,T_QTD))
   ELSE
      @ 05,39 GET T_VALUNI PICT "@R 99,999.9999" VALID(LASTKEY()=5 .OR. T_VALUNI>0 .AND. PEDIDO2())
      @ 05,51 GET T_QTD    PICT "@R 999,999.99" VALID(LASTKEY()=5 .OR. T_QTD>0 .AND. PEDIDO2() .AND. AVISOEST(TIPO,T_QTD))
      @ 05,73 GET T_ICMS   PICT "@R 99"
      @ 05,76 GET T_IPI    PICT "@R 99" VALID(PEDIDO2())
   ENDIF
   READ
   IF LASTKEY()=27
      IF CONFIRMA(20,20,"Deseja realmente cancelar a opera‡ao ?")
         EXIT
      ENDIF
      LOOP
   ENDIF
   IF LASTKEY()=18 .OR. LASTKEY()=3
      LOOP
   ENDIF
   IF CONT=.F.
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Confirma este Item ?")
      X:=X+1
      AADD(CODIGO,ITEM)
      AADD(QTD,T_QTD)
      AADD(VALOR,T_VALUNI)
      AADD(ICMS,T_ICMS)
      IF T="V"
         AADD(BASCAL,T_BASCAL)
         AADD(TBASCAL,T_TBASCAL)
      ELSE
         AADD(IPI,T_IPI)
         AADD(VALIPI,(T_QTD*T_VALUNI)*(T_IPI/100))
      ENDIF
      IF TIPO="V"
         TOTAL:=TOTAL+(T_QTD*T_VALUNI)
      ELSE
         TOTAL   :=TOTAL+(T_QTD*T_VALUNI)
         T_VALIPI:=T_VALIPI+(T_QTD*T_VALUNI)*(T_IPI/100)
      ENDIF
      SET KEY -1 TO FINALPEDIDO()
      TELA2:=SAVESCREEN(5,1,20,79)
      RESTSCREEN(6,1,21,79,TELA2)
      IF X>=CONFIG->QTDITENS_V
         AVISO(TRIM(STR(CONFIG->QTDITENS_V))+" ‚ o nŁmero m ximo de itens para sua Nota Fiscal...")
         FINALPEDIDO()
      ENDIF
   ENDIF
   ITEM    :=SPACE(LEN(ESTOQUE->CODIGO_V))
   T_QTD   :=0
   T_VALUNI:=0
ENDDO
CONFIG->(DBCLOSEAREA())
PEDIDO->(DBCLOSEAREA())
PEDIDO2->(DBCLOSEAREA())
ESTOQUE->(DBCLOSEAREA())
CLIFOR->(DBCLOSEAREA())
MOEDA->(DBCLOSEAREA())
SYSTEM->(DBCLOSEAREA())
IF TIPO="V"
   MECVEN->(DBCLOSEAREA())
   BASCAL->(DBCLOSEAREA())
ENDIF
TMP->(DBCLOSEAREA())
FERASE(ARQ+".DB?")
FERASE(ARQ+".NTX")
RESTSCREEN(,,,,TELA)
SET KEY -1 TO
SET KEY -9 TO
CLOSEWIN(0,0,24,79)
RETURN(.T.)

FUNCTION PEDIDO1(L1,C1,TAM,L2,C2) // PROCURA VALORES DO ESTOQUE P/ VARIAVEIS
LOCAL  OLD
MEMVAR CORDES
MEMVAR T_VALUNI,T_QTD,T_BASCAL,O_BASCAL,T_TBASCAL,O_TBASCAL,T,T_IPI
SETCOLOR(CORDES)
DO CASE
   CASE T="V"
      @ IF(L1=NIL,05,L1),IF(C1=NIL,15,C1) CLEAR TO IF(L1=NIL,05,L1),IF(C1=NIL,45,C1+21)
      @ IF(L1=NIL,05,L1),IF(C1=NIL,15,C1) SAY LEFT(ESTOQUE->NOME_V,IF(TAM=NIL,30,TAM)) COLOR CORDES
      IF CLIFOR->REVENDA_V="S"
         IF ESTOQUE->MOEDA_V="U"
            T_VALUNI:=ESTOQUE->VALREV_V*MOEDA->VALOR_V
         ELSE
            T_VALUNI:=ESTOQUE->VALREV_V
         ENDIF
      ELSE
         IF ESTOQUE->MOEDA_V="U"
            T_VALUNI:=IF(CONFIG->MULTPRCV_V='S',ESTOQUE->VALMED_V,ESTOQUE->VALVEN_V)*MOEDA->VALOR_V
         ELSE
            T_VALUNI:=IF(CONFIG->MULTPRCV_V='S',ESTOQUE->VALMED_V,ESTOQUE->VALVEN_V)
         ENDIF
      ENDIF
      @ IF(L2=NIL,05,L2),IF(C2=NIL,66,C2) CLEAR TO IF(L2=NIL,05,L2),IF(C2=NIL,77,C2+11)
      @ IF(L2=NIL,05,L2),IF(C2=NIL,66,C2) SAY T_VALUNI*T_QTD PICT "@R 9,999,999.99" COLOR CORDES
      IF ESTOQUE->SITTABB_V=2
         T_BASCAL:=O_BASCAL
         T_TBASCAL:=O_TBASCAL
      ELSE
         T_BASCAL:=100
         T_TBASCAL:=""
      ENDIF
   CASE T="C"
      @ IF(L1=NIL,05,L1),IF(C1=NIL,15,C1) CLEAR TO IF(L1=NIL,05,L1),IF(C1=NIL,37,C1+22)
      @ IF(L1=NIL,05,L1),IF(C1=NIL,15,C1) SAY LEFT(ESTOQUE->NOME_V,IF(TAM=NIL,23,TAM)) COLOR CORDES
//      IF ESTOQUE->MOEDA_V="U"
//         T_VALUNI:=ESTOQUE->VALCUS_V*MOEDA->VALOR_V
//      ELSE
         T_VALUNI:=ESTOQUE->VALCUS_V
//      ENDIF
      @ IF(L2=NIL,05,L2),IF(C2=NIL,62,C2) CLEAR TO IF(L2=NIL,05,L2),IF(C2=NIL,71,C2+9)
      @ IF(L2=NIL,05,L2),IF(C2=NIL,62,C2) SAY (T_VALUNI*T_QTD) PICT "@R 999,999.99" COLOR CORDES
ENDCASE
SETCOLOR(OLD)
RETURN(.T.)

FUNCTION PEDIDO2(LIN,COL) // CALCULA O VALOR TOTAL DO ITEM SELECIONADO
LOCAL  OLD
MEMVAR CORDES,T
MEMVAR T_VALUNI,T_QTD,T_IPI
OLD:=SETCOLOR()
SETCOLOR(CORDES)
IF T="V"
   @ IF(LIN=NIL,05,LIN),IF(COL=NIL,66,COL) CLEAR TO IF(LIN=NIL,05,LIN),IF(COL=NIL,68,COL+11)
   @ IF(LIN=NIL,05,LIN),IF(COL=NIL,66,COL) SAY T_VALUNI*T_QTD PICT "@R 9,999,999.99" COLOR CORDES
ELSE
   @ IF(LIN=NIL,05,LIN),IF(COL=NIL,62,COL) CLEAR TO IF(LIN=NIL,05,LIN),IF(COL=NIL,71,COL+9)
   @ IF(LIN=NIL,05,LIN),IF(COL=NIL,62,COL) SAY (T_VALUNI*T_QTD) PICT "@R 999,999.99" COLOR CORDES
ENDIF
SETCOLOR(OLD)
RETURN(.T.)

FUNCTION FINALPEDIDO()
LOCAL  X,TELA,VALMO,LINSERV1,LINSERV2,LINSERV3,LINSERV4
LOCAL  VALCUS,VALMIN,VALMED,VALMAX
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN
MEMVAR PEDIDO,CLIFOR,CODIGO,VALOR,QTD,ICMS,GETLIST,T,PEDCLI
MEMVAR ITEM,T_VALUNI,T_QTD,T_ICMS,TOTAL,CONT,MECVEN,BASCAL,T_BASCAL
MEMVAR TBASCAL,T_TBASCAL,T_IPI,IPI,T_VALIPI,VALIPI,FRETE
CLEAR GETS
TELA:=SAVESCREEN()
RESTSCREEN(,,,,TELA)
LINSERV1:=SPACE(LEN(PEDIDO->LINSERV1_V))
LINSERV2:=SPACE(LEN(PEDIDO->LINSERV2_V))
LINSERV3:=SPACE(LEN(PEDIDO->LINSERV3_V))
LINSERV4:=SPACE(LEN(PEDIDO->LINSERV4_V))
VALMO   :=0
FRETE   :=0
IF T="V"
   SET KEY -1 TO
   SET KEY -9 TO
   WINDOW(10,10,16,78)
   @ 10,11 SAY "Servi‡os Prestados" COLOR CORTIT
   @ 11,12 GET LINSERV1 PICT "@!"
   @ 12,12 GET LINSERV2 PICT "@!"
   @ 13,12 GET LINSERV3 PICT "@!"
   @ 14,12 GET LINSERV4 PICT "@!"
   @ 15,12 SAY "Valor dos Servi‡os :" GET VALMO PICT "@R 999,999,999.99"
   READ
   IF LASTKEY()=27
      SET KEY -1 TO FINALPEDIDO()
      SET KEY -9 TO ULTIMACOMPRA()
      RETURN(.F.)
   ENDIF
ENDIF
IF ! CONFIRMA(20,20,"Todos os dados estao corretos ?")
   SET KEY -1 TO FINALPEDIDO()
   RETURN(.F.)
ENDIF
AADD(CODIGO,)
X:=1
CONT:=.F.
IF PEDIDO->(ADDREC())
   DO WHILE .NOT. CONFIG->(RECLOCK())
   ENDDO
   DO CASE
      CASE T="V"
         CONFIG->PEDVEN_V:=CONFIG->PEDVEN_V+1
         PEDIDO:="V"+STRZERO(CONFIG->PEDVEN_V,5,0)
      CASE T="C"
         CONFIG->PEDCOM_V:=CONFIG->PEDCOM_V+1
         PEDIDO:="C"+STRZERO(CONFIG->PEDCOM_V,5,0)
   ENDCASE
   CONFIG->(DBCOMMIT(),DBUNLOCK())
   PEDIDO->CODIGO_V:=PEDIDO
   PEDIDO->CLIFOR_V:=CLIFOR
   IF T="V"
      PEDIDO->MECVEN_V:=MECVEN
   ENDIF
   PEDIDO->CLIFOR_V  :=CLIFOR
   PEDIDO->PEDCLI_V  :=PEDCLI
   PEDIDO->DATEMI_V  :=DATE()
   PEDIDO->VALTOT_V  :=TOTAL
   PEDIDO->VALTOT2_V :=T_VALIPI+FRETE+TOTAL
   PEDIDO->FRETE_V   :=FRETE
   PEDIDO->VALIPI_V  :=T_VALIPI
   PEDIDO->TIPO_V    :="P"
   PEDIDO->NOMSEN_V  :=NOMSEN
   PEDIDO->LINSERV1_V:=LINSERV1
   PEDIDO->LINSERV2_V:=LINSERV2
   PEDIDO->LINSERV3_V:=LINSERV3
   PEDIDO->LINSERV4_V:=LINSERV4
   PEDIDO->VALMO_V   :=VALMO
   VALCUS := 0
   VALMIN := 0
   VALMED := 0
   VALMAX := 0
   DO WHILE .T.
      IF CODIGO[X]=NIL
         EXIT
      ENDIF
      PEDIDO2->(ADDREC())
      PEDIDO2->CODIGO_V :=PEDIDO
      PEDIDO2->ITEM_V   :=CODIGO[X]
      PEDIDO2->VALUNI_V :=VALOR[X]
      PEDIDO2->QTD_V    :=QTD[X]
      PEDIDO2->ICMS_V    :=ICMS[X]
      IF T="V"
         PEDIDO2->BASCAL_V  :=BASCAL[X]
         PEDIDO2->TBASCAL_V :=TBASCAL[X]
      ELSE
         PEDIDO2->IPI_V     :=IPI[X]
         PEDIDO2->VALIPI_V  :=VALIPI[X]
      ENDIF
      IF T="V"
         IF ESTOQUE->(DBSEEK(CODIGO[X]))
            PEDIDO2->VALCUS_V := ESTOQUE->VALCUS_V
            PEDIDO2->VALMIN_V := ESTOQUE->VALVEN_V
            PEDIDO2->VALMED_V := IF(CONFIG->MULTPRCV_V='S',ESTOQUE->VALMED_V,ESTOQUE->VALVEN_V)
            PEDIDO2->VALMAX_V := ESTOQUE->VALMAX_V
            VALCUS += ESTOQUE->VALCUS_V
            VALMIN += ESTOQUE->VALVEN_V
            VALMED += IF(CONFIG->MULTPRCV_V='S',ESTOQUE->VALMED_V,ESTOQUE->VALVEN_V)
            VALMAX += ESTOQUE->VALMAX_V
            IF ESTOQUE->(RECLOCK())
               ESTOQUE->RESERVA_V:=ESTOQUE->RESERVA_V+QTD[X]
               ESTOQUE->(DBUNLOCK())
            ENDIF
         ENDIF
      ENDIF
      X++
      PEDIDO2->(DBCOMMIT(),DBUNLOCK())
   ENDDO
   IF T='V'
      PEDIDO->VALCUS_V := VALCUS
      PEDIDO->VALMED_V := VALMED
      IF CONFIG->MULTPRCV_V='S'
         PEDIDO->VALMIN_V := VALMIN
         PEDIDO->VALMAX_V := VALMAX
      ENDIF
   ENDIF
   IF SYSTEM->(ADDREC()) .AND. CONFIG->(RECLOCK())
      CONFIG->SYSTEM_V+=1
      SYSTEM->CODIGO_V :=CONFIG->SYSTEM_V
      SYSTEM->DATA_V   :=DATE()
      SYSTEM->HORA_V   :=TIME()
      SYSTEM->DESCR_V  :=IF(T="V","Inclusao de Pedido de Venda "+PEDIDO,"Inclusao de Pedido de Compra "+PEDIDO)
      SYSTEM->USUARIO_V:=NOMSEN
      PEDIDO->SYSTEM_V :=SYSTEM->CODIGO_V
   ENDIF
   SYSTEM->(DBCOMMIT(),DBUNLOCK())
   CONFIG->(DBCOMMIT(),DBUNLOCK())
   PEDIDO->(DBCOMMIT(),DBUNLOCK())
   IF CONFIRMA(20,20,"Deseja imprimir o pedido de "+IF(T="V","venda","compra")+" ?")
      DO WHILE ! ISPRINTER() .AND. LASTKEY()<>27
         AVISO("Impressora fora de linha ou nao conectada ...")
      ENDDO
      IF LASTKEY()<>27
         IMPPEDIDO(PEDIDO)
      ENDIF
   ENDIF
ENDIF
RETURN(.T.)

FUNCTION ULTIMACOMPRA()
LOCAL TELA,CAMPOS,TITULOS,LINHA1,COLUNA
MEMVAR CORTIT,ITEM,CORTEX
TELA:=SAVESCREEN()
LINHA1:=CHR(220)
COLUNA:=CHR(219)
CAMPOS := {"TRANSFORM(TMP->QTD_V,'@R 99,999.99')+' '+TMP->CODIGO_V+' '+LEFT(TMP->NOME_V,45)+' '+TRANSFORM(TMP->VALUNI_V,'@R 99,999.99')",}
TITULOS := {"   Quant. C˘digo       Descri‡ao                                      Vl.Unit."}
SETCOLOR(CORTEX)
WINDOW(01,0,06,79)
WINDOW(06,0,22,79)
@ 1,1  SAY "Ultimas Compras" COLOR CORTIT
@ 3,1  SAY PADC("Faturamento",78) COLOR CORTIT
@ 23,01 SAY "Pressione Setas "+CHR(27)+CHR(18)+CHR(26) COLOR CORTIT
TMP->(DBEDIT(07,01,21,78,CAMPOS,'FULTCPM',,TITULOS,LINHA1,COLUNA))
IF LASTKEY()=13 .OR. LASTKEY()=32
   ITEM := TMP->CODIGO_V
ENDIF
RESTSCREEN(,,,,TELA)
RETURN(.T.)

FUNCTION FULTCPM(NMODE,NCOL)
LOCAL NKEY,NRETVAL,OLD
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR S,N
OLD:=SETCOLOR()
NRETVAL:=1
NKEY:=LASTKEY()
DO CASE
   CASE NMODE==0
      @ 2,1  SAY "Pedido : "+TMP->PEDIDO_V
      @ 2,17 SAY "Emissao: "+DTOC(TMP->DATEMI_V)
      @ 4,1  SAY DTOC(TMP->DATPAG_V)
      @ 4,12 SAY DTOC(TMP->DATPAG1_V)
      @ 4,23 SAY DTOC(TMP->DATPAG2_V)
      @ 4,34 SAY DTOC(TMP->DATPAG3_V)
      @ 4,45 SAY DTOC(TMP->DATPAG4_V)
      @ 5,1  SAY TMP->DOCEXT_V
      @ 5,12 SAY TMP->DOCEXT1_V
      @ 5,23 SAY TMP->DOCEXT2_V
      @ 5,34 SAY TMP->DOCEXT3_V
      @ 5,45 SAY TMP->DOCEXT4_V
      NRETVAL:=1
   CASE NMODE==1
      NRETVAL:=1
   CASE NMODE==2
      NRETVAL:=1
   CASE NMODE==3
      NRETVAL:=1
   CASE NMODE==4
      DO CASE
         CASE NKEY=27 .OR. NKEY=13 .OR. LASTKEY()=32
            NRETVAL:=0
         OTHERWISE
            NRETVAL:=1
      ENDCASE
ENDCASE
SETCOLOR(OLD)
RETURN NRETVAL

FUNCTION IMPPEDIDO(PEDIDO)
LOCAL CONT
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN
PEDIDO->(DBSETORDER(1))
PEDIDO2->(DBSETORDER(1))
PEDIDO->(DBSEEK(PEDIDO))
PEDIDO2->(DBSEEK(PEDIDO))
CABECA("Pedido"+IF(LEFT(PEDIDO,1)="V"," de Venda "," de Compra "))
@ PROW()+1,0 SAY "Pedido : "+PEDIDO->CODIGO_V
@ PROW(),16 SAY "Emissao : "+DTOC(PEDIDO->DATEMI_V)
IF LEFT(PEDIDO,1)="V"
   @ PROW(),38 SAY "V.: "+IF(MECVEN->(dbsetorder(1), DBSEEK(PEDIDO->MECVEN_V)),LEFT(MECVEN->NOME_V,27),SPACE(27))
