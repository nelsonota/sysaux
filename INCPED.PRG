         @ PROW()  ,IF(CONFIG->IMPCVEN_V="N",18,25) SAY LEFT(IF(ESTOQUE->(DBSETORDER(1),DBSEEK(PEDIDO2->ITEM_V)),IF(CONFIG->DESCAPL_V='N',ESTOQUE->NOME_V,TRIM(ESTOQUE->NOME_V)+" "+TRIM(ESTOQUE->APLICA_V)+" "+TRIM(ESTOQUE->FABRICAN_V)),SPACE(37)),37)
