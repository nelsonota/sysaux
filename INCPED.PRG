         @ PROW()  ,IF(CONFIG->IMPCVEN_V="N",15,28) SAY LEFT(IF(ESTOQUE->(DBSETORDER(1),DBSEEK(PEDIDO2->ITEM_V)),IF(CONFIG->DESCAPL_V='N',ESTOQUE->NOME_V,TRIM(ESTOQUE->NOME_V)+" "+TRIM(ESTOQUE->APLICA_V)+" "+TRIM(ESTOQUE->FABRICAN_V)),SPACE(34)),34)
         @ PROW()  ,IF(CONFIG->IMPCVEN_V="N",51,64) SAY PEDIDO2->VALUNI_V PICT "@R 999.99"
         @ PROW()  ,IF(CONFIG->IMPCVEN_V="N",58,71) SAY PEDIDO2->VALUNI_V*PEDIDO2->QTD_V PICT "@R 9,999.99"   
      ELSEIF CONFIG->MODPED_V=4
         @ PROW()+1,00 SAY IF(CONFIG->IMPCVEN_V="N",'',PEDIDO2->ITEM_V)
