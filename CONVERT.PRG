FUNCTION CONVERT()
DBUSEAREA(.T.,,"ESTOQUE","ESTOQUE",.T.)
DBUSEAREA(.T.,,"EXPCOD","EXPCOD",.T.)
SET INDEX TO EXPCOD3
ESTOQUE->(DBGOTOP())
DO WHILE ! ESTOQUE->(EOF())
   @ 14,0 SAY PADC(ESTOQUE->CODIGO_V+" "+ESTOQUE->NOME_V,80)
   IF EXPCOD->(DBSEEK(ESTOQUE->CODIGO_V))
      @ 15,0 SAY PADC("ENCONTRADO",80)
   ELSE
      @ 15,0 SAY PADC("NAO ENCONTRADO",80)
      ESTOQUE->(RLOCK())
      ESTOQUE->(DBDELETE())
      ESTOQUE->(DBUNLOCK())
   ENDIF
   ESTOQUE->(DBSKIP())
ENDDO
RETURN(.T.)