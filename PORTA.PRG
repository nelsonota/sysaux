FUNCTION PORTA()
LOCAL TELA,GETLIST:={},OP
MEMVAR CODIGO,NOME
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,NETKEY,LEVEL,CODSEN
TELA:=SAVESCREEN()
WINDOW(17,8,19,43)
WINDOW(14,8,17,43)
@ 18,43 SAY CHR(219)
@ 13,8 SAY "Tabela de Portadores"
DBF_PORTA()
DO WHILE .T.
   SETCOLOR(CORTEX)
   CODIGO:=PORTA->CODIGO_V
   NOME  :=PORTA->NOME_V
   @ 15,10 SAY "Código   : " + CODIGO
   @ 16,10 SAY "Descrićao: " + NOME
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 18,9  PROMPT " Incluir "
   @ 18,18 PROMPT " Buscar "
   @ 18,26 PROMPT " Alterar "
   @ 18,35 PROMPT " Apagar "
   MENU TO OP
   DO CASE
      CASE OP=1
         IPORTA()
      CASE OP=2
         DBE_PORTA(10,5,20,50)
      CASE OP=3
         APORTA()
      CASE OP=4
         EPORTA()
      OTHERWISE
         EXIT
   ENDCASE
ENDDO
PORTA->(DBCLOSEAREA())
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(14,8,17,43)
RESTSCREEN(,,,,TELA)
RETURN(.T.)