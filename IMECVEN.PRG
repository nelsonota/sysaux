FUNCTION IMECVEN(OPCAO)
LOCAL GETLIST:={},COB
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN

*** VARIAVEIS PARA CADASTRO DE MECANICOS/VENDEDORES
MEMVAR CODIGO,NOME,ENDERECO,BAIRRO,CIDADE,ESTADO,CEP,FONE1,FONE2,FAX
MEMVAR MECVEN,CGCCPF,RGINSEST,CONTATO,ALLCLI, NUMERO, COMPLEM
SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
CODIGO  :=MECVEN+STRZERO(CONFIG->MECVEN_V+1,5,0)
NOME    :=SPACE(LEN(MECVEN->NOME_V))
CGCCPF  :=SPACE(LEN(MECVEN->CGCCPF_V))
RGINSEST:=SPACE(LEN(MECVEN->RGINSEST_V))
ENDERECO:=SPACE(LEN(MECVEN->ENDERECO_V))
NUMERO  :=SPACE(LEN(MECVEN->NUMERO_V))
COMPELM :=SPACE(LEN(MECVEN->COMPLEM_V))
BAIRRO  :=SPACE(LEN(MECVEN->BAIRRO_V))
CIDADE  :=SPACE(LEN(MECVEN->CIDADE_V))
ESTADO  :=SPACE(LEN(MECVEN->ESTADO_V))
CEP     :=SPACE(LEN(MECVEN->CEP_V))
FONE1   :=SPACE(LEN(MECVEN->FONE1_V))
FONE2   :=SPACE(LEN(MECVEN->FONE2_V))
FAX     :=SPACE(LEN(MECVEN->FAX_V))
CONTATO :=SPACE(LEN(MECVEN->CONTATO_V))
ALLCLI  :="N"
DO WHILE .T.
   @ 05,13 SAY CODIGO
   IF OPCAO="V"
      @ 05,48 GET ALLCLI   PICT "@!"
   ENDIF
   @ 06,13 GET NOME     PICT "@!" VALID(!EMPTY(NOME))
   @ 07,13 GET ENDERECO PICT "@!"
   @ 07,53 GET NUMERO PICT "@!"
   @ 07,68 GET COMPLEM PICT "@!"
   @ 08,13 GET BAIRRO   PICT "@!"
   @ 09,13 GET CIDADE   PICT "@!" valid sea_cidade(cidade)
   @ 09,54 GET ESTADO   PICT "@!"
   @ 09,65 GET CEP      PICT "@R 99999-999"
   @ 10,13 GET CGCCPF
   @ 10,43 GET RGINSEST
   @ 11,13 GET FONE1    PICT "@R (#999) ##99-9999"
   @ 11,37 GET FONE2    PICT "@R (#999) ##99-9999"
   @ 11,59 GET FAX      PICT "@R (#999) ##99-9999"
   @ 12,13 GET CONTATO  PICT "@!"
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(22,20,"Confirma Inclusao ?")
      IF MECVEN->(ADDREC(5))
         IF CONFIG->(RECLOCK(5))
            CONFIG->MECVEN_V:=CONFIG->MECVEN_V+1
            CODIGO:=MECVEN+STRZERO(CONFIG->MECVEN_V,5,0)
            CONFIG->(DBUNLOCK())
         ELSE
            EXIT
         ENDIF
         MECVEN->CODIGO_V  :=CODIGO
         MECVEN->NOME_V    :=NOME
         MECVEN->CGCCPF_V  :=CGCCPF
         MECVEN->RGINSEST_V:=RGINSEST
         MECVEN->ENDERECO_V:=ENDERECO
         MECVEN->NUMERO_V  :=NUMERO
         MECVEN->COMPLEM_V :=COMPLEM
         MECVEN->BAIRRO_V  :=BAIRRO
         MECVEN->CIDADE_V  :=CIDADE
         MECVEN->ESTADO_V  :=ESTADO
         MECVEN->CEP_V     :=CEP
         MECVEN->FONE1_V   :=FONE1
         MECVEN->FONE2_V   :=FONE2
         MECVEN->FAX_V     :=FAX
         MECVEN->ALLCLI_V  :=ALLCLI
         MECVEN->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
ENDDO
RETURN(.T.)