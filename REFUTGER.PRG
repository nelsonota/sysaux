FUNCTION REFUTGER()
LOCAL TELA,GETLIST:={},CLI
LOCAL ARQ,I,CFIELD,S:=SELECT(),CAMPOS,SUBTOT,TOTAL
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,INSMUN,NOMSEN
MEMVAR IMPFUN,LINHA
TELA:=SAVESCREEN()
DBF_CONFIG()
DBF_CLIFOR()
DBF_PAGREC()
DO WHILE .T.
   IF ! CONFIRMA(20,20,"Iniciar o Relat｢rio de Contas a Receber GERAL ?")
      EXIT
   ENDIF
   ARQ:=NOMETEMP()
   CAMPOS:=PAGREC->(DBSTRUCT())
   AADD(CAMPOS,{"NOME_V"    ,"C",50,0 })
   DBCREATE(ARQ,CAMPOS)
   DBUSEAREA(.T.,,ARQ,"TMP",.F.,.F.)
   IF NETERR()
      FERASE(ARQ+".DBF")
      AVISO("Erro na gera㌢o do arquivo temporrio...")
      LOOP
   ENDIF
   PAGREC->(DBSETORDER(1),DBSEEK('R'))
   DO WHILE ! PAGREC->(EOF()) .AND. LEFT(PAGREC->CODIGO_V,1)="R"
      DO WHILE ! TMP->(ADDREC(5)) ; ENDDO
      FOR I := 1 TO PAGREC->(FCOUNT())
         CFIELD := PAGREC->(FIELDNAME(I))
         &('TMP->'+CFIELD) := &('PAGREC->'+CFIELD)
      NEXT
      IF CLIFOR->(DBSETORDER(1),DBSEEK(PAGREC->CLIFOR_V))
         TMP->NOME_V := CLIFOR->NOME_V
      ENDIF
      TMP->(DBCOMMIT(),DBUNLOCK())
      PAGREC->(DBSKIP())
   ENDDO
   INDEX ON TMP->NOME_V+DTOS(TMP->DATVEN_V) TO &ARQ
   TMP->(DBGOTOP())
   LINHA:={}
   TOTAL:=0
   DO WHILE ! TMP->(EOF())
      CLI:=TMP->NOME_V
      AADD(LINHA,TMP->NOME_V)
      AADD(LINHA,REPLICATE("-",50))
      SUBTOT:=0
      AADD(LINHA ,LEFT(TMP->DESC_V,21)+" "+DTOC(TMP->DATEXT_V)+" "+TMP->DOCEXT_V+" "+TMP->DOCINT_V+" "+TRANSFORM(TMP->VALOR_V,"@R 999,999.99")+" "+DTOC(TMP->DATVEN_V)+" "+IF(TMP->PROTESTO_V="S","P",""))
      SUBTOT+=TMP->VALOR_V
      TMP->(DBSKIP())
      DO WHILE CLI==TMP->NOME_V .AND. ! TMP->(EOF())
         AADD(LINHA ,LEFT(TMP->DESC_V,21)+" "+DTOC(TMP->DATEXT_V)+" "+TMP->DOCEXT_V+" "+TMP->DOCINT_V+" "+TRANSFORM(TMP->VALOR_V,"@R 999,999.99")+" "+DTOC(TMP->DATVEN_V)+" "+IF(TMP->PROTESTO_V="S","P",""))
         SUBTOT+=TMP->VALOR_V
         TMP->(DBSKIP())
      ENDDO
      AADD(LINHA,REPLICATE("-",80))
      AADD(LINHA,"Total a Receber :"+TRANSFORM(SUBTOT,'@R 9,999,999.99'))
      AADD(LINHA,REPLICATE("-",80))
      AADD(LINHA,' ')
      TOTAL+=SUBTOT
   ENDDO
   AADD(LINHA,REPLICATE("-",80))
   AADD(LINHA,"Total Geral a Receber :"+TRANSFORM(TOTAL,'@R 9,999,999.99'))
   AADD(LINHA,REPLICATE("-",80))
   WINDOW(02,0,23,79)
   @ 03,1 SAY "Descricao             Dt.Extr.   D.Externo  D.Interno       Valor Vencimento P" COLOR CORTIT
   @ 4,1 TO 4,78
   ACHOICE(5,1,22,78,LINHA,.T.,"RELACHOFUN")
   IF CONFIRMA(20,20,"Deseja Imprimir ?")
      IMPREL("Contas Futuras a Receber","Descricao             Dt.Extr.   D.Externo  D.Interno       Valor Vencimento P",45)
   ENDIF
   SELECT(S)
   TMP->(DBCLOSEAREA())
   FERASE(ARQ+".DBF")
   EXIT
ENDDO
CLIFOR->(DBCLOSEAREA())
PAGREC->(DBCLOSEAREA())
CONFIG->(DBCLOSEAREA())
RESTSCREEN(,,,,TELA)
RETURN(.T.)