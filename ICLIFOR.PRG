FUNCTION ICLIFOR(OPCAO)
LOCAL GETLIST:={},TELA
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN

*** VARIAVEIS PARA CADASTRO CLIENTES/FORNECEDORES
MEMVAR CODIGO,NOME,FANTASIA,ENDERECO,BAIRRO,CIDADE,ESTADO,CEP,FONE1,FONE2,FAX
MEMVAR ENDCOB,BAICOB,CIDCOB,ESTCOB,CEPCOB,FONECOB1,FONECOB2,FAXCOB,CLIFOR
MEMVAR CGCCPF,RGINSEST,CONTATO,REFERE1,REFERE2,TELREF1,TELREF2,COB,REVENDA,INSMUN
MEMVAR ENDENT,BAIENT,CIDENT,ESTENT,CEPENT,FONEENT1,FONEENT2,FAXENT,CODTRAN,ENT
MEMVAR MIDIA,EMAIL,EMAILNF,MECVEN,OBS,OBS1,PESSOA, NUMERO, COMPLEM, NUMCOB, COMPCOB, NUMENT, COMPENT
SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
CODIGO  :=CLIFOR+STRZERO(CONFIG->CLIFOR_V+1,5,0)
REVENDA :="N"
NOME    :=SPACE(LEN(CLIFOR->NOME_V))
EMAIL   :=SPACE(LEN(CLIFOR->EMAIL_V))
EMAILNF :=SPACE(LEN(CLIFOR->EMAILNF_V))
CGCCPF  :=SPACE(LEN(CLIFOR->CGCCPF_V))
RGINSEST:=SPACE(LEN(CLIFOR->RGINSEST_V))
INSMUN  :=SPACE(LEN(CLIFOR->INSMUN_V))
FANTASIA:=SPACE(LEN(CLIFOR->FANTASIA_V))
ENDERECO:=SPACE(LEN(CLIFOR->ENDERECO_V))
NUMERO  :=SPACE(LEN(CLIFOR->NUMERO_V))
COMPLEM :=SPACE(LEN(CLIFOR->COMPLEM_V))
BAIRRO  :=SPACE(LEN(CLIFOR->BAIRRO_V))
CIDADE  :=SPACE(LEN(CLIFOR->CIDADE_V))
ESTADO  :=SPACE(LEN(CLIFOR->ESTADO_V))
CEP     :=SPACE(LEN(CLIFOR->CEP_V))
FONE1   :=SPACE(LEN(CLIFOR->FONE1_V))
FONE2   :=SPACE(LEN(CLIFOR->FONE2_V))
FAX     :=SPACE(LEN(CLIFOR->FAX_V))
CONTATO :=SPACE(LEN(CLIFOR->CONTATO_V))
REFERE1 :=SPACE(LEN(CLIFOR->REFERE1_V))
TELREF1 :=SPACE(LEN(CLIFOR->TELREF1_V))
REFERE2 :=SPACE(LEN(CLIFOR->REFERE2_V))
TELREF2 :=SPACE(LEN(CLIFOR->TELREF2_V))
MECVEN  :=SPACE(LEN(CLIFOR->CODVEN_V))
OBS     :=SPACE(LEN(CLIFOR->OBS_V))
OBS1    :=SPACE(LEN(CLIFOR->OBS1_V))
PESSOA  :=SPACE(LEN(CLIFOR->PESSOA_V))
COB     :=0
ENT     :=0
MIDIA   :=0
TELA:=SAVESCREEN()
DO WHILE .T.
   RESTSCREEN(,,,,TELA)
   @ 03,13 SAY CODIGO
   CLIFOR->(DBSETORDER(2))
   IF OPCAO="C"
      @ 03,30 GET REVENDA PICT "@!" VALID(REVENDA$"SN")
   ENDIF
   @ 03,41 GET PESSOA PICT "@!" VALID(PESSOA$"FJ")
   IF OPCAO="C"
      @ 03,54 GET MECVEN VALID(SEA_MECVEN(MECVEN,03,61,"V"))
   ENDIF
   @ 04,13 GET CGCCPF valid empty(cgccpf) .or. (cgccpf(cgccpf) .and. cgccpf_unico(cgccpf, clifor))
   @ 04,43 GET RGINSEST
   @ 04,61 GET INSMUN
   @ 05,13 GET NOME     PICT "@!" VALID(!EMPTY(NOME).AND.IF(CLIFOR->(DBSEEK(NOME)),AVISO("J Existe Cadastro Com Este Nome"),.T.))
   @ 06,13 GET FANTASIA PICT "@!"
   @ 07,13 GET OBS PICT "@!"
   @ 08,13 GET OBS1 PICT "@!"
   @ 09,13 GET ENDERECO PICT "@s35!" VALID(CLIFORCOPY())
   @ 09,53 GET NUMERO PICT "@!"
   @ 09,68 GET COMPLEM PICT "@!"
   @ 10,13 GET BAIRRO   PICT "@!" VALID(CLIFORCOPY())
   @ 11,13 GET CIDADE   PICT "@!" VALID(sea_cidade(cidade) .and. CLIFORCOPY())
   @ 11,54 GET ESTADO   PICT "@!" VALID CLIFORCOPY()
   @ 11,65 GET CEP      PICT "@R 99999-999" VALID(CLIFORCOPY())
   @ 12,13 GET FONE1    PICT "@R (#99) ###99-9999" VALID(CLIFORCOPY())
   @ 12,37 GET FONE2    PICT "@R (#99) ###99-9999" VALID(CLIFORCOPY())
   @ 12,59 GET FAX      PICT "@R (#99) ###99-9999" VALID(CLIFORCOPY())
   @ 13,13 GET CONTATO  PICT "@!"
   @ 14,13 GET REFERE1  PICT "@!"
   @ 14,62 GET TELREF1  PICT "@R (#99) ###99-9999"
   @ 15,13 GET REFERE2  PICT "@!"
   @ 15,62 GET TELREF2  PICT "@R (#99) ###99-9999"
   @ 17,1 SAY PADC("Dados Para Cobran㌢",78) COLOR CORTIT
   @ 18,13 GET ENDCOB   PICT "@s35!"
   @ 18,53 GET NUMCOB PICT "@!"
   @ 18,68 GET COMPCOB PICT "@!"
   @ 19,13 GET BAICOB   PICT "@!"
   @ 20,13 GET CIDCOB   PICT "@!"
   @ 20,54 GET ESTCOB   PICT "@!"
   @ 20,65 GET CEPCOB   PICT "@R 99999-999"
   @ 21,13 GET FONECOB1 PICT "@R (#99) ###99-9999"
   @ 21,37 GET FONECOB2 PICT "@R (#99) ###99-9999"
   @ 21,59 GET FAXCOB   PICT "@R (#99) ###99-9999"
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF OPCAO="C"
      @ 07,1 CLEAR TO 15,78
      @ 07,02 SAY "E-Mail   :" GET EMAIL PICT "@S65" valid email()
      @ 08,02 SAY "E-Mail NF:" GET EMAILNF PICT "@S65"
      @ 09,02 SAY "Registrado por   : "+NOMSEN
      @ 10,02 SAY "Data de Cadastro : "+DTOC(DATE())
      @ 10,32 SAY "M｡dia  :" GET MIDIA PICT "99" VALID(SEA_MIDIA(MIDIA,09,45))
      @ 11,02 SAY "Ultima Compra    : "+DTOC(CLIFOR->DATPED_V)+" Pedido : "+CLIFOR->ULTPED_V+" Valor :"+TRANSFORM(IF(PEDIDO->(DBSETORDER(1),DBSEEK(CLIFOR->ULTPED_V)),PEDIDO->VALTOT_V,CLIFOR->VALPED_V),"@R 999,999.99")
      @ 12,02 SAY "Maior Compra     : "+DTOC(CLIFOR->DATMAI_V)+" Pedido : "+CLIFOR->PEDMAI_V+" Valor :"+TRANSFORM(IF(PEDIDO->(DBSETORDER(1),DBSEEK(CLIFOR->PEDMAI_V)),PEDIDO->VALTOT_V,CLIFOR->VALMAI_V),"@R 999,999.99")
      @ 13,02 SAY "Ultimo Servi㎜   : "+DTOC(CLIFOR->DATTEC_V)+" Ficha  : "+CLIFOR->ULTTEC_V
      @ 14,01 TO 14,78
      @ 15,02 SAY "Transportadora   :" GET CODTRAN VALID(SEA_CODTRAN(CODTRAN,15,27))
      @ 17,1 SAY PADC("Dados Para Entrega",78) COLOR CORTIT
      @ 18,13 GET ENDENT   PICT "@s35!"
      @ 18,53 GET NUMENT PICT "@!"
      @ 18,68 GET COMPENT PICT "@!"
      @ 19,13 GET BAIENT   PICT "@!"
      @ 20,13 GET CIDENT   PICT "@!"
      @ 20,54 GET ESTENT   PICT "@!"
      @ 20,65 GET CEPENT   PICT "@R 99999-999"
      @ 21,13 GET FONEENT1 PICT "@R (#999) ##99-9999"
      @ 21,37 GET FONEENT2 PICT "@R (#999) ##99-9999"
      @ 21,59 GET FAXENT   PICT "@R (#999) ##99-9999"
      READ
      IF LASTKEY()=27
         LOOP
      ENDIF
   ENDIF
   COB++
   ENT++
   if len(sonumero(cgccpf))>11 .and. !ieok(rginsest, ESTADO)
      aviso("Inscricao Estadual invalida")
      loop
   endif
   IF CONFIRMA(22,20,"Confirma Inclusao ?")
      IF CLIFOR->(ADDREC(5))
         DO WHILE .NOT. CONFIG->(RECLOCK(5))
         ENDDO
         CONFIG->CLIFOR_V:=CONFIG->CLIFOR_V+1
         CODIGO:=CLIFOR+STRZERO(CONFIG->CLIFOR_V,5,0)
         CONFIG->(DBCOMMIT(),DBUNLOCK())
         CLIFOR->CODIGO_V  :=CODIGO
         CLIFOR->REVENDA_V :=REVENDA
         CLIFOR->NOME_V    :=NOME
         CLIFOR->FANTASIA_V:=FANTASIA
         CLIFOR->EMAIL_V   :=EMAIL
         CLIFOR->EMAILNF_V :=EMAILNF
         CLIFOR->CGCCPF_V  :=CGCCPF
         CLIFOR->RGINSEST_V:=RGINSEST
         CLIFOR->INSMUN_V  :=INSMUN
         CLIFOR->ENDERECO_V:=ENDERECO
         CLIFOR->NUMERO_V  :=NUMERO
         CLIFOR->COMPLEM_V :=COMPLEM
         CLIFOR->BAIRRO_V  :=BAIRRO
         CLIFOR->CIDADE_V  :=CIDADE
         CLIFOR->ESTADO_V  :=ESTADO
         CLIFOR->CEP_V     :=CEP
         CLIFOR->FONE1_V   :=FONE1
         CLIFOR->FONE2_V   :=FONE2
         CLIFOR->FAX_V     :=FAX
         CLIFOR->CONTATO_V :=CONTATO
         CLIFOR->REFERE1_V :=REFERE1
         CLIFOR->TELREF1_V :=TELREF1
         CLIFOR->REFERE2_V :=REFERE2
         CLIFOR->TELREF2_V :=TELREF2
         CLIFOR->ENDCOB_V  :=ENDCOB
         CLIFOR->BAICOB_V  :=BAICOB
         CLIFOR->NUMCOB_V  :=NUMCOB
         CLIFOR->COMPCOB_V :=COMPCOB
         CLIFOR->CIDCOB_V  :=CIDCOB
         CLIFOR->ESTCOB_V  :=ESTCOB
         CLIFOR->CEPCOB_V  :=CEPCOB
         CLIFOR->FONECOB1_V:=FONECOB1
         CLIFOR->FONECOB2_V:=FONECOB2
         CLIFOR->FAXCOB_V  :=FAXCOB
         CLIFOR->ENDENT_V  :=ENDENT
         CLIFOR->NUMENT_V  :=NUMENT
         CLIFOR->COMPENT_V :=COMPENT
         CLIFOR->BAIENT_V  :=BAIENT
         CLIFOR->CIDENT_V  :=CIDENT
         CLIFOR->ESTENT_V  :=ESTENT
         CLIFOR->CEPENT_V  :=CEPENT
         CLIFOR->FONEENT1_V:=FONEENT1
         CLIFOR->FONEENT2_V:=FONEENT2
         CLIFOR->FAXENT_V  :=FAXENT
         CLIFOR->CODTRAN_V :=CODTRAN
         CLIFOR->NOMSEN_V  :=NOMSEN
         CLIFOR->DATCAD_V  :=DATE()
         CLIFOR->MIDIA_V   :=MIDIA
         CLIFOR->CODVEN_V  :=MECVEN
         CLIFOR->OBS_V     :=OBS
         CLIFOR->OBS1_V    :=OBS1
         CLIFOR->PESSOA_V  :=PESSOA
         CLIFOR->(DBUNLOCK())
         RETURN(.T.)
      ENDIF
   ENDIF
ENDDO
RETURN(.T.)