FUNCTION DIRETOC()
LOCAL  TELA,TELA2,X
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN
*** VARIAVEIS DO MODULO COMPRA/VENDA DIRETO
MEMVAR PEDIDO,CLIFOR,CODIGO,VALOR,QTD,ICMS,GETLIST,VALIPI,T_VALIPI
MEMVAR ITEM,T_VALUNI,T_QTD,T_ICMS,TOTAL,CONT,T_BASCAL,BASCAL,O_BASCAL
MEMVAR T_TBASCAL,TBASCAL,O_TBASCAL,NOTACOM,T_IPI,IPI
TELA:=SAVESCREEN()
X:=0
DBF_CONFIG()
DBF_PEDIDO()
DBF_2PEDIDO()
DBF_ESTOQUE()
DBF_CLIFOR()
DBF_PLANO()
DBF_PAGREC()
DBF_CFOP()
DBF_SYSTEM()
WINDOW(0,0,24,79)
@ 00,01 SAY "Compra Direta" COLOR CORTIT
CONT    :=.F.
CLIFOR  :=SPACE(LEN(PEDIDO->CLIFOR_V))
ITEM    :=SPACE(LEN(ESTOQUE->CODIGO_V))
NOTACOM :=0
T_QTD   :=0
T_VALUNI:=0
T_ICMS  :=0
T_IPI   :=0
T_VALIPI:=0
TOTAL   :=0
CODIGO  :={}
VALOR   :={}
QTD     :={}
ICMS    :={}
IPI     :={}
VALIPI  :={}
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   PEDIDO:="C"+STRZERO(CONFIG->PEDCOM_V+1,5,0)
   @ 01,02 SAY "Compra         : "+PEDIDO
   CLIFOR->(DBSETORDER(2))
   DO WHILE .T.
      DBE_CLIFOR(5,10,15,70)
      @ 02,02 SAY "Fornecedor     : "+CLIFOR->NOME_V
      IF LASTKEY()=27
         EXIT
      ENDIF
      IF LEFT(CLIFOR->CODIGO_V,1)="C"
         AVISO("É necessĀrio que seja selecionado um fornecedor...")
         LOOP
      ENDIF
      CLIFOR:=CLIFOR->CODIGO_V
      EXIT
   ENDDO
   IF LASTKEY()=27
      EXIT
   ENDIF
   @ 01,26 SAY "Nota Fiscal" GET NOTACOM PICT "99999999"
   READ
   IF LASTKEY()=27
      LOOP
   ENDIF
   CLIFOR->(DBSETORDER(1))
   @ 3,2  SAY "Endereco   : "+IF(CLIFOR->(DBSEEK(CLIFOR)),alltrim(CLIFOR->ENDERECO_V)+" "+alltrim(clifor->numero_v)+" "+alltrim(clifor->complem_v),SPACE(50))
   @ 4,2  SAY "Bairro     : "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->BAIRRO_V,SPACE(30))
   @ 4,45 SAY "C.E.P. : "+ IF(CLIFOR->(DBSEEK(CLIFOR)),TRANSFORM(CLIFOR->CEP_V,"99999-9"),SPACE(9))
   @ 5,2  SAY "Cidade     : "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->CIDADE_V,SPACE(30))
   @ 5,45 SAY "Estado : "+ IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->ESTADO_V,SPACE(2))
   @ 6,2  SAY "Telefone   : "+IF(CLIFOR->(DBSEEK(CLIFOR)),TRANSFORM(CLIFOR->FONE1_V,"@R (#999) 9999-9999"),SPACE(15))
   @ 6,45 SAY "CGC/CPF: "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->CGCCPF_V,SPACE(18))
   @ 7,2  SAY "RG/Ins.Est.: "+IF(CLIFOR->(DBSEEK(CLIFOR)),CLIFOR->RGINSEST_V,SPACE(15))
   @ 8,1 TO 8,78
   IF ! CONFIRMA(20,20,"Confirma o Fornecedor ?")
      @ 03,01 CLEAR TO 08,78
      LOOP
   ENDIF
   SETCOLOR(CORTEX)
   @ 03,01 CLEAR TO 08,78
   CONT:=.T.
   EXIT
ENDDO
IF CONT=.T.
   SETCOLOR(CORDES)
   @ 05,02 CLEAR TO 21,13
   @ 05,15 CLEAR TO 21,37
   @ 05,39 CLEAR TO 21,49
   @ 05,51 CLEAR TO 21,60
   @ 05,62 CLEAR TO 21,71
   @ 05,73 CLEAR TO 21,74
   @ 05,76 CLEAR TO 21,77
ENDIF
DO WHILE CONT=.T. 
   SETCOLOR(CORDES)
   @ 05,02 CLEAR TO 05,13
   @ 05,15 CLEAR TO 05,37
   @ 05,39 CLEAR TO 05,49
   @ 05,51 CLEAR TO 05,60
   @ 05,62 CLEAR TO 05,71
   @ 05,73 CLEAR TO 05,74
   @ 05,76 CLEAR TO 05,77
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 3,1 TO 3,78
   @ 22,1 TO 22,78
   @ 04,01 SAY " Código       Descrićao               Vl.UnitĀrio Qtd.       Vl.Total ICMS IPI" COLOR CORTIT
   @ 23,01 SAY PADL("Valor Total do IPI : "+TRANSFORM(T_VALIPI,"@R 999,999.99")+"       Valor Total dos Itens : "+TRANSFORM(TOTAL,"@R 999,999,999.99")+" ",78) COLOR CORTIT
   @ 24,01 SAY "ESC - Cancela Operaćao   F2 - Finaliza"
   @ 05,02 GET ITEM PICT "@K!" VALID(SEA_ESTOQUE(ITEM).AND.DIRETOC1())
   @ 05,39 GET T_VALUNI PICT "@R 99,999.9999" VALID(LASTKEY()=5 .OR. T_VALUNI>0 .AND. DIRETOC2())
   @ 05,51 GET T_QTD    PICT "@R 999,999.99" VALID(LASTKEY()=5 .OR. T_QTD>0 .AND. DIRETOC2() .AND. AVISOEST("C",T_QTD))
   @ 05,73 GET T_ICMS   PICT "@R 99"
   @ 05,76 GET T_IPI    PICT "@R 99" VALID(DIRETOC2())
   READ
   IF LASTKEY()=27
      IF CONFIRMA(20,20,"Deseja realmente cancelar a operaćao ?")
         EXIT
      ELSE
         LOOP
      ENDIF
   ENDIF
   IF LASTKEY()=18 .OR. LASTKEY()=3
      LOOP
   ENDIF
   IF CONT=.F.
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Confirma este Item ?")
      X:=X+1
      AADD(CODIGO,ITEM)
      AADD(QTD,T_QTD)
      AADD(VALOR,T_VALUNI)
      AADD(ICMS,T_ICMS)
      AADD(IPI,T_IPI)
      AADD(VALIPI,(T_QTD*T_VALUNI)*(T_IPI/100))
      TOTAL:=TOTAL+(T_QTD*T_VALUNI)
      T_VALIPI:=T_VALIPI+((T_QTD*T_VALUNI)*(T_IPI/100))
      IF X>=19
         AVISO("19 é o nŻmero mĀximo de itens para sua Nota Fiscal...")
         IF CONFIRMA(20,20,"Finaliza a Venda ?")
            FIMDIRETOC()
         ENDIF
      ENDIF
      SET KEY -1 TO FIMDIRETOC()
      TELA2:=SAVESCREEN(5,1,20,79)
      RESTSCREEN(6,1,21,79,TELA2)
   ENDIF
   ITEM    :=SPACE(LEN(ESTOQUE->CODIGO_V))
   T_QTD   :=0
   T_VALUNI:=0
ENDDO
CONFIG->(DBCLOSEAREA())
PEDIDO->(DBCLOSEAREA())
PEDIDO2->(DBCLOSEAREA())
ESTOQUE->(DBCLOSEAREA())
CLIFOR->(DBCLOSEAREA())
PLANO->(DBCLOSEAREA())
PAGREC->(DBCLOSEAREA())
CFOP->(DBCLOSEAREA())
SYSTEM->(DBCLOSEAREA())
RESTSCREEN(,,,,TELA)
SET KEY -1 TO
CLOSEWIN(0,0,24,79)
RETURN(.T.)

FUNCTION FIMDIRETOC()
LOCAL  TELA,X,PARC,INTER,TOTPAR,ENT,ENT2,COL,MDATE,VALPAR,DOCEXT
LOCAL  PAGREC,TELA2,REGISTRAR
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN
MEMVAR PEDIDO,CLIFOR,CODIGO,VALOR,QTD,ICMS,GETLIST,T
MEMVAR ITEM,T_VALUNI,T_QTD,T_ICMS,TOTAL,CONT
MEMVAR NOTACOM,IPI,T_IPI,CODPLA,CFOP,T_VALIPI,VALIPI,FRETE
CLEAR GETS
TELA:=SAVESCREEN()
TELA2:=SAVESCREEN(3,1,14,78)
RESTSCREEN(10,1,21,78,TELA2)
SET KEY -1 TO
@ 03,01 CLEAR TO 10,78
CODPLA:=SPACE(LEN(PLANO->CODIGO_V))
FRETE:=0
CFOP :=SPACE(LEN(CFOP->CFOP_V))
@ 24,40 SAY "Valor Total do Pedido : "+TRANSFORM(FRETE+TOTAL+T_VALIPI,"@R 999,999,999.99") COLOR CORTIT
DO WHILE .T.
   @ 03,02 SAY "C.F.OP.        :" GET CFOP VALID(SEA_CFOP(CFOP,03,26))
   @ 04,02 SAY "Frete          :" GET FRETE PICT "@R 999,999.99" VALID(DIRETOC3())
   @ 05,02 SAY "Plano de Conta :" GET CODPLA VALID(SEA_CODPLA(CODPLA,5,25,"-"))
   PARC:=0
   INTER:=0
   ENT:=SPACE(1)
   @ 06,2  SAY "Parcelas   :" GET PARC PICT "9" VALID(PARC>0 .AND. PARC<=5)
   @ 06,18 SAY "Intervalo de Dias :" GET INTER PICT "99" VALID(IF(PARC>1,INTER>0,INTER>=0))
   @ 06,43 SAY "1” Parc. ģ Vista ? :" GET ENT PICT "@!" VALID(LASTKEY()=5 .OR. ENT$"SN")
   @ 07,02 SAY "Vencimento         :"
   @ 08,02 SAY "Valor da Parcela   :"
   @ 09,02 SAY "Doc.Ext.da Parcela :"
   @ 10,01 TO 10,78
   READ
   IF LASTKEY()=27
      RESTSCREEN(,,,,TELA)
      SET KEY -1 TO FIMDIRETOC()
      RETURN(.F.)
   ENDIF
   X:=1
   ENT2:=ENT
   TOTPAR:=0
   MDATE:={,,,,,}
   VALPAR:={,,,,,}
   DOCEXT:={,,,,,}
   DO WHILE X<=PARC
      IF ENT2="S"
         MDATE[X]=DATE()
         ENT2:="N"
      ELSE
         IF X>1
            MDATE[X]=MDATE[X-1]+INTER
         ELSE
            MDATE[X]=DATE()+INTER
         ENDIF
      ENDIF
      X++
   ENDDO
   X:=1
   COL:=23
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   DO WHILE .T.
      IF MDATE[X]=(NIL)
         EXIT
      ENDIF
      VALPAR[X]:=ROUND((TOTAL+FRETE+T_VALIPI)/PARC,2)
      DOCEXT[X]:=IF(EMPTY(NOTACOM),SPACE(LEN(PAGREC->DOCEXT_V)),SPACE(10-LEN("NF."+ALLTRIM(STR(NOTACOM))))+"NF."+ALLTRIM(STR(NOTACOM)))
      @ 7,COL GET MDATE[X]
      @ 8,COL GET VALPAR[X] PICT "@R 999,999.99"
      @ 9,COL GET DOCEXT[X]
      READ
      IF LASTKEY()=27
         @ 7,1 CLEAR TO 9,78
         EXIT
      ENDIF
      TOTPAR:=TOTPAR+VALPAR[X]
      X++
      COL=COL+11
   ENDDO
   IF LASTKEY()=27
      LOOP
   ENDIF
   IF ROUND(TOTPAR,2)#ROUND(TOTAL+FRETE+T_VALIPI,2) .AND. TOTPAR#TOTAL+FRETE+T_VALIPI
      AVISO("O Valor Total das Parcelas nao Conferem com o Valor Total do Pedido ...")
      LOOP
   ENDIF
   IF ! CONFIRMA(20,20,"Todos os dados estao corretos ?")
      LOOP
   ENDIF
   IF CONFIG->AUTCOM_V="P"
      IF CONFIRMA(20,20,"Registrar Contas Futuras ?")
         REGISTRAR:="S"
      ELSE
         REGISTRAR:="N"
      ENDIF
   ELSE
      REGISTRAR:=CONFIG->AUTCOM_V
   ENDIF
   EXIT
ENDDO
AADD(CODIGO,)
X:=1
CLEAR GETS
CONT:=.F.
IF PEDIDO->(ADDREC())
   IF CONFIG->(RECLOCK())
      CONFIG->PEDCOM_V:=CONFIG->PEDCOM_V+1
      PEDIDO:="C"+STRZERO(CONFIG->PEDCOM_V,5,0)
      CONFIG->(DBUNLOCK())
   ENDIF
   PEDIDO->CODIGO_V:=PEDIDO
   PEDIDO->CLIFOR_V:=CLIFOR
   PEDIDO->CLIFOR_V  :=CLIFOR
   PEDIDO->DATEMI_V  :=DATE()
   PEDIDO->DATBAI_V  :=DATE()
   PEDIDO->VALTOT_V  :=TOTAL
   PEDIDO->VALTOT2_V :=TOTAL+T_VALIPI+FRETE
   PEDIDO->FRETE_V   :=FRETE
   PEDIDO->VALIPI_V  :=T_VALIPI
   PEDIDO->CFOP_V    :=CFOP
   PEDIDO->NOTACOM_V :=NOTACOM
   IF MDATE[1]#(NIL)
      PEDIDO->DATPAG_V:=MDATE[1]
      PEDIDO->VALPAR_V:=VALPAR[1]
      PEDIDO->DOCEXT_V:=DOCEXT[1]
      IF REGISTRAR="S"
         DO WHILE .NOT. PAGREC->(ADDREC(5));ENDDO
         DO WHILE .NOT. CONFIG->(RECLOCK());ENDDO
         PAGREC:="P"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PEDIDO->PAGREC_V:=PAGREC
         PAGREC->CODIGO_V:=PAGREC
         PAGREC->CLIFOR_V:=CLIFOR
         PAGREC->CODPLA_V:=CODPLA
         PAGREC->PEDIDO_V:=PEDIDO
         PAGREC->VALOR_V :=VALPAR[1]
         PAGREC->DATVEN_V:=MDATE[1]
         PAGREC->DOCEXT_V:=DOCEXT[1]
         PAGREC->DESC_V  :="Compra Direta "+PEDIDO
         PAGREC->(DBUNLOCK())
      ENDIF
   ENDIF
   IF MDATE[2]#(NIL)
      PEDIDO->DATPAG1_V:=MDATE[2]
      PEDIDO->VALPAR1_V:=VALPAR[2]
      PEDIDO->DOCEXT1_V:=DOCEXT[2]
      IF REGISTRAR="S"
         PAGREC->(ADDREC(5))
         CONFIG->(RECLOCK())
         PAGREC:="P"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PEDIDO->PAGREC1_V:=PAGREC
         PAGREC->CODIGO_V :=PAGREC
         PAGREC->CLIFOR_V :=CLIFOR
         PAGREC->CODPLA_V :=CODPLA
         PAGREC->PEDIDO_V :=PEDIDO
         PAGREC->VALOR_V  :=VALPAR[2]
         PAGREC->DATVEN_V :=MDATE[2]
         PAGREC->DOCEXT_V :=DOCEXT[2]
         PAGREC->DESC_V   :="Compra Direta "+PEDIDO
         PAGREC->(DBUNLOCK())
      ENDIF
   ENDIF
   IF MDATE[3]#(NIL)
      PEDIDO->DATPAG2_V:=MDATE[3]
      PEDIDO->VALPAR2_V:=VALPAR[3]
      PEDIDO->DOCEXT2_V:=DOCEXT[3]
      IF REGISTRAR="S"
         PAGREC->(ADDREC(5))
         CONFIG->(RECLOCK())
         PAGREC:="P"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PEDIDO->PAGREC2_V:=PAGREC
         PAGREC->CODIGO_V :=PAGREC
         PAGREC->CLIFOR_V :=CLIFOR
         PAGREC->CODPLA_V :=CODPLA
         PAGREC->PEDIDO_V :=PEDIDO
         PAGREC->VALOR_V  :=VALPAR[3]
         PAGREC->DATVEN_V :=MDATE[3]
         PAGREC->DOCEXT_V :=DOCEXT[3]
         PAGREC->DESC_V   :="Compra Direta "+PEDIDO
         PAGREC->(DBUNLOCK())
      ENDIF
   ENDIF
   IF MDATE[4]#(NIL)
      PEDIDO->DATPAG3_V:=MDATE[4]
      PEDIDO->VALPAR3_V:=VALPAR[4]
      PEDIDO->DOCEXT3_V:=DOCEXT[4]
      IF REGISTRAR="S"
         PAGREC->(ADDREC(5))
         CONFIG->(RECLOCK())
         PAGREC:="P"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PEDIDO->PAGREC3_V:=PAGREC
         PAGREC->CODIGO_V :=PAGREC
         PAGREC->CLIFOR_V :=CLIFOR
         PAGREC->CODPLA_V :=CODPLA
         PAGREC->PEDIDO_V :=PEDIDO
         PAGREC->VALOR_V  :=VALPAR[4]
         PAGREC->DATVEN_V :=MDATE[4]
         PAGREC->DOCEXT_V :=DOCEXT[4]
         PAGREC->DESC_V   :="Compra Direta "+PEDIDO
         PAGREC->(DBUNLOCK())
      ENDIF
   ENDIF
   IF MDATE[5]#(NIL)
      PEDIDO->DATPAG4_V:=MDATE[5]
      PEDIDO->VALPAR4_V:=VALPAR[5]
      PEDIDO->DOCEXT4_V:=DOCEXT[5]
      IF REGISTRAR="S"
         PAGREC->(ADDREC(5))
         CONFIG->(RECLOCK())
         PAGREC:="P"+STRZERO(CONFIG->PAGREC_V+1,5,0)
         CONFIG->PAGREC_V:=CONFIG->PAGREC_V+1
         CONFIG->(DBUNLOCK())
         PEDIDO->PAGREC4_V:=PAGREC
         PAGREC->CODIGO_V :=PAGREC
         PAGREC->CLIFOR_V :=CLIFOR
         PAGREC->CODPLA_V :=CODPLA
         PAGREC->PEDIDO_V :=PEDIDO
         PAGREC->VALOR_V  :=VALPAR[5]
         PAGREC->DATVEN_V :=MDATE[5]
         PAGREC->DOCEXT_V :=DOCEXT[5]
         PAGREC->DESC_V   :="Compra Direta "+PEDIDO
         PAGREC->(DBUNLOCK())
      ENDIF
   ENDIF
   IF ! EMPTY(NOTACOM) .AND. EMPTY(PEDIDO->DATPAG_V)
      PEDIDO->DATPAG_V:=DATE()
   ENDIF
   PEDIDO->TIPO_V    :="D"
   PEDIDO->NOMSEN_V  :=NOMSEN
   DO WHILE .T.
      IF CODIGO[X]=NIL
         EXIT
      ENDIF
      PEDIDO2->(ADDREC())
      PEDIDO2->CODIGO_V :=PEDIDO
      PEDIDO2->ITEM_V   :=CODIGO[X]
      PEDIDO2->VALUNI_V :=VALOR[X]
      PEDIDO2->QTD_V    :=QTD[X]
      PEDIDO2->ICMS_V   :=ICMS[X]
      PEDIDO2->BASCAL_V :=100
      PEDIDO2->IPI_V    :=IPI[X]
      PEDIDO2->VALIPI_V :=VALIPI[X]
      IF ESTOQUE->(DBSEEK(CODIGO[X]))
         movest("E",pedido2->item_v, "CM", qtd[x], pedido2->codigo_v, valor[x])
      ENDIF
      X++
   ENDDO
   IF SYSTEM->(ADDREC()) .AND. CONFIG->(RECLOCK())
      CONFIG->SYSTEM_V+=1
      SYSTEM->CODIGO_V :=CONFIG->SYSTEM_V
      SYSTEM->DATA_V   :=DATE()
      SYSTEM->HORA_V   :=TIME()
      SYSTEM->DESCR_V  :="Compra "+PEDIDO
      SYSTEM->USUARIO_V:=NOMSEN
      PEDIDO->SYSTEM_V :=SYSTEM->CODIGO_V
   ENDIF
   SYSTEM->(DBCOMMIT(),DBUNLOCK())
   PEDIDO->(DBCOMMIT(),DBUNLOCK())
   PEDIDO2->(DBCOMMIT(),DBUNLOCK())
   IF CONFIRMA(20,20,"Deseja imprimir o registro de compra ?")
      DO WHILE ! ISPRINTER() .AND. LASTKEY()<>27
         AVISO("Impressora fora de linha ou nao conectada ...")
      ENDDO
      IF LASTKEY()<>27
         IMPDIRETOC(PEDIDO)
      ENDIF
   ENDIF
ENDIF
RETURN(.T.)

FUNCTION IMPDIRETOC(PEDIDO)
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,NOMSEN
PEDIDO->(DBSETORDER(1))
PEDIDO2->(DBSETORDER(1))
PEDIDO->(DBSEEK(PEDIDO))
PEDIDO2->(DBSEEK(PEDIDO))
CABECA("Registro de Compra "+PEDIDO)
@ PROW()+1,1 SAY "Dt.Operacao: "+DTOC(PEDIDO->DATEMI_V)
@ PROW()+1,1 SAY "Fornecedor : "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->NOME_V,SPACE(50))
@ PROW()+1,1 SAY "Endereco   : "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),alltrim(CLIFOR->ENDERECO_V)+" "+alltrim(clifor->numero_v)+" "+alltrim(clifor->complem_v),SPACE(50))
@ PROW()+1,1 SAY "Bairro     : "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->BAIRRO_V,SPACE(30))
@ PROW(),45  SAY "C.E.P. :"+ IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),TRANSFORM(CLIFOR->CEP_V,"@R 99999-999"),SPACE(9))
@ PROW()+1,1 SAY "Cidade     : "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->CIDADE_V,SPACE(30))
@ PROW(),45  SAY "Estado :"+ IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->ESTADO_V,SPACE(2))
@ PROW()+1,1 SAY "Telefone   : "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),TRANSFORM(CLIFOR->FONE1_V,"@R (#999) 9999-9999"),SPACE(15))
@ PROW(),45  SAY "CGC/CPF:"+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->CGCCPF_V,SPACE(18))
@ PROW()+1,1 SAY "RG/Ins.Est.: "+IF(CLIFOR->(DBSEEK(PEDIDO->CLIFOR_V)),CLIFOR->RGINSEST_V,SPACE(15))
@ PROW()+1,1 SAY REPLICATE("-",79)
@ PROW()+1,1 SAY " Código       Descrićao               Vl.UnitĀrio Qtd.       Vl.Total ICMS IPI" COLOR CORTIT
@ PROW()+1,1 SAY REPLICATE("-",79)
DO WHILE PEDIDO2->CODIGO_V=PEDIDO->CODIGO_V
   @ PROW()+1,02 SAY PEDIDO2->ITEM_V
   @ PROW()  ,16 SAY LEFT(IF(ESTOQUE->(DBSEEK(PEDIDO2->ITEM_V)),ESTOQUE->NOME_V,SPACE(17)),17)
   @ PROW()  ,39 SAY PEDIDO2->VALUNI_V PICT "@R 9,999.9999"
   @ PROW()  ,50 SAY PEDIDO2->QTD_V    PICT "@R 999,999.99"
   @ PROW()  ,61 SAY PEDIDO2->VALUNI_V*PEDIDO2->QTD_V PICT "@R 999,999.99"
   @ PROW()  ,72 SAY PEDIDO2->ICMS_V   PICT "@R 99"
   @ PROW()  ,76 SAY PEDIDO2->IPI_V    PICT "@R 99"
   PEDIDO2->(DBSKIP())
ENDDO
@ PROW()+1,1 SAY REPLICATE("-",79)
@ PROW()+1,01 SAY PADL("Valor Total dos Itens : "+TRANSFORM(PEDIDO->VALTOT_V,"@R 999,999,999.99")+"       ",78)
IF ! EMPTY(PEDIDO->DATPAG_V)
   @ PROW()+1,01 SAY "Pago"
ENDIF
@ PROW()+1,1 SAY REPLICATE("-",79)
EJECT
SET PRINTER TO
SET DEVICE TO SCREEN
RETURN(.T.)

FUNCTION DIRETOC1() // PROCURA VALORES DO ESTOQUE P/ VARIAVEIS
LOCAL  OLD
MEMVAR CORDES
MEMVAR T_VALUNI,T_QTD,T_IPI
SETCOLOR(CORDES)
@ 05,15 CLEAR TO 05,37
@ 05,15 SAY LEFT(ESTOQUE->NOME_V,23) COLOR CORDES
T_VALUNI:=ESTOQUE->VALCUS_V
@ 05,62 CLEAR TO 05,71
@ 05,62 SAY T_VALUNI*T_QTD PICT "@R 999,999.99" COLOR CORDES
SETCOLOR(OLD)
RETURN(.T.)

FUNCTION DIRETOC2() // CALCULA O VALOR TOTAL DO ITEM SELECIONADO
LOCAL  OLD
MEMVAR CORDES,T,T_IPI
MEMVAR T_VALUNI,T_QTD
OLD:=SETCOLOR()
SETCOLOR(CORDES)
@ 05,62 CLEAR TO 05,71
