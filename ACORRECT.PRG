FUNCTION ACORRECT()
LOCAL  GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR BANCO,CLIFOR,CODPLA,DOCEXT,DESC,DOCINT,DATVEN,DATBAI,VALOR,CHEQUE,MOVI
MEMVAR DATEXT,DATINT,CODPORTA
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   IF (MOVI)->FUTVIS_V="V"
      @ 10,19 GET CLIFOR VALID(SEA_CLIFOR(CLIFOR,10,22,IF(LEFT((MOVI)->PAGREC_V,1)="P","F","C")))
   ENDIF
   @ 11,19 GET CODPLA VALID(SEA_CODPLA(CODPLA,11,24))
   IF LEFT((MOVI)->PAGREC_V,1)="R"
      @ 11,51 GET CODPORTA PICT "@!" VALID(LASTKEY()=5 .OR. SEA_PORTA(CODPORTA,12,64))
   ENDIF
   @ 12,19 GET DOCEXT PICT "@K!"
   @ 12,54 GET DATEXT
   @ 13,19 GET DESC   PICT "@K!"
   @ 14,19 GET DOCINT PICT "@K!"
   @ 14,54 GET DATINT
   READ
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Confirma Altera‡oes nos Dados ?")
      IF (MOVI) ->(RECLOCK(5))
         (MOVI)->CLIFOR_V  :=CLIFOR
         (MOVI)->DOCEXT_V  :=DOCEXT
         (MOVI)->DATEXT_V  :=DATEXT
         (MOVI)->DESC_V    :=DESC
         (MOVI)->DOCINT_V  :=DOCINT
         (MOVI)->DATINT_V  :=DATINT
         (MOVI)->CODPLA_V  :=CODPLA
         (MOVI)->CODPORTA_V:=CODPORTA
         (MOVI)->(DBUNLOCK())
      ENDIF
      EXIT
   ENDIF
ENDDO
RETURN(.T.)