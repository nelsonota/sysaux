FUNCTION LISTACOTA()
LOCAL TELA,TELA1,X
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR LINHA,ITEM,MITEM,FIM,GETLIST
GETLIST:={}
FIM:=.F.
MITEM:={}
TELA:=SAVESCREEN()
DBF_CONFIG()
DBF_CLIFOR()
DBF_COTA()
DBF_ESTOQUE()
SETCOLOR(CORTIT)
@ 9,0 SAY "Montagem de Lista de Itens para Cota‡ao"
WINDOW(10,0,20,79)
ITEM:=SPACE(12)
LINHA:={}
COTA->(DBSETORDER(2))
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   @ 11,2 GET ITEM PICT "@K!" VALID(SEA_ESTOQUE(ITEM,11,16))
   READ
   IF FIM=.T.
      EXIT
   ENDIF
   IF LASTKEY()=27
      IF CONFIRMA(20,20,"Cancela Opera‡ao ?")
         EXIT
      ELSE
         LOOP
      ENDIF
   ENDIF
   IF CONFIRMA(20,20,"Confirma este Item ?")
      SET KEY -1 TO FINALCOTA()
      @ 24,0 CLEAR TO 24,79
      @ 24,2 SAY "ESC - Cancela Opera‡ao  F2 - Finaliza"
      TELA1:=SAVESCREEN(11,1,18,78)
      @ 11,1 CLEAR TO 11,78
      RESTSCREEN(12,1,19,78,TELA1)
      AADD(MITEM,ITEM)
      ITEM:=SPACE(12)
   ENDIF
ENDDO
CONFIG->(DBCLOSEAREA())
CLIFOR->(DBCLOSEAREA())
COTA->(DBCLOSEAREA())
ESTOQUE->(DBCLOSEAREA())
RESTSCREEN(,,,,TELA)
CLOSEWIN(10,0,20,79)
RETURN(.T.)

FUNCTION FINALCOTA()
LOCAL X
MEMVAR FIM,MITEM,LINHA,GETLIST
CLEAR GETS
AADD(MITEM,)
X:=1
DO WHILE .T.
   IF MITEM[X]=(NIL)
      EXIT
   ENDIF
   AADD(LINHA,MITEM[X]+" - "+IF(ESTOQUE->(DBSEEK(MITEM[X])),ESTOQUE->NOME_V,SPACE(50)))
   AADD(LINHA," *"+IF(CLIFOR->(DBSEEK(ESTOQUE->CLIFOR_V)),CLIFOR->NOME_V,SPACE(50))+"  "+TRANSFORM(ESTOQUE->VALCUS_V,"@R 999,999,999.99"))
   COTA->(DBSEEK(MITEM[X]))
   DO WHILE COTA->ITEM_V=MITEM[X] .AND. COTA->(!EOF())
      AADD(LINHA,"  "+IF(CLIFOR->(DBSEEK(COTA->CLIFOR_V)),CLIFOR->NOME_V,SPACE(50))+"  "+TRANSFORM(COTA->VALOR_V,"@R 999,999,999.99"))
      COTA->(DBSKIP())
   ENDDO
   AADD(LINHA," ")
   X++
ENDDO
ACHOICE(11,1,19,78,LINHA,.T.,"RELACHOFUN")
IF CONFIRMA(20,20,"Deseja Imprimir ?")
   IMPREL("Itens para Cota‡ao",,48)
ENDIF
SET KEY -1 TO
FIM:=.T.
RETURN(.T.)