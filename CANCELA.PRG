FUNCTION CANCELA()
LOCAL TELA,GETLIST:={},CODBAN
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR CHEQUE
TELA:=SAVESCREEN(0,0,24,80)
DBF_BANK()
DBF_CHEQUE()
WINDOW(11,18,16,45)
SETCOLOR(CORTIT)
@ 10,18 SAY "Cancelamento de Cheques"
DO WHILE .T.
   SETCOLOR(CORTEX+","+CORBAR+",,,"+CORDES)
   CHEQUE:=SPACE(6)
   DO WHILE .T.
      DBE_BANK(10,5,20,75)
      IF LASTKEY()#27
         IF BANK->CODIGO_V=0
            AVISO("Selecione Um Banco")
            LOOP
         ENDIF
      ENDIF
      EXIT
   ENDDO
   IF LASTKEY()=27
      EXIT
   ENDIF
   CODBAN:=BANK->CODIGO_V
   @ 12,20 SAY "Banco   : "+BANK->NOME_V
   @ 13,20 SAY "Cheque  :" GET CHEQUE VALID(SEA_CHEQUE(CHEQUE,CODBAN,"CAN").AND.!EMPTY(CHEQUE))
   READ
   @ 14,20 SAY "Emissao : "+DTOC(CHEQUE->DATEMI_V)
   @ 15,20 SAY "Valor   : "+TRANSFORM(CHEQUE->VALOR_V,"@R 999,999,999.99")
   IF LASTKEY()=27
      EXIT
   ENDIF
   IF CONFIRMA(20,20,"Confirma Cancelamento do Cheque ?")
      IF CHEQUE->(RECLOCK(5))
         CHEQUE->DATBAI_V:=TRABALHO
         IF EMPTY(CHEQUE->DATEMI_V)
            CHEQUE->DATEMI_V:=TRABALHO
         ENDIF
         CHEQUE->OBS_V:="Cancelado"
         CHEQUE->(DBUNLOCK())
         EXIT
      ENDIF
   ENDIF
ENDDO
CHEQUE->(DBCLOSEAREA())
BANK->(DBCLOSEAREA())
RESTSCREEN(0,0,24,80,TELA)
CLOSEWIN(11,18,16,45)
RETURN(.T.)