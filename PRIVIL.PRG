FUNCTION PRIVIL()
LOCAL VARIAVEIS,LINHA1,COLUNA,TELA,TITULOS
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO,INSMUN,NOMSEN
TELA:=SAVESCREEN()
LINHA1:=CHR(220)
COLUNA:=CHR(219)
WINDOW(05,2,22,78)
@ 04,2 SAY "Privil‚gios de : " + SENHA->NOMSEN_V COLOR CORTIT
@ 23,2 SAY "F10 - Permitir/Bloquear " COLOR CORTIT
VARIAVEIS:={"MENU_V","IF(PRIVIL->(DBSEEK(STR(SENHA->CODSEN_V,5)+ACCCOM->CODIGO_V)) ,'*',' ')"}
TITULOS := {"Menu","Permissao"}
ACCCOM->(DBEDIT(06,3,21,77,VARIAVEIS,"FPRIVIL",,TITULOS,LINHA1,COLUNA))
RESTSCREEN(,,,,TELA)
RETURN(.T.)

FUNCTION FPRIVIL(NMODE,NCOL)
LOCAL NKEY,NRETVAL,TELA,OLD,NOME,GETLIST:={}
MEMVAR CORTIT,CORTEX,CORPAR,CORBAR,CORDES,LEVEL,CODSEN,TRABALHO
MEMVAR S,N
OLD:=SETCOLOR()
TELA:=SAVESCREEN(0,0,24,80)
NRETVAL:=1
NKEY:=LASTKEY()
DO CASE
   CASE NMODE==0
      NRETVAL:=1
   CASE NMODE==1
      NRETVAL:=1
   CASE NMODE==2
      NRETVAL:=1
   CASE NMODE==3
      NRETVAL:=1
   CASE NMODE==4
      DO CASE
         CASE NKEY=27 .OR. NKEY=13
            NRETVAL:=0
         CASE NKEY=-9
            IF PRIVIL->(DBSEEK(STR(SENHA->CODSEN_V,5)+ACCCOM->CODIGO_V))
               IF PRIVIL->(RECLOCK(5))
                  PRIVIL->(DBDELETE())
               ENDIF
            ELSE
               IF PRIVIL->(ADDREC(5))
                  PRIVIL->CODSEN_V := SENHA->CODSEN_V
                  PRIVIL->CODMEN_V := ACCCOM->CODIGO_V
               ENDIF
            ENDIF
            PRIVIL->(DBCOMMIT(),DBUNLOCK())
         OTHERWISE
            NRETVAL:=1
      ENDCASE
ENDCASE
SETCOLOR(OLD)
RESTSCREEN(0,0,24,80,TELA)
RETURN NRETVAL